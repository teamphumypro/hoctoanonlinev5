# ===== DATABASE (bat buoc) =====
# Lay chuoi ket noi mien phi tai https://neon.tech (Create Project -> Connection string)
# Dang: postgresql://user:password@host/dbname?sslmode=require
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# ===== SESSION (bat buoc) =====
# Go bua mot chuoi bat ky 20-30 ky tu
SESSION_SECRET=thay-doi-chuoi-nay-bang-mot-chuoi-bi-mat-ngau-nhien

PORT=3000

# ===== VNPay (tuy chon - dang ky mien phi tai https://sandbox.vnpayment.vn de test) =====
VNP_TMN_CODE=
VNP_HASH_SECRET=
VNP_URL=https://sandbox.vnpayment.vn/paymentv2/vpcpay.html

# ===== MoMo (tuy chon - dang ky merchant test tai https://business.momo.vn) =====
MOMO_PARTNER_CODE=
MOMO_ACCESS_KEY=
MOMO_SECRET_KEY=
MOMO_ENDPOINT=https://test-payment.momo.vn/v2/gateway/api/create

# ===== ZaloPay (tuy chon - dang ky merchant test tai https://docs.zalopay.vn) =====
ZALOPAY_APP_ID=
ZALOPAY_KEY1=
ZALOPAY_ENDPOINT=https://sb-openapi.zalopay.vn/v2/create

# ===== Chuyen khoan QR - VietQR (mien phi, khong can dang ky) =====
