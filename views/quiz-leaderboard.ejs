<% var pageTitle = 'Bảng xếp hạng: ' + quiz.title %>
<%- include('partials/header') %>
<div class="row justify-content-center">
  <div class="col-lg-8">
    <div class="card p-4">
      <h4 class="fw-bold mb-1"><i class="fa-solid fa-trophy text-warning"></i> Bảng xếp hạng</h4>
      <p class="text-muted small mb-3"><%= quiz.title %></p>

      <a href="/thi/<%= quiz.id %>" class="btn btn-primary btn-sm mb-3">Làm bài / Làm lại</a>

      <table class="table">
        <thead><tr><th>#</th><th>Học viên</th><th>Điểm</th><th>Thời gian làm bài</th></tr></thead>
        <tbody>
          <% ranking.forEach((r, i) => { %>
            <tr class="<%= typeof currentUser !== 'undefined' && currentUser && currentUser.id === r.user_id ? 'table-primary' : '' %>">
              <td>
                <% if (i === 0) { %>🥇<% } else if (i === 1) { %>🥈<% } else if (i === 2) { %>🥉<% } else { %><%= i+1 %><% } %>
              </td>
              <td class="d-flex align-items-center gap-2">
                <img src="<%= r.avatar_url || '/img/placeholder.svg' %>" width="28" height="28" class="rounded-circle" style="object-fit:cover">
                <%= r.user_name %>
              </td>
              <td class="fw-bold"><%= r.score %>/<%= r.total %></td>
              <td class="text-muted small"><%= r.duration_seconds ? Math.floor(r.duration_seconds/60) + ' phút ' + (r.duration_seconds%60) + ' giây' : '—' %></td>
            </tr>
          <% }) %>
          <% if (ranking.length === 0) { %><tr><td colspan="4" class="text-center text-muted">Chưa có ai làm bài này.</td></tr><% } %>
        </tbody>
      </table>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
