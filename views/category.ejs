<% var pageTitle = category.name %>
<%- include('partials/header') %>
<h3 class="fw-bold mb-3"><%= category.name %></h3>
<div class="row g-3">
  <% courses.forEach(c => { %>
    <div class="col-md-3">
      <a href="/khoa-hoc/<%= c.slug %>" class="text-decoration-none text-dark">
        <div class="card course-card">
          <img src="<%= c.thumbnail_url || '/img/placeholder.svg' %>" class="w-100">
          <div class="p-3">
            <div class="fw-semibold mb-1"><%= c.title %></div>
            <div class="price-tag"><%= c.price > 0 ? formatVND(c.price) : 'Miễn phí' %></div>
          </div>
        </div>
      </a>
    </div>
  <% }) %>
  <% if (courses.length === 0) { %><p class="text-muted">Chưa có khóa học trong danh mục này.</p><% } %>
</div>
<%- include('partials/footer') %>
