<% var pageTitle = 'Thanh toán' %>
<%- include('partials/header') %>
<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="card p-4">
      <h4 class="fw-bold mb-2">Đơn hàng của bạn</h4>
      <ul class="list-group list-group-flush mb-3">
        <% items.forEach(i => { %>
          <li class="list-group-item d-flex justify-content-between px-0">
            <span><%= i.item_type === 'book' ? '📘' : '🎓' %> <%= i.title %></span>
            <span class="fw-semibold"><%= formatVND(i.price) %></span>
          </li>
        <% }) %>
      </ul>
      <div class="d-flex justify-content-between mb-3">
        <span class="fw-bold">Tổng cộng</span>
        <span class="price-tag fs-4"><%= formatVND(total) %></span>
      </div>

      <% if (typeof notice !== 'undefined' && notice) { %><div class="alert alert-warning small"><%= notice %></div><% } %>

      <% if (typeof codConfirmed !== 'undefined' && codConfirmed) { %>
        <div class="text-center border rounded p-3 mb-3">
          <i class="fa-solid fa-truck-fast fa-2x text-success mb-2"></i>
          <p class="fw-semibold mb-1">Đặt hàng COD thành công!</p>
          <p class="small text-muted mb-2">Mã đơn hàng #<%= order.id %> — bạn sẽ thanh toán <strong><%= formatVND(order.amount) %></strong> khi nhận hàng/kích hoạt khóa học.</p>
          <div class="text-start small bg-light rounded p-2">
            <div><strong>Người nhận:</strong> <%= order.recipient_name %></div>
            <div><strong>Điện thoại:</strong> <%= order.recipient_phone %></div>
            <div><strong>Địa chỉ:</strong> <%= order.recipient_address %></div>
          </div>
          <p class="small text-muted mt-2 mb-0">Quản trị viên sẽ liên hệ xác nhận rồi mở khóa học cho bạn.</p>
        </div>
      <% } else if (qrUrl) { %>
        <div class="text-center border rounded p-3 mb-3">
          <p class="fw-semibold mb-2">Quét mã QR để chuyển khoản</p>
          <img src="<%= qrUrl %>" style="max-width:260px" class="mb-2" onerror="document.getElementById('qrFallback').classList.remove('d-none'); this.classList.add('d-none')">
          <p class="small text-muted mb-0">Nội dung chuyển khoản đã được tự động điền sẵn (mã đơn hàng #<%= order.id %>).<br>
          Sau khi chuyển khoản, quản trị viên sẽ xác nhận và mở khóa học trong ít phút.</p>
          <div id="qrFallback" class="alert alert-warning small mt-2 d-none text-start">
            <p class="mb-2">Không hiện được ảnh QR. Bạn có thể chuyển khoản thủ công theo thông tin bên dưới:</p>
            <% if (typeof bankInfo !== 'undefined' && bankInfo && bankInfo.bank_account_no) { %>
              <div><strong>Ngân hàng (BIN):</strong> <%= bankInfo.bank_bin %></div>
              <div><strong>Số tài khoản:</strong> <%= bankInfo.bank_account_no %></div>
              <div><strong>Tên chủ TK:</strong> <%= bankInfo.bank_account_name %></div>
              <div><strong>Số tiền:</strong> <%= formatVND(order.amount) %></div>
              <div><strong>Nội dung CK:</strong> THANHTOAN DH<%= order.id %></div>
            <% } %>
            <a href="<%= qrUrl %>" target="_blank" class="d-inline-block mt-1">Xem chi tiết lỗi ảnh QR</a>
          </div>
        </div>
      <% } else if (methods && (methods.vnpay || methods.momo || methods.zalopay || methods.bank_transfer || methods.cod)) { %>
        <form method="POST" action="/thanh-toan" id="checkoutForm">
          <div class="border rounded p-3 mb-3">
            <p class="fw-semibold small mb-2">Thông tin khách hàng</p>
            <div class="mb-2"><input name="recipient_name" class="form-control" placeholder="Họ và tên" value="<%= typeof customer !== 'undefined' && customer ? customer.name : '' %>" required></div>
            <div class="row g-2 mb-2">
              <div class="col-md-6"><input name="recipient_phone" class="form-control" placeholder="Số điện thoại" value="<%= typeof customer !== 'undefined' && customer && customer.phone ? customer.phone : '' %>" required></div>
              <div class="col-md-6"><input type="number" name="recipient_birth_year" class="form-control" placeholder="Năm sinh" min="1930" max="2020" value="<%= typeof customer !== 'undefined' && customer && customer.birth_year ? customer.birth_year : '' %>"></div>
            </div>
            <textarea name="recipient_address" class="form-control" rows="2" placeholder="Địa chỉ" required><%= typeof customer !== 'undefined' && customer && customer.address ? customer.address : '' %></textarea>
          </div>

          <label class="form-label fw-semibold">Chọn phương thức thanh toán</label>
          <div class="list-group mb-3">
            <% if (methods.vnpay) { %><label class="list-group-item"><input class="form-check-input me-2 pm-radio" type="radio" name="payment_method" value="vnpay" checked> VNPay</label><% } %>
            <% if (methods.momo) { %><label class="list-group-item"><input class="form-check-input me-2 pm-radio" type="radio" name="payment_method" value="momo" <%= !methods.vnpay?'checked':'' %>> Ví MoMo</label><% } %>
            <% if (methods.zalopay) { %><label class="list-group-item"><input class="form-check-input me-2 pm-radio" type="radio" name="payment_method" value="zalopay" <%= (!methods.vnpay && !methods.momo)?'checked':'' %>> ZaloPay</label><% } %>
            <% if (methods.bank_transfer) { %><label class="list-group-item"><input class="form-check-input me-2 pm-radio" type="radio" name="payment_method" value="bank_transfer" <%= (!methods.vnpay && !methods.momo && !methods.zalopay)?'checked':'' %>> Chuyển khoản QR (VietQR)</label><% } %>
            <% if (methods.cod) { %><label class="list-group-item"><input class="form-check-input me-2 pm-radio" type="radio" name="payment_method" value="cod" id="pmCod" <%= (!methods.vnpay && !methods.momo && !methods.zalopay && !methods.bank_transfer)?'checked':'' %>> Thanh toán khi nhận hàng (COD)</label><% } %>
          </div>

          <button class="btn btn-primary w-100">Thanh toán</button>
        </form>
      <% } else if (!(typeof notice !== 'undefined' && notice)) { %>
        <div class="alert alert-warning small mb-0">
          Chưa có phương thức thanh toán nào được cấu hình. Quản trị viên vào <strong>Admin → Cài đặt thanh toán</strong> để thiết lập (chuyển khoản QR chỉ cần nhập số tài khoản ngân hàng là dùng được ngay, không cần đăng ký gì thêm).
        </div>
      <% } %>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
