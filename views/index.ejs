<% var pageTitle = 'Trang chủ' %>
<%- include('partials/header') %>

<% if (banners && banners.length) { %>
<div id="bannerCarousel" class="carousel slide mb-4 hero" data-bs-ride="carousel" style="overflow:hidden;border-radius:16px;">
  <div class="carousel-inner">
    <% banners.forEach((b, i) => { %>
      <div class="carousel-item <%= i===0 ? 'active' : '' %>">
        <a href="<%= b.link_url || '#' %>"><img src="<%= b.image_url %>" class="d-block w-100" style="object-fit:contain"></a>
      </div>
    <% }) %>
  </div>
</div>
<% } else { %>
<div class="hero p-5 mb-4">
  <h1 class="fw-bold"><%= site.hero_title %></h1>
  <p class="mb-0"><%= site.hero_subtitle %></p>
  <div class="seal d-none d-md-flex">HỌC<br>ONLINE</div>
</div>
<% } %>

<div class="row">
  <div class="col-lg-3 mb-4">
    <div class="card p-3">
      <h6 class="fw-bold mb-3"><i class="fa-solid fa-bars"></i> Danh mục</h6>
      <div class="sidebar-cat">
        <% categories.forEach(cat => { %>
          <div class="mb-1">
            <a href="/danh-muc/<%= cat.slug %>" class="fw-semibold"><%= cat.name %></a>
            <% if (cat.children && cat.children.length) { %>
              <ul class="list-unstyled ms-3 small">
                <% cat.children.forEach(child => { %>
                  <li><a href="/danh-muc/<%= child.slug %>"><i class="fa-solid fa-angle-right small"></i> <%= child.name %></a></li>
                <% }) %>
              </ul>
            <% } %>
          </div>
        <% }) %>
      </div>
    </div>
  </div>

  <div class="col-lg-9">
    <h4 class="fw-bold mb-3">Khóa học nổi bật</h4>
    <div class="row g-3">
      <% courses.forEach(c => { %>
        <div class="col-md-4">
          <a href="/khoa-hoc/<%= c.slug %>" class="text-decoration-none text-dark">
            <div class="card course-card">
              <img src="<%= c.thumbnail_url || '/img/placeholder.svg' %>" class="w-100">
              <div class="p-3">
                <% if (c.category_name) { %><span class="badge badge-cat mb-2"><%= c.category_name %></span><% } %>
                <div class="fw-semibold mb-1"><%= c.title %></div>
                <div class="small text-muted mb-2"><%= c.short_desc %></div>
                <div class="price-tag"><%= c.price > 0 ? formatVND(c.price) : 'Miễn phí' %></div>
              </div>
            </div>
          </a>
        </div>
      <% }) %>
      <% if (courses.length === 0) { %><p class="text-muted">Chưa có khóa học nào.</p><% } %>
    </div>

    <% if (news && news.length) { %>
    <h4 class="fw-bold mt-5 mb-3">Tin tức mới</h4>
    <div class="row g-3">
      <% news.forEach(n => { %>
        <div class="col-md-3">
          <a href="/tin-tuc/<%= n.slug %>" class="text-decoration-none text-dark">
            <div class="card h-100">
              <img src="<%= n.thumbnail_url || '/img/placeholder.svg' %>" class="w-100" style="height:100px;object-fit:cover">
              <div class="p-2 small fw-semibold"><%= n.title %></div>
            </div>
          </a>
        </div>
      <% }) %>
    </div>
    <% } %>
  </div>
</div>

<%- include('partials/footer') %>
