<% var pageTitle = book.title %>
<%- include('partials/header') %>
<div class="row g-4">
  <div class="col-lg-8">
    <div class="card p-3 mb-3">
      <h2 class="fw-bold mb-0" style="font-size:1.5rem"><%= book.title %></h2>
      <% if (book.author) { %><div class="text-muted">Tác giả: <%= book.author %></div><% } %>
    </div>
    <div class="card p-3 mb-3">
      <img src="<%= book.cover_url || '/img/placeholder.svg' %>" class="w-100 rounded mb-3" style="max-height:360px;object-fit:contain">
      <% if (book.short_desc) { %><p class="text-muted"><%= book.short_desc %></p><% } %>
      <% if (book.description) { %><div><%- book.description %></div><% } %>
    </div>
    <div class="card p-3">
      <h6 class="fw-bold mb-2">Danh sách chương (<%= chapters.length %>)</h6>
      <ul class="list-group list-group-flush">
        <% chapters.forEach((c, i) => { %>
          <li class="list-group-item d-flex justify-content-between align-items-center">
            <span>Chương <%= i+1 %>: <%= c.title %></span>
            <% if (book.price === 0 || c.is_free || purchased) { %><span class="badge bg-success">Đọc được</span>
            <% } else { %><i class="fa-solid fa-lock text-muted"></i><% } %>
          </li>
        <% }) %>
        <% if (chapters.length === 0) { %><li class="list-group-item text-muted">Chưa có chương nào.</li><% } %>
      </ul>
    </div>
  </div>
  <div class="col-lg-4">
    <div class="card p-3" style="position:sticky; top:80px">
      <div class="d-flex align-items-baseline gap-2 mb-3">
        <div class="fs-3 fw-bold price-tag"><%= book.price > 0 ? formatVND(book.price) : 'Miễn phí' %></div>
        <% if (book.compare_at_price && book.compare_at_price > book.price) { %>
          <div class="text-muted text-decoration-line-through"><%= formatVND(book.compare_at_price) %></div>
        <% } %>
      </div>
      <a href="/doc-sach-online/<%= book.slug %>/doc" class="btn btn-primary w-100 mb-2"><i class="fa-solid fa-book-open"></i> Đọc ngay (kiểu lật trang)</a>
      <% if (book.price > 0 && !purchased) { %>
        <form method="POST" action="/gio-hang/them" class="mb-2">
          <input type="hidden" name="item_type" value="online_book">
          <input type="hidden" name="item_id" value="<%= book.id %>">
          <button class="btn btn-outline-primary w-100">Thêm vào giỏ hàng</button>
        </form>
        <a href="/mua-ngay/doc-sach-online/<%= book.slug %>" class="btn btn-outline-primary w-100">Mua trọn bộ ngay</a>
      <% } %>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
