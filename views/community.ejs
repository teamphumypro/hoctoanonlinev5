<% var pageTitle = 'Cộng đồng' %>
<%- include('partials/header') %>

<div class="row justify-content-center">
  <div class="col-lg-7">
    <div class="card p-3 mb-4">
      <h6 class="fw-bold mb-2">Đăng bài mới</h6>
      <form method="POST" action="/cong-dong">
        <div class="mb-2"><textarea name="content" class="form-control" rows="3" placeholder="Bạn đang nghĩ gì?"></textarea></div>
        <div class="row g-2 mb-2">
          <div class="col-md-6"><input type="url" name="image_url" class="form-control form-control-sm" placeholder="Link ảnh (tùy chọn)"></div>
          <div class="col-md-6"><input type="url" name="video_url" class="form-control form-control-sm" placeholder="Link video Youtube/bất kỳ (tùy chọn)"></div>
        </div>
        <div class="mb-2 d-flex gap-3 small">
          <label><input type="radio" name="video_orientation" value="ngang" checked> Video ngang</label>
          <label><input type="radio" name="video_orientation" value="doc"> Video dọc</label>
        </div>
        <button class="btn btn-primary btn-sm">Đăng bài</button>
      </form>
    </div>

    <% posts.forEach(p => { %>
      <div class="card p-3 mb-3">
        <div class="d-flex justify-content-between align-items-start mb-2">
          <div class="d-flex align-items-center gap-2">
            <img src="<%= p.avatar_url || '/img/placeholder.svg' %>" width="36" height="36" class="rounded-circle" style="object-fit:cover">
            <div>
              <div class="fw-semibold"><%= p.user_name %></div>
              <div class="small text-muted"><%= formatDate(p.created_at) %></div>
            </div>
          </div>
          <% if (currentUser && currentUser.id === p.user_id) { %>
            <form method="POST" action="/cong-dong/<%= p.id %>/xoa" onsubmit="return confirm('Xóa bài viết này?')">
              <button class="btn btn-sm btn-link text-danger p-0">Xóa</button>
            </form>
          <% } %>
        </div>

        <% if (p.content) { %><p class="mb-2" style="white-space:pre-wrap"><%= p.content %></p><% } %>
        <% if (p.image_url) { %><img src="<%= p.image_url %>" class="w-100 rounded mb-2" style="max-height:420px;object-fit:contain;background:#f0f0f7"><% } %>

        <% if (p.embed) { %>
          <% if (p.embed.type === 'youtube' || p.embed.type === 'vimeo' || p.embed.type === 'drive') { %>
            <div class="<%= p.video_orientation === 'doc' ? 'mx-auto' : '' %> mb-2" style="<%= p.video_orientation === 'doc' ? 'max-width:280px' : '' %>">
              <div class="<%= p.video_orientation === 'doc' ? 'ratio' : 'ratio ratio-16x9' %>" style="<%= p.video_orientation === 'doc' ? 'aspect-ratio:9/16' : '' %>">
                <% if (p.embed.type === 'youtube') { %>
                  <iframe src="https://www.youtube-nocookie.com/embed/<%= p.embed.id %>" allowfullscreen></iframe>
                <% } else if (p.embed.type === 'vimeo') { %>
                  <iframe src="https://player.vimeo.com/video/<%= p.embed.id %>" allowfullscreen></iframe>
                <% } else { %>
                  <iframe src="<%= p.embed.embedUrl %>" allowfullscreen></iframe>
                <% } %>
              </div>
            </div>
          <% } else { %>
            <a href="<%= p.embed.url %>" target="_blank" class="btn btn-sm btn-outline-secondary mb-2"><i class="fa-solid fa-video"></i> Xem video ngoài</a>
          <% } %>
        <% } %>

        <div class="d-flex align-items-center gap-3 border-top pt-2 mt-1">
          <form method="POST" action="/cong-dong/<%= p.id %>/thich">
            <button class="btn btn-sm <%= p.liked_by_me>0 ? 'btn-primary' : 'btn-outline-secondary' %>">
              <i class="fa-solid fa-thumbs-up"></i> Thích (<%= p.like_count %>)
            </button>
          </form>
        </div>

        <div class="mt-2">
          <% p.comments.forEach(c => { %>
            <div class="d-flex gap-2 mb-1 small">
              <img src="<%= c.avatar_url || '/img/placeholder.svg' %>" width="24" height="24" class="rounded-circle" style="object-fit:cover">
              <div class="bg-light rounded px-2 py-1"><strong><%= c.user_name %>:</strong> <%= c.content %></div>
            </div>
          <% }) %>
          <form method="POST" action="/cong-dong/<%= p.id %>/binh-luan" class="d-flex gap-2 mt-2">
            <input name="content" class="form-control form-control-sm" placeholder="Viết bình luận...">
            <button class="btn btn-sm btn-outline-primary">Gửi</button>
          </form>
        </div>
      </div>
    <% }) %>
    <% if (posts.length === 0) { %><p class="text-muted text-center">Chưa có bài đăng nào. Hãy là người đầu tiên!</p><% } %>
  </div>
</div>

<%- include('partials/footer') %>
