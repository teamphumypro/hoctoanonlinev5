<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' - ' + site.site_name_1 + site.site_name_2 : site.site_name_1 + site.site_name_2 + ' - ' + site.hero_subtitle %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>
<nav class="navbar navbar-expand-lg bg-white border-bottom sticky-top">
  <div class="container">
    <a class="navbar-brand" href="/"><%= site.site_name_1 %><span class="brand-accent"><%= site.site_name_2 %></span></a>
    <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav1">
      <span class="navbar-toggler-icon"></span>
    </button>
    <div class="collapse navbar-collapse" id="nav1">
      <ul class="navbar-nav me-auto ms-3">
        <li class="nav-item"><a class="nav-link" href="/">Trang chủ</a></li>
        <% navItems.forEach(item => { %>
          <li class="nav-item"><a class="nav-link" href="<%= item.url %>"><%= item.label %></a></li>
        <% }) %>
      </ul>
      <ul class="navbar-nav align-items-lg-center">
        <% if (typeof currentUser !== 'undefined' && currentUser) { %>
          <li class="nav-item"><a class="nav-link" href="/gio-hang" title="Giỏ hàng"><i class="fa-solid fa-cart-shopping"></i></a></li>
          <li class="nav-item dropdown">
            <a class="nav-link dropdown-toggle d-flex align-items-center gap-2" href="#" data-bs-toggle="dropdown">
              <img src="<%= currentUser.avatar_url || '/img/placeholder.svg' %>" width="28" height="28" class="rounded-circle" style="object-fit:cover">
              <%= currentUser.name %>
            </a>
            <ul class="dropdown-menu dropdown-menu-end">
              <li><a class="dropdown-item" href="/tai-khoan">Khóa học của tôi</a></li>
              <li><a class="dropdown-item" href="/tai-khoan/tu-sach">Tủ sách của tôi</a></li>
              <li><a class="dropdown-item" href="/tai-khoan/doc-sach-online-da-mua">Sách đọc online đã mua</a></li>
              <li><a class="dropdown-item" href="/tai-khoan/chung-chi">Chứng chỉ</a></li>
              <li><a class="dropdown-item" href="/cong-dong">Cộng đồng</a></li>
              <li><a class="dropdown-item" href="/kich-hoat">Nhập mã kích hoạt</a></li>
              <li><a class="dropdown-item" href="/tai-khoan/doi-mat-khau">Đổi mật khẩu</a></li>
              <li><hr class="dropdown-divider"></li>
              <li><a class="dropdown-item text-danger" href="/dang-xuat">Đăng xuất</a></li>
            </ul>
          </li>
        <% } else { %>
          <li class="nav-item"><a class="btn btn-outline-primary btn-sm me-2" href="/dang-nhap">Đăng nhập</a></li>
          <li class="nav-item"><a class="btn btn-primary btn-sm" href="/dang-ky">Đăng ký</a></li>
        <% } %>
      </ul>
    </div>
  </div>
</nav>
<main class="container my-4">
