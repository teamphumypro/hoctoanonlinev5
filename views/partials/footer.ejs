</main>
<footer class="border-top bg-white py-4 mt-5">
  <div class="container text-center text-muted small">
    &copy; <%= new Date().getFullYear() %> <%= site.footer_text %>
  </div>
</footer>

<% if (typeof activePopup !== 'undefined' && activePopup) { %>
<div class="modal fade" id="adPopupModal" tabindex="-1">
  <div class="modal-dialog modal-dialog-centered">
    <div class="modal-content">
      <button type="button" class="btn-close position-absolute top-0 end-0 m-2 bg-white rounded-circle p-2" style="z-index:10" data-bs-dismiss="modal"></button>
      <a href="<%= activePopup.link_url || '#' %>">
        <img src="<%= activePopup.image_url %>" class="w-100 rounded" style="max-height:80vh;object-fit:contain">
      </a>
    </div>
  </div>
</div>
<script>
  if (!sessionStorage.getItem('adPopupShown_<%= activePopup.id %>')) {
    window.addEventListener('DOMContentLoaded', () => {
      new bootstrap.Modal(document.getElementById('adPopupModal')).show();
      sessionStorage.setItem('adPopupShown_<%= activePopup.id %>', '1');
    });
  }
</script>
<% } %>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
