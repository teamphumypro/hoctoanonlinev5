<%
// Partial dung chung cho cay danh muc dang thu gon/mo rong (+/-).
// Locals bat buoc: categories (tree), baseUrl (vd '/sach' hoac '/doc-sach-online')
// Locals tuy chon: activeCategory (slug dang chon), extraQuery (chuoi vd '&the_loai=abc')
var _extraQuery = typeof extraQuery !== 'undefined' ? extraQuery : '';
var _activeCategory = typeof activeCategory !== 'undefined' ? activeCategory : null;

function _catTreeContainsActive(node, activeSlug) {
  if (!activeSlug) return false;
  if (node.slug === activeSlug) return true;
  if (node.children && node.children.length) return node.children.some(function (ch) { return _catTreeContainsActive(ch, activeSlug); });
  return false;
}

function _renderCatTreeNodes(nodes, level) {
%>
  <ul class="cat-tree-list <%= level === 0 ? 'cat-tree-root' : '' %>">
    <% nodes.forEach(function (node) {
         var hasChildren = node.children && node.children.length;
         var isActive = _activeCategory === node.slug;
         var isOpen = hasChildren && _catTreeContainsActive(node, _activeCategory);
    %>
      <li class="cat-tree-item">
        <div class="cat-tree-row">
          <% if (hasChildren) { %>
            <button type="button" class="cat-tree-toggle <%= isOpen ? 'is-open' : '' %>" aria-label="Thu gọn/mở rộng">
              <i class="fa-solid <%= isOpen ? 'fa-square-minus' : 'fa-square-plus' %>"></i>
            </button>
          <% } else { %>
            <span class="cat-tree-toggle cat-tree-toggle-leaf"><i class="fa-regular fa-file-lines"></i></span>
          <% } %>
          <a href="<%= baseUrl %>?danh_muc=<%= node.slug %><%= _extraQuery %>" class="cat-tree-link <%= isActive ? 'is-active' : '' %>"><%= node.name %></a>
        </div>
        <% if (hasChildren) { %>
          <div class="cat-tree-children <%= isOpen ? '' : 'is-collapsed' %>">
            <% _renderCatTreeNodes(node.children, level + 1); %>
          </div>
        <% } %>
      </li>
    <% }); %>
  </ul>
<%
}
%>

<div class="cat-tree">
  <div class="cat-tree-row cat-tree-row-all">
    <span class="cat-tree-toggle cat-tree-toggle-leaf"><i class="fa-solid fa-layer-group"></i></span>
    <a href="<%= baseUrl %>" class="cat-tree-link <%= !_activeCategory ? 'is-active' : '' %>">Tất cả</a>
  </div>
  <% _renderCatTreeNodes(categories, 0); %>
</div>

<script>
(function () {
  if (window.__catTreeInit) return;
  window.__catTreeInit = true;
  document.addEventListener('click', function (e) {
    var btn = e.target.closest('.cat-tree-toggle:not(.cat-tree-toggle-leaf)');
    if (!btn) return;
    e.preventDefault();
    var row = btn.closest('.cat-tree-item');
    var children = row && row.querySelector(':scope > .cat-tree-children');
    if (!children) return;
    var icon = btn.querySelector('i');
    var opening = children.classList.contains('is-collapsed');
    children.classList.toggle('is-collapsed');
    btn.classList.toggle('is-open', opening);
    if (icon) {
      icon.classList.toggle('fa-square-plus', !opening);
      icon.classList.toggle('fa-square-minus', opening);
    }
  });
})();
</script>
