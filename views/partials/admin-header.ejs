<!DOCTYPE html>
<html lang="vi">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= typeof pageTitle !== 'undefined' ? pageTitle + ' - Quản trị' : 'Quản trị' %></title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link href="/css/style.css" rel="stylesheet">
</head>
<body>
<div class="admin-wrap">
  <div class="admin-sidebar py-3">
    <div class="px-3 mb-3 text-white fw-bold fs-5"><%= site.site_name_1 %><span style="color:var(--orange)"><%= site.site_name_2 %></span> <span class="fw-normal fs-6 opacity-75">Admin</span></div>
    <a href="/admin" class="<%= path === '/admin' ? 'active' : '' %>"><i class="fa-solid fa-chart-line me-2"></i>Dashboard</a>

    <div class="section-title">📚 Nội dung học tập</div>
    <a href="/admin/danh-muc" class="<%= path.startsWith('/admin/danh-muc') ? 'active' : '' %>"><i class="fa-solid fa-sitemap me-2"></i>Danh mục</a>
    <a href="/admin/khoa-hoc" class="<%= path.startsWith('/admin/khoa-hoc') ? 'active' : '' %>"><i class="fa-solid fa-book-open me-2"></i>Khóa học / Chương / Bài / Video</a>
    <a href="/admin/sach" class="<%= path === '/admin/sach' || path.startsWith('/admin/sach/them') || path.match(/^\/admin\/sach\/\d+/) ? 'active' : '' %>"><i class="fa-solid fa-book me-2"></i>Sách (bán/tải file)</a>
    <a href="/admin/doc-sach-online" class="<%= path.startsWith('/admin/doc-sach-online') && !path.startsWith('/admin/doc-sach-online/danh-muc') ? 'active' : '' %>"><i class="fa-solid fa-book-open-reader me-2"></i>Đọc sách online</a>
    <a href="/admin/doc-sach-online/danh-muc" class="<%= path.startsWith('/admin/doc-sach-online/danh-muc') ? 'active' : '' %>"><i class="fa-solid fa-sitemap me-2"></i>Danh mục đọc sách online</a>
    <a href="/admin/sach/danh-muc" class="<%= path.startsWith('/admin/sach/danh-muc') ? 'active' : '' %>"><i class="fa-solid fa-sitemap me-2"></i>Danh mục sách</a>
    <a href="/admin/sach/loai" class="<%= path === '/admin/sach/loai' ? 'active' : '' %>"><i class="fa-solid fa-tags me-2"></i>Thể loại sách</a>
    <a href="/admin/phong-thi" class="<%= path.startsWith('/admin/phong-thi') || path.startsWith('/admin/bai-kiem-tra') ? 'active' : '' %>"><i class="fa-solid fa-user-graduate me-2"></i>Thực chiến phòng thi</a>

    <div class="section-title">👨‍🎓 Học viên</div>
    <a href="/admin/hoc-vien" class="<%= path.startsWith('/admin/hoc-vien') ? 'active' : '' %>"><i class="fa-solid fa-users me-2"></i>Danh sách học viên</a>

    <div class="section-title">💳 Thanh toán</div>
    <a href="/admin/don-hang" class="<%= path.startsWith('/admin/don-hang') ? 'active' : '' %>"><i class="fa-solid fa-receipt me-2"></i>Đơn hàng</a>
    <a href="/admin/ma-kich-hoat" class="<%= path.startsWith('/admin/ma-kich-hoat') ? 'active' : '' %>"><i class="fa-solid fa-key me-2"></i>Mã kích hoạt</a>

    <div class="section-title">🎨 Giao diện &amp; Marketing</div>
    <a href="/admin/banner" class="<%= path.startsWith('/admin/banner') ? 'active' : '' %>"><i class="fa-solid fa-image me-2"></i>Banner</a>
    <a href="/admin/popup" class="<%= path.startsWith('/admin/popup') ? 'active' : '' %>"><i class="fa-solid fa-window-restore me-2"></i>Popup quảng cáo</a>
    <a href="/admin/menu" class="<%= path.startsWith('/admin/menu') ? 'active' : '' %>"><i class="fa-solid fa-bars me-2"></i>Menu điều hướng</a>
    <a href="/admin/tin-tuc" class="<%= path.startsWith('/admin/tin-tuc') ? 'active' : '' %>"><i class="fa-solid fa-newspaper me-2"></i>Tin tức</a>

    <div class="section-title">⚙ Cài đặt hệ thống</div>
    <a href="/admin/cai-dat/chung" class="<%= path === '/admin/cai-dat/chung' ? 'active' : '' %>"><i class="fa-solid fa-gear me-2"></i>Cài đặt chung (chữ trên web)</a>
    <a href="/admin/cai-dat/ai" class="<%= path === '/admin/cai-dat/ai' ? 'active' : '' %>"><i class="fa-solid fa-robot me-2"></i>Cài đặt AI (nhập đề từ file)</a>
    <a href="/admin/cai-dat/thanh-toan" class="<%= path.startsWith('/admin/cai-dat/thanh-toan') ? 'active' : '' %>"><i class="fa-solid fa-money-check-dollar me-2"></i>Cài đặt thanh toán</a>
    <a href="/admin/nhan-su" class="<%= path.startsWith('/admin/nhan-su') ? 'active' : '' %>"><i class="fa-solid fa-user-shield me-2"></i>Nhân sự &amp; phân quyền</a>

    <div class="section-title">👤 Tài khoản</div>
    <a href="/admin/doi-mat-khau" class="<%= path.startsWith('/admin/doi-mat-khau') ? 'active' : '' %>"><i class="fa-solid fa-lock me-2"></i>Đổi mật khẩu</a>
    <a href="/admin/dang-xuat" class="text-danger"><i class="fa-solid fa-right-from-bracket me-2"></i>Đăng xuất</a>
  </div>
  <div class="admin-main">
    <div class="d-flex justify-content-between align-items-center mb-4">
      <h4 class="fw-bold mb-0"><%= typeof pageTitle !== 'undefined' ? pageTitle : '' %></h4>
      <div class="text-muted small">Xin chào, <strong><%= adminUser.name %></strong> (<%= adminUser.role %>)</div>
    </div>
