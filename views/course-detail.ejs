<% var pageTitle = course.title %>
<%- include('partials/header') %>

<nav class="small text-muted mb-3">
  <a href="/">Trang chủ</a>
  <% if (course.category_slug) { %> &raquo; <a href="/danh-muc/<%= course.category_slug %>"><%= course.category_name %></a><% } %>
  &raquo; <span class="text-dark"><%= course.title %></span>
</nav>

<div class="row g-4">
  <div class="col-lg-8">
    <div class="card p-3 mb-3">
      <h2 class="fw-bold mb-0" style="font-size:1.5rem"><%= course.title %></h2>
    </div>

    <div class="card p-0 mb-3 overflow-hidden">
      <ul class="nav nav-tabs px-3 pt-2" id="courseTabs">
        <li class="nav-item"><button class="nav-link active" data-tab="noidung">Nội dung</button></li>
        <li class="nav-item"><button class="nav-link" data-tab="binhluan">Bình luận</button></li>
        <li class="nav-item"><button class="nav-link" data-tab="danhgia">Đánh giá</button></li>
      </ul>

      <div class="tab-pane p-3" id="tab-noidung">
        <% var introEmbed = course.intro_video_url ? embedVideoInfo(course.intro_video_url) : null;
           var previewVideo = null;
           if (!introEmbed) {
             for (const ch of chapters) { for (const l of ch.lessons) { if (l.is_preview && l.videos.length) { previewVideo = l.videos[0]; break; } } if (previewVideo) break; }
           } %>

        <% if (introEmbed) { %>
          <div class="ratio ratio-16x9 mb-3 bg-dark rounded overflow-hidden">
            <% if (introEmbed.type === 'youtube') { %>
              <iframe src="https://www.youtube-nocookie.com/embed/<%= introEmbed.id %>" allowfullscreen></iframe>
            <% } else if (introEmbed.type === 'vimeo') { %>
              <iframe src="https://player.vimeo.com/video/<%= introEmbed.id %>" allowfullscreen></iframe>
            <% } else if (introEmbed.type === 'drive') { %>
              <iframe src="<%= introEmbed.embedUrl %>" allowfullscreen></iframe>
            <% } else { %>
              <video controls class="w-100 h-100"><source src="<%= introEmbed.url %>"></video>
            <% } %>
          </div>
        <% } else if (previewVideo) { %>
          <div class="ratio ratio-16x9 mb-3 bg-dark rounded overflow-hidden">
            <% if (previewVideo.source_type === 'youtube') { %>
              <iframe src="https://www.youtube-nocookie.com/embed/<%= previewVideo.source_value %>" allowfullscreen></iframe>
            <% } else if (previewVideo.source_type === 'vimeo') { %>
              <iframe src="https://player.vimeo.com/video/<%= previewVideo.source_value %>" allowfullscreen></iframe>
            <% } else if (previewVideo.source_type === 'drive') { %>
              <iframe src="<%= previewVideo.source_value.replace('/view','/preview') %>" allowfullscreen></iframe>
            <% } else { %>
              <video controls class="w-100 h-100"><source src="<%= previewVideo.source_value %>"></video>
            <% } %>
          </div>
        <% } else { %>
          <img src="<%= course.thumbnail_url || '/img/placeholder.svg' %>" class="w-100 rounded mb-3" style="max-height:360px;object-fit:cover">
        <% } %>

        <% if (course.short_desc) { %><p class="text-muted"><%= course.short_desc %></p><% } %>
        <% if (course.description) { %><div class="mb-3"><%- course.description %></div><% } %>

        <% if (course.teacher_name) { %>
        <div class="border rounded p-3 mb-3">
          <h6 class="fw-bold mb-1">Giáo viên</h6>
          <div><%= course.teacher_name %></div>
        </div>
        <% } %>

        <h6 class="fw-bold mb-2">Giáo trình khóa học</h6>
        <div class="accordion" id="chapAcc">
          <% chapters.forEach((ch, ci) => { %>
            <div class="accordion-item">
              <h2 class="accordion-header">
                <button class="accordion-button <%= ci>0?'collapsed':'' %>" data-bs-toggle="collapse" data-bs-target="#c<%= ch.id %>">
                  <%= ch.title %> <span class="text-muted ms-2 small">(<%= ch.lessons.length %> bài)</span>
                </button>
              </h2>
              <div id="c<%= ch.id %>" class="accordion-collapse collapse <%= ci===0?'show':'' %>" data-bs-parent="#chapAcc">
                <div class="accordion-body p-0">
                  <ul class="list-group list-group-flush">
                    <% ch.lessons.forEach(l => { %>
                      <li class="list-group-item d-flex justify-content-between align-items-center">
                        <a href="/hoc/<%= l.id %>" class="text-decoration-none text-dark">
                          <i class="fa-solid <%= l.videos.length ? 'fa-circle-play' : 'fa-file-lines' %> text-primary"></i>
                          <%= l.title %>
                        </a>
                        <% if (l.is_preview) { %><span class="badge bg-success">Học thử</span>
                        <% } else if (!enrolled) { %><i class="fa-solid fa-lock text-muted"></i><% } %>
                      </li>
                    <% }) %>
                  </ul>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      </div>

      <div class="tab-pane p-4 text-center text-muted d-none" id="tab-binhluan">Tính năng bình luận đang được phát triển.</div>
      <div class="tab-pane p-4 text-center text-muted d-none" id="tab-danhgia">Tính năng đánh giá đang được phát triển.</div>
    </div>
  </div>

  <div class="col-lg-4">
    <div class="card p-0 overflow-hidden" style="position:sticky; top:80px">
      <img src="<%= course.thumbnail_url || '/img/placeholder.svg' %>" class="w-100" style="height:180px;object-fit:cover">
      <div class="p-3">
        <div class="d-flex align-items-baseline gap-2 mb-3">
          <div class="fs-3 fw-bold price-tag"><%= course.price > 0 ? formatVND(course.price) : 'Miễn phí' %></div>
          <% if (course.compare_at_price && course.compare_at_price > course.price) { %>
            <div class="text-muted text-decoration-line-through"><%= formatVND(course.compare_at_price) %></div>
          <% } %>
        </div>

        <% if (enrolled) { %>
          <a href="/tai-khoan" class="btn btn-success w-100 mb-2">Vào học ngay</a>
        <% } else { %>
          <a href="/kich-hoat" class="btn btn-outline-primary w-100 mb-2">Kích hoạt khóa học</a>
          <form method="POST" action="/gio-hang/them" class="mb-2">
            <input type="hidden" name="item_type" value="course">
            <input type="hidden" name="item_id" value="<%= course.id %>">
            <button class="btn btn-outline-primary w-100">Thêm vào giỏ hàng</button>
          </form>
          <a href="/mua-ngay/khoa-hoc/<%= course.slug %>" class="btn btn-primary w-100">Đăng ký học</a>
        <% } %>

        <hr>
        <ul class="list-unstyled small text-muted mb-0">
          <li class="mb-2"><i class="fa-solid fa-layer-group me-2"></i><%= chapters.length %> chương học</li>
          <li class="mb-2"><i class="fa-solid fa-list-check me-2"></i><%= chapters.reduce((sum,ch)=>sum+ch.lessons.length,0) %> bài học</li>
          <% if (course.view_count) { %><li><i class="fa-solid fa-eye me-2"></i><%= course.view_count %> lượt xem</li><% } %>
        </ul>
      </div>
    </div>
  </div>
</div>

<script>
  document.querySelectorAll('#courseTabs .nav-link').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('#courseTabs .nav-link').forEach(b => b.classList.remove('active'));
      document.querySelectorAll('.tab-pane').forEach(p => p.classList.add('d-none'));
      btn.classList.add('active');
      document.getElementById('tab-' + btn.dataset.tab).classList.remove('d-none');
    });
  });
</script>

<%- include('partials/footer') %>
