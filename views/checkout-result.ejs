<% var pageTitle = 'Kết quả thanh toán' %>
<%- include('partials/header') %>
<div class="text-center py-5">
  <% if (success) { %>
    <i class="fa-solid fa-circle-check fa-4x text-success mb-3"></i>
    <h4>Thanh toán thành công!</h4>
    <p class="text-muted">Khóa học đã được mở khóa trong tài khoản của bạn.</p>
    <a href="/tai-khoan" class="btn btn-primary">Vào học ngay</a>
  <% } else { %>
    <i class="fa-solid fa-circle-xmark fa-4x text-danger mb-3"></i>
    <h4>Thanh toán không thành công</h4>
    <a href="/" class="btn btn-outline-primary">Về trang chủ</a>
  <% } %>
</div>
<%- include('partials/footer') %>
