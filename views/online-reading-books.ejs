<% var pageTitle = 'Đọc sách online' %>
<%- include('partials/header') %>

<div class="hero p-5 mb-4 text-center">
  <h1 class="fw-bold">Đọc sách online</h1>
  <p class="mb-0">Đọc trực tiếp trên web theo kiểu lật trang — không cần tải file về máy.</p>
</div>

<div class="row g-3">
  <% books.forEach(b => { %>
    <div class="col-md-3">
      <a href="/doc-sach-online/<%= b.slug %>" class="text-decoration-none text-dark">
        <div class="card course-card">
          <img src="<%= b.cover_url || '/img/placeholder.svg' %>" class="w-100" style="height:220px;object-fit:cover">
          <div class="p-3">
            <div class="fw-semibold mb-1"><%= b.title %></div>
            <div class="small text-muted mb-2"><%= b.author %> — <%= b.chapter_count %> chương</div>
            <div class="price-tag"><%= b.price > 0 ? formatVND(b.price) : 'Miễn phí' %></div>
          </div>
        </div>
      </a>
    </div>
  <% }) %>
  <% if (books.length === 0) { %><p class="text-muted">Chưa có sách nào hỗ trợ đọc online.</p><% } %>
</div>

<%- include('partials/footer') %>
