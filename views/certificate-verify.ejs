<% var pageTitle = 'Xác thực chứng chỉ' %>
<%- include('partials/header') %>
<div class="row justify-content-center">
  <div class="col-md-6">
    <div class="card p-4 text-center">
      <% if (cert) { %>
        <i class="fa-solid fa-circle-check fa-3x text-success mb-3"></i>
        <h5 class="fw-bold">Chứng chỉ hợp lệ</h5>
        <p class="mb-1"><strong>Học viên:</strong> <%= cert.student_name %></p>
        <p class="mb-1"><strong>Khóa học:</strong> <%= cert.course_title %></p>
        <p class="mb-1"><strong>Mã chứng chỉ:</strong> <%= cert.certificate_code %></p>
        <p class="mb-0"><strong>Ngày cấp:</strong> <%= formatDate(cert.issued_at) %></p>
      <% } else { %>
        <i class="fa-solid fa-circle-xmark fa-3x text-danger mb-3"></i>
        <h5 class="fw-bold">Không tìm thấy chứng chỉ</h5>
        <p class="text-muted mb-0">Mã chứng chỉ không hợp lệ hoặc không tồn tại.</p>
      <% } %>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
