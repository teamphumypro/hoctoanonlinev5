<% var pageTitle = 'Tin tức' %>
<%- include('partials/header') %>
<h3 class="fw-bold mb-3">Tin tức</h3>
<div class="row g-3">
  <% news.forEach(n => { %>
    <div class="col-md-4">
      <a href="/tin-tuc/<%= n.slug %>" class="text-decoration-none text-dark">
        <div class="card h-100">
          <img src="<%= n.thumbnail_url || '/img/placeholder.svg' %>" class="w-100" style="height:160px;object-fit:cover">
          <div class="p-3 fw-semibold"><%= n.title %></div>
        </div>
      </a>
    </div>
  <% }) %>
</div>
<%- include('partials/footer') %>
