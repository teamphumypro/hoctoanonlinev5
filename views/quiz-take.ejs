<% var pageTitle = quiz.title %>
<%- include('partials/header') %>

<% if (quiz.pdf_exam_mode) { %>
<style>
  body{overflow:hidden}.pdf-exam-shell{height:calc(100vh - 68px);display:grid;grid-template-columns:minmax(0,1.55fr) minmax(360px,.8fr);background:#e9edf3}
  .exam-paper{min-width:0;display:flex;flex-direction:column;border-right:1px solid #d8dde6}.exam-answer{min-width:0;background:#fff;display:flex;flex-direction:column}
  .exam-bar{min-height:54px;background:#fff;border-bottom:1px solid #dfe3ea;display:flex;align-items:center;gap:8px;padding:8px 12px;flex-wrap:wrap}
  .flip-reader{flex:1;min-height:0;overflow:hidden;position:relative;perspective:1900px;background:radial-gradient(circle at center,#fafbfc 0,#e1e6ee 75%);padding:14px}
  .reader-book{height:100%;max-width:1020px;margin:auto;display:flex;align-items:center;justify-content:center;position:relative}
  .reader-sheet{position:absolute;width:min(96%,900px);height:97%;background:#fff;border-radius:5px;box-shadow:0 20px 50px #111b2b33,0 2px 8px #0002;transform-style:preserve-3d;backface-visibility:hidden;transform-origin:left center;overflow:hidden;transition:transform .58s cubic-bezier(.2,.72,.12,1),opacity .3s ease}
  .reader-sheet::after{content:"";position:absolute;inset:0;pointer-events:none;background:linear-gradient(90deg,#00000012,transparent 4%,transparent 95%,#0000000d)}
  .reader-sheet iframe{display:block;width:100%;height:100%;border:0;background:#fff}.reader-sheet.is-hidden{opacity:0;pointer-events:none}.reader-sheet.turn-forward{transform:rotateY(-93deg);opacity:.18}.reader-sheet.turn-back{transform-origin:right center;transform:rotateY(93deg);opacity:.18}
  .reader-shadow{position:absolute;bottom:0;width:min(88%,830px);height:24px;border-radius:50%;background:#1722332b;filter:blur(12px)}.reader-loading{position:absolute;z-index:5;background:#fff;padding:9px 14px;border-radius:999px;box-shadow:0 4px 18px #0002;font-size:.875rem}
  .answer-head{padding:12px 14px;border-bottom:1px solid #e2e6ed}.question-nav{display:flex;gap:6px;flex-wrap:wrap;padding:10px 14px;border-bottom:1px solid #e2e6ed;max-height:116px;overflow:auto}.qnav{width:34px;height:34px;border:1px solid #cfd6e2;background:#fff;border-radius:7px}.qnav.active{background:#1759c7;color:#fff;border-color:#1759c7}.qnav.answered{box-shadow:inset 0 -4px #2cab65}
  .answer-body{flex:1;overflow:auto;padding:16px}.question-card{display:none}.question-card.active{display:block}.option-button{display:flex;gap:10px;align-items:center;padding:12px;border:1px solid #dce2eb;border-radius:10px;margin-bottom:9px;cursor:pointer}.option-button:has(input:checked){border-color:#1759c7;background:#eef4ff}.option-letter{width:32px;height:32px;border-radius:8px;background:#edf1f6;display:grid;place-items:center;font-weight:700}
  .exam-actions{padding:10px 14px;border-top:1px solid #e2e6ed;display:flex;gap:8px}.mobile-tabs{display:none}
  @media(max-width:900px){body{overflow:auto}.pdf-exam-shell{height:calc(100vh - 68px);display:block}.mobile-tabs{display:flex;position:sticky;top:0;z-index:30;background:#fff;border-bottom:1px solid #ddd}.mobile-tabs button{flex:1;padding:11px;border:0;background:#fff;font-weight:700}.mobile-tabs button.active{color:#1759c7;border-bottom:3px solid #1759c7}.exam-paper,.exam-answer{height:calc(100vh - 112px);border:0}.mobile-hidden{display:none!important}.question-nav{max-height:90px}.flip-reader{padding:6px}.reader-sheet{width:99%;height:99%}}
</style>
<div class="mobile-tabs"><button type="button" class="active" data-tab="paper">Đề thi</button><button type="button" data-tab="answer">Bài làm</button></div>
<div class="pdf-exam-shell">
  <section class="exam-paper" id="paperPane">
    <div class="exam-bar">
      <button type="button" class="btn btn-sm btn-outline-secondary" id="pdfPrev">← Trang trước</button>
      <strong>Trang <span id="pdfPageNum">1</span>/<%= quiz.pdf_page_count || 1 %></strong>
      <button type="button" class="btn btn-sm btn-outline-secondary" id="pdfNext">Trang sau →</button>
      <button type="button" class="btn btn-sm btn-outline-secondary" id="openOriginalPdf">Mở PDF gốc</button>
      <% if (quiz.time_limit_minutes && quizStart) { %><span id="timerDisplay" class="ms-auto fw-bold text-danger">--:--</span><% } %>
    </div>
    <div class="flip-reader">
      <div class="reader-book">
        <div class="reader-shadow"></div>
        <div class="reader-loading" id="readerLoading">Đang mở trang đề…</div>
        <div class="reader-sheet" id="readerSheetA"><iframe title="Trang đề thi" loading="eager"></iframe></div>
        <div class="reader-sheet is-hidden" id="readerSheetB"><iframe title="Trang đề thi kế tiếp" loading="eager"></iframe></div>
      </div>
    </div>
  </section>
  <section class="exam-answer mobile-hidden" id="answerPane">
    <div class="answer-head"><div class="fw-bold"><%= quiz.title %></div><small class="text-muted">Chọn câu để làm. Đề tự lật tới trang tương ứng.</small></div>
    <div class="question-nav">
      <% questions.forEach((q,qi)=>{ %><button class="qnav <%= qi===0?'active':'' %>" type="button" data-index="<%= qi %>" data-page="<%= q.source_page || 1 %>"><%= q.display_number || qi+1 %></button><% }) %>
    </div>
    <form method="POST" action="/thi/<%= quiz.id %>/nop-bai" id="quizForm" style="display:flex;flex-direction:column;min-height:0;flex:1">
      <div class="answer-body">
      <% questions.forEach((q,qi)=>{ %>
        <div class="question-card <%= qi===0?'active':'' %>" data-index="<%= qi %>" data-page="<%= q.source_page || 1 %>">
          <div class="d-flex justify-content-between align-items-center mb-3"><h5 class="fw-bold mb-0">Câu <%= q.display_number || qi+1 %></h5><span class="badge text-bg-light"><%= q.points %> điểm</span></div>
          <% if (q.type === 'single_choice') { %>
            <% q.options.forEach((o,oi)=>{ %><label class="option-button"><input class="form-check-input answer-input" type="radio" name="answers[<%= q.id %>]" value="<%= o.id %>"><span class="option-letter"><%= o.option_text || String.fromCharCode(65+oi) %></span><span>Chọn phương án <%= o.option_text || String.fromCharCode(65+oi) %></span></label><% }) %>
          <% } else if (q.type === 'true_false') { %>
            <% q.tfItems.forEach((item,i)=>{ %><div class="border rounded-3 p-3 mb-2"><div class="fw-semibold mb-2"><%= String.fromCharCode(97+i) %>) <%= item.content %></div><label class="me-4"><input class="answer-input" type="radio" name="answers_tf[<%= q.id %>][<%= item.id %>]" value="true"> Đúng</label><label><input class="answer-input" type="radio" name="answers_tf[<%= q.id %>][<%= item.id %>]" value="false"> Sai</label></div><% }) %>
          <% } else if (q.type === 'short_answer') { %><label class="form-label">Nhập đáp án</label><input name="answers[<%= q.id %>]" class="form-control answer-input" placeholder="Đáp án của bạn">
          <% } else { %><label class="form-label">Bài làm</label><textarea name="essay[<%= q.id %>]" class="form-control answer-input" rows="12" placeholder="Viết bài làm tại đây..."></textarea><% } %>
        </div>
      <% }) %>
      </div>
      <div class="exam-actions"><button type="button" class="btn btn-outline-secondary" id="qPrev">Câu trước</button><button type="button" class="btn btn-outline-primary" id="qNext">Câu tiếp</button><button class="btn btn-success ms-auto" onclick="return confirm('Bạn chắc chắn muốn nộp bài?')">Nộp bài</button></div>
    </form>
  </section>
</div>
<script>
(() => {
  const totalPages = <%= quiz.pdf_page_count || 1 %>;
  const pdfUrl = '/thi/<%= quiz.id %>/de.pdf';
  const sheets = [document.getElementById('readerSheetA'), document.getElementById('readerSheetB')];
  const loading = document.getElementById('readerLoading');
  let activeSheet = 0, pageNo = 1, turning = false;
  const pageSrc = page => `${pdfUrl}?flip=1&page=${page}#page=${page}&zoom=page-fit&toolbar=0&navpanes=0&scrollbar=0`;
  function loadSheet(sheet, page, callback) {
    const iframe = sheet.querySelector('iframe'); let completed = false;
    const done = () => { if (completed) return; completed = true; iframe.removeEventListener('load', done); callback(); };
    iframe.addEventListener('load', done, { once:true }); iframe.src = pageSrc(page); setTimeout(done, 1400);
  }
  function renderPage(number, animate = true) {
    const target = Math.max(1, Math.min(totalPages, Number(number) || 1));
    if (turning || (target === pageNo && animate)) return;
    const forward = target >= pageNo, old = sheets[activeSheet], nextIndex = 1-activeSheet, next = sheets[nextIndex];
    turning = true; loading.hidden = false; next.className = 'reader-sheet is-hidden';
    loadSheet(next, target, () => {
      next.className = 'reader-sheet'; old.classList.add(animate ? (forward ? 'turn-forward' : 'turn-back') : 'is-hidden');
      setTimeout(() => { old.className='reader-sheet is-hidden'; activeSheet=nextIndex; pageNo=target; turning=false; loading.hidden=true; document.getElementById('pdfPageNum').textContent=pageNo; }, animate ? 590 : 40);
    });
  }
  document.getElementById('pdfPrev').addEventListener('click',()=>renderPage(pageNo-1));
  document.getElementById('pdfNext').addEventListener('click',()=>renderPage(pageNo+1));
  document.getElementById('openOriginalPdf').addEventListener('click',()=>window.open(`${pdfUrl}#page=${pageNo}`,'_blank','noopener'));
  let currentQ=0; const cards=[...document.querySelectorAll('.question-card')], navs=[...document.querySelectorAll('.qnav')];
  function goQuestion(i){currentQ=Math.max(0,Math.min(cards.length-1,i));cards.forEach((x,j)=>x.classList.toggle('active',j===currentQ));navs.forEach((x,j)=>x.classList.toggle('active',j===currentQ));renderPage(Number(cards[currentQ].dataset.page)||1);if(innerWidth<=900)showTab('answer')}
  navs.forEach((b,i)=>b.addEventListener('click',()=>goQuestion(i)));document.getElementById('qPrev').addEventListener('click',()=>goQuestion(currentQ-1));document.getElementById('qNext').addEventListener('click',()=>goQuestion(currentQ+1));
  document.querySelectorAll('.answer-input').forEach(el=>{const mark=()=>navs[currentQ].classList.add('answered');el.addEventListener('change',mark);el.addEventListener('input',mark)});
  function showTab(tab){document.getElementById('paperPane').classList.toggle('mobile-hidden',tab!=='paper');document.getElementById('answerPane').classList.toggle('mobile-hidden',tab!=='answer');document.querySelectorAll('.mobile-tabs button').forEach(b=>b.classList.toggle('active',b.dataset.tab===tab))}
  document.querySelectorAll('.mobile-tabs button').forEach(b=>b.addEventListener('click',()=>showTab(b.dataset.tab)));
  renderPage(1,false);
  <% if (quiz.time_limit_minutes && quizStart) { %>const startedAt=new Date('<%= quizStart.started_at %>').getTime(),limit=<%= quiz.time_limit_minutes %>*60,display=document.getElementById('timerDisplay'),form=document.getElementById('quizForm');let sent=false;setInterval(()=>{const r=limit-Math.floor((Date.now()-startedAt)/1000);if(r<=0){display.textContent='00:00';if(!sent){sent=true;form.submit()}return}display.textContent=String(Math.floor(r/60)).padStart(2,'0')+':'+String(r%60).padStart(2,'0')},1000);<% } %>
})();
</script>
<% } else { %><label class="form-label">Bài làm</label><textarea name="essay[<%= q.id %>]" class="form-control answer-input" rows="12" placeholder="Viết bài làm tại đây..."></textarea><% } %>
        </div>
      <% }) %>
      </div>
      <div class="exam-actions"><button type="button" class="btn btn-outline-secondary" id="qPrev">Câu trước</button><button type="button" class="btn btn-outline-primary" id="qNext">Câu tiếp</button><button class="btn btn-success ms-auto" onclick="return confirm('Bạn chắc chắn muốn nộp bài?')">Nộp bài</button></div>
    </form>
  </section>
</div>
<script type="module">
import * as pdfjsLib from 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.4.168/pdf.min.mjs';
pdfjsLib.GlobalWorkerOptions.workerSrc='https://cdnjs.cloudflare.com/ajax/libs/pdf.js/4.4.168/pdf.worker.min.mjs';
const pdf=await pdfjsLib.getDocument('/thi/<%= quiz.id %>/de.pdf').promise; let pageNo=1, zoom=1;
const canvas=document.getElementById('pdfCanvas'), body=document.getElementById('paperBody');
async function renderPage(n){pageNo=Math.max(1,Math.min(pdf.numPages,n));document.getElementById('pdfPageNum').textContent=pageNo;const page=await pdf.getPage(pageNo);const base=page.getViewport({scale:1});const fit=Math.max(.55,Math.min(1.7,(body.clientWidth-28)/base.width));const vp=page.getViewport({scale:fit*zoom});canvas.width=vp.width;canvas.height=vp.height;await page.render({canvasContext:canvas.getContext('2d'),viewport:vp}).promise;}
document.getElementById('pdfPrev').onclick=()=>renderPage(pageNo-1);document.getElementById('pdfNext').onclick=()=>renderPage(pageNo+1);document.getElementById('zoomIn').onclick=()=>{zoom=Math.min(2,zoom+.15);document.getElementById('zoomValue').textContent=Math.round(zoom*100)+'%';renderPage(pageNo)};document.getElementById('zoomOut').onclick=()=>{zoom=Math.max(.55,zoom-.15);document.getElementById('zoomValue').textContent=Math.round(zoom*100)+'%';renderPage(pageNo)};renderPage(1);
let currentQ=0;const cards=[...document.querySelectorAll('.question-card')],navs=[...document.querySelectorAll('.qnav')];
function goQuestion(i){currentQ=Math.max(0,Math.min(cards.length-1,i));cards.forEach((x,j)=>x.classList.toggle('active',j===currentQ));navs.forEach((x,j)=>x.classList.toggle('active',j===currentQ));renderPage(Number(cards[currentQ].dataset.page)||1);if(innerWidth<=900){showTab('answer')}}
navs.forEach((b,i)=>b.onclick=()=>goQuestion(i));document.getElementById('qPrev').onclick=()=>goQuestion(currentQ-1);document.getElementById('qNext').onclick=()=>goQuestion(currentQ+1);
document.querySelectorAll('.answer-input').forEach(el=>el.addEventListener('change',()=>navs[currentQ].classList.add('answered')));
function showTab(tab){document.getElementById('paperPane').classList.toggle('mobile-hidden',tab!=='paper');document.getElementById('answerPane').classList.toggle('mobile-hidden',tab!=='answer');document.querySelectorAll('.mobile-tabs button').forEach(b=>b.classList.toggle('active',b.dataset.tab===tab));if(tab==='paper')setTimeout(()=>renderPage(pageNo),30)}
document.querySelectorAll('.mobile-tabs button').forEach(b=>b.onclick=()=>showTab(b.dataset.tab));
<% if (quiz.time_limit_minutes && quizStart) { %>const startedAt=new Date('<%= quizStart.started_at %>').getTime(),limit=<%= quiz.time_limit_minutes %>*60,display=document.getElementById('timerDisplay'),form=document.getElementById('quizForm');let sent=false;setInterval(()=>{const r=limit-Math.floor((Date.now()-startedAt)/1000);if(r<=0){display.textContent='00:00';if(!sent){sent=true;form.submit()}return}display.textContent=String(Math.floor(r/60)).padStart(2,'0')+':'+String(r%60).padStart(2,'0')},1000);<% } %>
</script>
<% } else { %>
<%- include('quiz-take-legacy') %>
<% } %>
<%- include('partials/footer') %>
