<% var pageTitle = 'Sách' %>
<%- include('partials/header') %>
<h3 class="fw-bold mb-3">Sách</h3>
<div class="row">
  <div class="col-lg-3 mb-4">
    <div class="card p-3 mb-3">
      <h6 class="fw-bold mb-2"><i class="fa-solid fa-graduation-cap"></i> Theo lớp / môn</h6>
      <div class="sidebar-cat small">
        <div class="mb-1"><a href="/sach" class="<%= !activeCategory ? 'fw-bold text-primary' : '' %>">Tất cả</a></div>
        <% categories.forEach(cat => { %>
          <div class="mb-1">
            <a href="/sach?danh_muc=<%= cat.slug %><%= activeType ? '&the_loai='+activeType : '' %>" class="<%= activeCategory===cat.slug ? 'fw-bold text-primary' : '' %>"><%= cat.name %></a>
            <% if (cat.children && cat.children.length) { %>
              <ul class="list-unstyled ms-3">
                <% cat.children.forEach(child => { %>
                  <li><a href="/sach?danh_muc=<%= child.slug %><%= activeType ? '&the_loai='+activeType : '' %>" class="<%= activeCategory===child.slug ? 'fw-bold text-primary' : '' %>"><i class="fa-solid fa-angle-right small"></i> <%= child.name %></a></li>
                <% }) %>
              </ul>
            <% } %>
          </div>
        <% }) %>
      </div>
    </div>
    <div class="card p-3">
      <h6 class="fw-bold mb-2"><i class="fa-solid fa-tags"></i> Theo thể loại</h6>
      <div class="small">
        <div class="mb-1"><a href="/sach<%= activeCategory ? '?danh_muc='+activeCategory : '' %>" class="<%= !activeType ? 'fw-bold text-primary' : '' %>">Tất cả</a></div>
        <% bookTypes.forEach(t => { %>
          <div class="mb-1">
            <a href="/sach?the_loai=<%= t.slug %><%= activeCategory ? '&danh_muc='+activeCategory : '' %>" class="<%= activeType===t.slug ? 'fw-bold text-primary' : '' %>"><%= t.name %></a>
          </div>
        <% }) %>
      </div>
    </div>
  </div>
  <div class="col-lg-9">
    <div class="row g-3">
      <% books.forEach(b => { %>
        <div class="col-md-4">
          <a href="/sach/<%= b.slug %>" class="text-decoration-none text-dark">
            <div class="card course-card">
              <img src="<%= b.cover_url || '/img/placeholder.svg' %>" class="w-100" style="height:200px;object-fit:cover">
              <div class="p-3">
                <% if (b.category_name || b.book_type_name) { %>
                  <span class="badge badge-cat mb-2"><%= b.book_type_name || b.category_name %></span>
                <% } %>
                <div class="fw-semibold mb-1"><%= b.title %></div>
                <div class="small text-muted mb-2"><%= b.author %></div>
                <div class="price-tag"><%= b.price > 0 ? formatVND(b.price) : 'Miễn phí' %></div>
              </div>
            </div>
          </a>
        </div>
      <% }) %>
      <% if (books.length === 0) { %><p class="text-muted">Chưa có sách nào phù hợp.</p><% } %>
    </div>
  </div>
</div>
<%- include('partials/footer') %>
