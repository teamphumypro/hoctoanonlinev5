<% var pageTitle = 'Bài được giao' %>
<%- include('../partials/header') %>
<h4 class="fw-bold mb-3">Bài được giao</h4>
<div class="card p-3">
  <table class="table">
    <thead><tr><th>Đề thi</th><th>Hạn nộp</th><th>Trạng thái</th><th></th></tr></thead>
    <tbody>
      <% var now = new Date(); %>
      <% assignments.forEach(a => { %>
        <% var overdue = a.due_at && new Date(a.due_at) < now && a.attempt_count == 0; %>
        <tr>
          <td><%= a.title %></td>
          <td><%= a.due_at ? formatDate(a.due_at) : 'Không giới hạn' %></td>
          <td>
            <% if (a.attempt_count > 0) { %><span class="badge bg-success">Đã làm</span>
            <% } else if (overdue) { %><span class="badge bg-danger">Quá hạn</span>
            <% } else { %><span class="badge bg-warning text-dark">Chưa làm</span><% } %>
          </td>
          <td><a href="/thi/<%= a.quiz_id %>" class="btn btn-sm btn-primary"><%= a.attempt_count > 0 ? 'Làm lại' : 'Làm bài' %></a></td>
        </tr>
      <% }) %>
      <% if (assignments.length === 0) { %><tr><td colspan="4" class="text-center text-muted">Chưa có bài nào được giao cho bạn.</td></tr><% } %>
    </tbody>
  </table>
</div>
<%- include('../partials/footer') %>
