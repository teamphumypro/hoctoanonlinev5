<% var pageTitle = 'Sách đọc online đã mua' %>
<%- include('../partials/header') %>
<h4 class="fw-bold mb-3">Sách đọc online đã mua</h4>
<div class="row g-3">
  <% books.forEach(b => { %>
    <div class="col-md-3">
      <div class="card p-2">
        <img src="<%= b.cover_url || '/img/placeholder.svg' %>" class="w-100 mb-2" style="height:180px;object-fit:cover;border-radius:6px">
        <div class="fw-semibold small mb-2"><%= b.title %></div>
        <a href="/doc-sach-online/<%= b.slug %>/doc" class="btn btn-sm btn-primary w-100">Đọc ngay</a>
      </div>
    </div>
  <% }) %>
  <% if (books.length === 0) { %><p class="text-muted">Bạn chưa mua sách đọc online nào. <a href="/doc-sach-online">Khám phá</a></p><% } %>
</div>
<%- include('../partials/footer') %>
