<% var pageTitle = 'Nhập mã kích hoạt' %>
<%- include('../partials/header') %>
<div class="row justify-content-center">
  <div class="col-md-5">
    <div class="card p-4">
      <h5 class="fw-bold mb-3">Nhập mã kích hoạt khóa học</h5>
      <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
      <% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>
      <form method="POST" action="/kich-hoat">
        <div class="mb-3">
          <input name="code" class="form-control text-uppercase" placeholder="AB12-CD34-EF56" required>
        </div>
        <button class="btn btn-primary w-100">Kích hoạt</button>
      </form>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
