<% var pageTitle = 'Chứng chỉ của tôi' %>
<%- include('../partials/header') %>
<h4 class="fw-bold mb-3">Chứng chỉ của tôi</h4>
<div class="row g-3">
  <% certs.forEach(c => { %>
    <div class="col-md-4">
      <div class="card p-3 text-center">
        <i class="fa-solid fa-award fa-2x text-warning mb-2"></i>
        <div class="fw-semibold"><%= c.course_title %></div>
        <div class="small text-muted mb-2"><%= c.certificate_code %></div>
        <a href="/chung-chi/tai-xuong/<%= c.course_id %>" class="btn btn-sm btn-primary" target="_blank">Tải PDF</a>
      </div>
    </div>
  <% }) %>
  <% if (certs.length === 0) { %><p class="text-muted">Bạn chưa có chứng chỉ nào. Hoàn thành 100% khóa học để nhận chứng chỉ.</p><% } %>
</div>
<%- include('../partials/footer') %>
