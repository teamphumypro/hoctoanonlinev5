<% var pageTitle = 'Khóa học của tôi' %>
<%- include('../partials/header') %>
<h4 class="fw-bold mb-3">Khóa học của tôi</h4>
<div class="row g-3 mb-4">
  <% enrollments.forEach(e => { %>
    <div class="col-md-4">
      <div class="card p-3">
        <img src="<%= e.thumbnail_url || '/img/placeholder.svg' %>" class="w-100 rounded mb-2" style="height:120px;object-fit:cover">
        <div class="fw-semibold mb-2"><%= e.title %></div>
        <div class="progress mb-2" style="height:8px"><div class="progress-bar" style="width:<%= e.progress_percent %>%"></div></div>
        <div class="d-flex justify-content-between align-items-center">
          <small class="text-muted"><%= e.progress_percent %>% hoàn thành</small>
          <a href="/khoa-hoc/<%= e.slug %>" class="btn btn-sm btn-primary">Vào học</a>
        </div>
        <% if (e.progress_percent === 100) { %>
          <a href="/chung-chi/tai-xuong/<%= e.course_id %>" class="btn btn-sm btn-outline-success mt-2" target="_blank"><i class="fa-solid fa-award"></i> Tải chứng chỉ</a>
        <% } %>
      </div>
    </div>
  <% }) %>
  <% if (enrollments.length === 0) { %><p class="text-muted">Bạn chưa đăng ký khóa học nào. <a href="/">Khám phá khóa học</a></p><% } %>
</div>

<div class="row g-4">
  <div class="col-md-6">
    <div class="card p-3">
      <h6 class="fw-bold">Nhật ký học tập gần đây</h6>
      <ul class="list-group list-group-flush">
        <% logs.forEach(l => { %>
          <li class="list-group-item small">
            Đã học <strong><%= l.lesson_title %></strong> — <%= l.course_title %>
            <div class="text-muted"><%= formatDate(l.last_watched_at) %></div>
          </li>
        <% }) %>
        <% if (logs.length === 0) { %><li class="list-group-item small text-muted">Chưa có hoạt động.</li><% } %>
      </ul>
    </div>
  </div>
  <div class="col-md-6">
    <div class="card p-3">
      <h6 class="fw-bold">Lịch sử đăng nhập</h6>
      <ul class="list-group list-group-flush">
        <% loginHistory.forEach(h => { %>
          <li class="list-group-item small">IP: <%= h.ip_address %> — <%= formatDate(h.logged_in_at) %></li>
        <% }) %>
        <% if (loginHistory.length === 0) { %><li class="list-group-item small text-muted">Chưa có dữ liệu.</li><% } %>
      </ul>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
