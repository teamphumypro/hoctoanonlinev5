<% var pageTitle = 'Tủ sách của tôi' %>
<%- include('../partials/header') %>
<h4 class="fw-bold mb-3">Tủ sách của tôi</h4>
<div class="row g-3">
  <% books.forEach(b => { %>
    <div class="col-md-3">
      <div class="card p-2">
        <img src="<%= b.cover_url || '/img/placeholder.svg' %>" class="w-100 mb-2" style="height:180px;object-fit:cover;border-radius:6px">
        <div class="fw-semibold small"><%= b.title %></div>
        <div class="text-muted small mb-2"><%= b.author %></div>
        <% if (b.file_url) { %>
          <a href="<%= b.file_url %>" target="_blank" class="btn btn-sm btn-primary w-100">Tải sách</a>
        <% } else { %>
          <span class="badge bg-secondary">Chưa có file tải</span>
        <% } %>
      </div>
    </div>
  <% }) %>
  <% if (books.length === 0) { %><p class="text-muted">Bạn chưa mua cuốn sách nào. <a href="/sach">Khám phá sách</a></p><% } %>
</div>
<%- include('../partials/footer') %>
