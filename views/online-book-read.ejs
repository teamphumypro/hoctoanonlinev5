<% var pageTitle = 'Đọc: ' + book.title %>
<%- include('partials/header') %>

<div class="text-center mb-3">
  <h5 class="fw-bold mb-0"><%= book.title %></h5>
  <div class="small text-muted">Bấm vào mép trang hoặc dùng nút để lật trang</div>
</div>

<div class="d-flex justify-content-center mb-3">
  <div id="flipbook"></div>
</div>

<div class="d-flex justify-content-center gap-2 mb-4">
  <button id="prevBtn" class="btn btn-outline-secondary btn-sm"><i class="fa-solid fa-arrow-left"></i> Trang trước</button>
  <button id="nextBtn" class="btn btn-outline-secondary btn-sm">Trang sau <i class="fa-solid fa-arrow-right"></i></button>
</div>

<% if (mode === 'chapters') { %>
<div id="pageSource" class="d-none">
  <% chapters.forEach((c, i) => { %>
    <div class="storypage" data-density="hard">
      <div class="storypage-inner">
        <h6 class="fw-bold mb-2">Chương <%= i+1 %>: <%= c.title %></h6>
        <% if (c.unlocked) { %>
          <div class="storypage-content"><%- c.content %></div>
        <% } else { %>
          <div class="text-center py-5">
            <i class="fa-solid fa-lock fa-2x text-muted mb-3"></i>
            <p class="text-muted">Chương này cần mua sách mới đọc được.</p>
            <a href="/doc-sach-online/<%= book.slug %>" class="btn btn-primary btn-sm">Xem thông tin mua sách</a>
          </div>
        <% } %>
      </div>
    </div>
  <% }) %>
</div>
<% } else { %>
<div id="pdfLoading" class="text-center text-muted py-5">
  <div class="spinner-border spinner-border-sm mb-2"></div>
  <div>Đang tải sách...</div>
</div>
<% } %>

<style>
  #flipbook{ box-shadow:0 10px 30px rgba(0,0,0,.2); }
  .storypage{ background:#fdfaf3; width:100%; height:100%; overflow:hidden; }
  .storypage-inner{ padding:24px; height:100%; overflow-y:auto; font-size:.95rem; line-height:1.7; }
  .storypage.pdfpage{ display:flex; align-items:center; justify-content:center; background:#fff; }
  .storypage.pdfpage canvas{ max-width:100%; max-height:100%; }
</style>

<script src="https://cdn.jsdelivr.net/npm/page-flip@2.0.7/dist/js/page-flip.browser.js"></script>

<% if (mode === 'chapters') { %>
<script>
  const pageEls = document.querySelectorAll('#pageSource .storypage');
  const flipbookEl = document.getElementById('flipbook');
  const isMobile = window.innerWidth < 700;
  const pageFlip = new St.PageFlip(flipbookEl, {
    width: isMobile ? 320 : 420,
    height: isMobile ? 460 : 600,
    size: 'stretch',
    minWidth: 280, maxWidth: 600, minHeight: 400, maxHeight: 820,
    showCover: true,
    maxShadowOpacity: 0.5
  });
  pageFlip.loadFromHTML(pageEls);

  document.getElementById('prevBtn').addEventListener('click', () => pageFlip.flipPrev());
  document.getElementById('nextBtn').addEventListener('click', () => pageFlip.flipNext());
</script>
<% } else { %>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
<script>
(async function () {
  const flipbookEl = document.getElementById('flipbook');
  const loadingEl = document.getElementById('pdfLoading');
  const isMobile = window.innerWidth < 700;
  const unlocked = <%- unlocked ? 'true' : 'false' %>;
  const bookSlug = <%- JSON.stringify(book.slug) %>;
  const buySlug = '/doc-sach-online/' + bookSlug;

  pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

  try {
    const loadingTask = pdfjsLib.getDocument('/doc-sach-online/' + bookSlug + '/file');
    const pdf = await loadingTask.promise;
    const totalPages = pdf.numPages;
    const previewLimit = 3; // so trang xem thu neu sach chua duoc mua
    const pagesToRender = unlocked ? totalPages : Math.min(previewLimit, totalPages);

    const container = document.createElement('div');
    container.style.display = 'none';

    const targetWidth = isMobile ? 320 : 420;
    for (let i = 1; i <= pagesToRender; i++) {
      const page = await pdf.getPage(i);
      const baseViewport = page.getViewport({ scale: 1 });
      const scale = (targetWidth * 2) / baseViewport.width; // *2 cho net tren man hinh Retina
      const viewport = page.getViewport({ scale });
      const canvas = document.createElement('canvas');
      canvas.width = viewport.width;
      canvas.height = viewport.height;
      await page.render({ canvasContext: canvas.getContext('2d'), viewport }).promise;

      const pageDiv = document.createElement('div');
      pageDiv.className = 'storypage pdfpage';
      pageDiv.setAttribute('data-density', (i === 1 || i === pagesToRender) ? 'hard' : 'soft');
      pageDiv.appendChild(canvas);
      container.appendChild(pageDiv);
    }

    if (!unlocked && totalPages > previewLimit) {
      const lockDiv = document.createElement('div');
      lockDiv.className = 'storypage';
      lockDiv.setAttribute('data-density', 'hard');
      lockDiv.innerHTML = '<div class="storypage-inner text-center py-5">' +
        '<i class="fa-solid fa-lock fa-2x text-muted mb-3"></i>' +
        '<p class="text-muted">Bạn đã xem hết ' + previewLimit + ' trang xem thử. Mua sách để đọc toàn bộ ' + totalPages + ' trang.</p>' +
        '<a href="' + buySlug + '" class="btn btn-primary btn-sm">Xem thông tin mua sách</a></div>';
      container.appendChild(lockDiv);
    }

    document.body.appendChild(container);
    loadingEl.remove();

    const pageFlip = new St.PageFlip(flipbookEl, {
      width: targetWidth,
      height: isMobile ? 460 : 600,
      size: 'stretch',
      minWidth: 280, maxWidth: 600, minHeight: 400, maxHeight: 820,
      showCover: true,
      maxShadowOpacity: 0.5
    });
    pageFlip.loadFromHTML(container.querySelectorAll('.storypage'));

    document.getElementById('prevBtn').addEventListener('click', () => pageFlip.flipPrev());
    document.getElementById('nextBtn').addEventListener('click', () => pageFlip.flipNext());
  } catch (err) {
    console.error('Loi tai sach PDF:', err);
    loadingEl.innerHTML = '<div class="text-danger">Không tải được sách. Vui lòng thử lại sau hoặc liên hệ hỗ trợ.</div>';
  }
})();
</script>
<% } %>

<%- include('partials/footer') %>
