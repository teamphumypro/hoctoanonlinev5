<% var pageTitle = 'Đọc: ' + book.title %>
<%- include('partials/header') %>

<div class="text-center mb-3">
  <h5 class="fw-bold mb-0"><%= book.title %></h5>
  <div class="small text-muted">Bấm vào mép trang hoặc dùng nút để lật trang</div>
</div>

<div class="d-flex justify-content-center mb-3">
  <div style="position:relative; display:inline-block">
    <div id="flipbook"></div>
    <div id="tocPanel" class="d-none" style="position:absolute; top:0; left:0; bottom:0; width:280px; max-width:80vw; background:#fff; border-radius:8px; box-shadow:0 10px 30px rgba(0,0,0,.25); z-index:20; overflow-y:auto; padding:14px;">
      <div class="d-flex justify-content-between align-items-center mb-2">
        <b class="small text-uppercase text-muted">Mục lục</b>
        <button type="button" id="tocCloseBtn" class="btn-close btn-sm" aria-label="Đóng"></button>
      </div>
      <div id="tocList" class="small text-muted">Đang nhận diện mục lục...</div>
    </div>
  </div>
</div>

<div class="d-flex justify-content-center gap-2 mb-4">
  <button id="tocToggleBtn" class="btn btn-outline-primary btn-sm"><i class="fa-solid fa-list"></i> Mục lục</button>
  <button id="prevBtn" class="btn btn-outline-secondary btn-sm"><i class="fa-solid fa-arrow-left"></i> Trang trước</button>
  <button id="nextBtn" class="btn btn-outline-secondary btn-sm">Trang sau <i class="fa-solid fa-arrow-right"></i></button>
</div>

<% if (mode === 'chapters') { %>
<div id="pageSource" class="d-none">
  <% chapters.forEach((c, i) => { %>
    <div class="storypage" data-density="hard">
      <div class="storypage-inner">
        <h6 class="fw-bold mb-2">Chương <%= i+1 %>: <%= c.title %></h6>
        <% if (c.unlocked) { %>
          <div class="storypage-content"><%- c.content %></div>
        <% } else { %>
          <div class="text-center py-5">
            <i class="fa-solid fa-lock fa-2x text-muted mb-3"></i>
            <p class="text-muted">Chương này cần mua sách mới đọc được.</p>
            <a href="/doc-sach-online/<%= book.slug %>" class="btn btn-primary btn-sm">Xem thông tin mua sách</a>
          </div>
        <% } %>
      </div>
    </div>
  <% }) %>
</div>
<% } else { %>
<div id="pdfLoading" class="text-center text-muted py-5">
  <div class="spinner-border spinner-border-sm mb-2"></div>
  <div>Đang tải sách...</div>
</div>
<% } %>

<style>
  #flipbook{ box-shadow:0 10px 30px rgba(0,0,0,.2); }
  .storypage{ background:#fdfaf3; width:100%; height:100%; overflow:hidden; }
  .storypage-inner{ padding:24px; height:100%; overflow-y:auto; font-size:.95rem; line-height:1.7; }
  .storypage.pdfpage{ display:flex; align-items:center; justify-content:center; background:#fff; }
  .storypage.pdfpage canvas{ max-width:100%; max-height:100%; }
  .toc-item{ display:block; width:100%; text-align:left; background:none; border:0; padding:6px 8px; border-radius:6px; color:#333; font-size:.85rem; }
  .toc-item:hover{ background:#f1f1f1; }
  .toc-item.locked{ color:#aaa; }
  .toc-item .fa-lock{ font-size:.7rem; margin-left:4px; }
</style>

<script src="https://cdn.jsdelivr.net/npm/page-flip@2.0.7/dist/js/page-flip.browser.js"></script>

<script>
  // Dung chung cho ca 2 che do doc (pdf / chapters): dieu khien mo/dong bang muc luc
  const tocPanel = document.getElementById('tocPanel');
  document.getElementById('tocToggleBtn').addEventListener('click', () => tocPanel.classList.toggle('d-none'));
  document.getElementById('tocCloseBtn').addEventListener('click', () => tocPanel.classList.add('d-none'));

  // entries: [{ title, pageIndex, locked, level }]
  function renderTocList(entries, onJump, buySlug) {
    const listEl = document.getElementById('tocList');
    if (!entries.length) {
      listEl.innerHTML = '<div class="text-muted">Không nhận diện được mục lục cho sách này.</div>';
      return;
    }
    listEl.innerHTML = '';
    entries.forEach(entry => {
      const btn = document.createElement('button');
      btn.type = 'button';
      btn.className = 'toc-item' + (entry.locked ? ' locked' : '');
      btn.style.paddingLeft = (8 + (entry.level || 0) * 14) + 'px';
      btn.innerHTML = entry.title + (entry.locked ? ' <i class="fa-solid fa-lock"></i>' : '');
      btn.addEventListener('click', () => {
        tocPanel.classList.add('d-none');
        if (entry.locked) { window.location.href = buySlug; return; }
        onJump(entry.pageIndex);
      });
      listEl.appendChild(btn);
    });
  }
</script>

<% if (mode === 'chapters') { %>
<script>
  const pageEls = document.querySelectorAll('#pageSource .storypage');
  const flipbookEl = document.getElementById('flipbook');
  const isMobile = window.innerWidth < 700;
  const pageFlip = new St.PageFlip(flipbookEl, {
    width: isMobile ? 320 : 420,
    height: isMobile ? 460 : 600,
    size: 'stretch',
    minWidth: 280, maxWidth: 600, minHeight: 400, maxHeight: 820,
    showCover: true,
    maxShadowOpacity: 0.5
  });
  pageFlip.loadFromHTML(pageEls);

  document.getElementById('prevBtn').addEventListener('click', () => pageFlip.flipPrev());
  document.getElementById('nextBtn').addEventListener('click', () => pageFlip.flipNext());

  // Muc luc lay thang tu danh sach chuong da co san (khong can tu nhan dien)
  const chapterEntries = <%- JSON.stringify(chapters.map((c, i) => ({ title: 'Chương ' + (i + 1) + ': ' + c.title, pageIndex: i, locked: !c.unlocked }))) %>;
  renderTocList(chapterEntries, (i) => pageFlip.flip(i), '/doc-sach-online/<%= book.slug %>');
</script>
<% } else { %>
<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
<script>
(async function () {
  const flipbookEl = document.getElementById('flipbook');
  const loadingEl = document.getElementById('pdfLoading');
  const isMobile = window.innerWidth < 700;
  const unlocked = <%- unlocked ? 'true' : 'false' %>;
  const bookSlug = <%- JSON.stringify(book.slug) %>;
  const buySlug = '/doc-sach-online/' + bookSlug;

  pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';

  // Nhan dien tieu de chuong trong van ban 1 trang (dung chung dau hieu voi bo tach chuong tu file Word/PDF)
  const chapterHeadingRegex = /^(Chương|CHƯƠNG|Phần|PHẦN|Hồi|HỒI)\s+[\dIVXLCM]+[\.\:\-\s]?.{0,80}$/;
  function findHeadingOnPage(textItems) {
    // Chi xet vai dong dau trang (tieu de chuong thuong nam tren cung)
    const lines = [];
    let current = '';
    for (const it of textItems) {
      current += it.str;
      if (it.hasEOL) { lines.push(current.trim()); current = ''; if (lines.length >= 6) break; }
    }
    if (current.trim()) lines.push(current.trim());
    for (const line of lines.slice(0, 6)) {
      if (line.length > 2 && line.length < 90 && chapterHeadingRegex.test(line)) return line;
    }
    return null;
  }

  try {
    const loadingTask = pdfjsLib.getDocument('/doc-sach-online/' + bookSlug + '/file');
    const pdf = await loadingTask.promise;
    const totalPages = pdf.numPages;
    const previewLimit = 3; // so trang xem thu neu sach chua duoc mua
    const pagesToRender = unlocked ? totalPages : Math.min(previewLimit, totalPages);

    const container = document.createElement('div');
    container.style.display = 'none';

    const targetWidth = isMobile ? 320 : 420;
    const tocEntries = [];
    for (let i = 1; i <= pagesToRender; i++) {
      const page = await pdf.getPage(i);
      const baseViewport = page.getViewport({ scale: 1 });
      const scale = (targetWidth * 2) / baseViewport.width; // *2 cho net tren man hinh Retina
      const viewport = page.getViewport({ scale });
      const canvas = document.createElement('canvas');
      canvas.width = viewport.width;
      canvas.height = viewport.height;
      await page.render({ canvasContext: canvas.getContext('2d'), viewport }).promise;

      const pageDiv = document.createElement('div');
      pageDiv.className = 'storypage pdfpage';
      pageDiv.setAttribute('data-density', (i === 1 || i === pagesToRender) ? 'hard' : 'soft');
      pageDiv.appendChild(canvas);
      container.appendChild(pageDiv);

      try {
        const textContent = await page.getTextContent();
        const heading = findHeadingOnPage(textContent.items);
        if (heading) tocEntries.push({ title: heading, pageIndex: i - 1, locked: false, level: 0 });
      } catch (e) { /* khong sao neu trang khong doc duoc text (anh scan...) */ }
    }

    // Neu con trang bi khoa (chua mua), quet tiep phan text (khong render anh) de muc luc van day du,
    // cac chuong sau diem khoa se hien kem bieu tuong khoa, bam vao se dan toi trang mua sach
    if (!unlocked && totalPages > pagesToRender) {
      for (let i = pagesToRender + 1; i <= totalPages; i++) {
        try {
          const page = await pdf.getPage(i);
          const textContent = await page.getTextContent();
          const heading = findHeadingOnPage(textContent.items);
          if (heading) tocEntries.push({ title: heading, pageIndex: i - 1, locked: true, level: 0 });
        } catch (e) { /* bo qua */ }
      }
    }

    // Neu file PDF co san muc luc/bookmark (outline) thi uu tien dung, chuan xac hon viec do chu
    try {
      const outline = await pdf.getOutline();
      if (outline && outline.length) {
        tocEntries.length = 0;
        async function flattenOutline(items, level) {
          for (const item of items) {
            let dest = item.dest;
            if (typeof dest === 'string') dest = await pdf.getDestination(dest);
            if (dest && dest[0] != null) {
              const pageIndex = await pdf.getPageIndex(dest[0]);
              tocEntries.push({ title: item.title, pageIndex, locked: !unlocked && pageIndex >= pagesToRender, level });
            }
            if (item.items && item.items.length) await flattenOutline(item.items, level + 1);
          }
        }
        await flattenOutline(outline, 0);
      }
    } catch (e) { /* khong co outline thi thoi, dung ket qua tu nhan dien van ban o tren */ }

    if (!unlocked && totalPages > previewLimit) {
      const lockDiv = document.createElement('div');
      lockDiv.className = 'storypage';
      lockDiv.setAttribute('data-density', 'hard');
      lockDiv.innerHTML = '<div class="storypage-inner text-center py-5">' +
        '<i class="fa-solid fa-lock fa-2x text-muted mb-3"></i>' +
        '<p class="text-muted">Bạn đã xem hết ' + previewLimit + ' trang xem thử. Mua sách để đọc toàn bộ ' + totalPages + ' trang.</p>' +
        '<a href="' + buySlug + '" class="btn btn-primary btn-sm">Xem thông tin mua sách</a></div>';
      container.appendChild(lockDiv);
    }

    document.body.appendChild(container);
    loadingEl.remove();

    const pageFlip = new St.PageFlip(flipbookEl, {
      width: targetWidth,
      height: isMobile ? 460 : 600,
      size: 'stretch',
      minWidth: 280, maxWidth: 600, minHeight: 400, maxHeight: 820,
      showCover: true,
      maxShadowOpacity: 0.5
    });
    pageFlip.loadFromHTML(container.querySelectorAll('.storypage'));

    document.getElementById('prevBtn').addEventListener('click', () => pageFlip.flipPrev());
    document.getElementById('nextBtn').addEventListener('click', () => pageFlip.flipNext());

    renderTocList(tocEntries, (i) => pageFlip.flip(i), buySlug);
  } catch (err) {
    console.error('Loi tai sach PDF:', err);
    loadingEl.innerHTML = '<div class="text-danger">Không tải được sách. Vui lòng thử lại sau hoặc liên hệ hỗ trợ.</div>';
  }
})();
</script>
<% } %>

<%- include('partials/footer') %>
