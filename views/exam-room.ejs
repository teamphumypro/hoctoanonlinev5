<% var pageTitle = 'Thực chiến phòng thi' %>
<%- include('partials/header') %>

<div class="hero p-5 mb-4 text-center">
  <h1 class="fw-bold">Thực chiến phòng thi</h1>
  <p class="mb-0">Thi thử online với thư viện đề thi từ giáo viên — chấm điểm tự động ngay sau khi nộp bài.</p>
</div>

<div class="row">
  <div class="col-lg-3 mb-4">
    <div class="card p-3">
      <h6 class="fw-bold mb-2"><i class="fa-solid fa-layer-group"></i> Theo danh mục</h6>
      <div class="sidebar-cat small">
        <div class="mb-1"><a href="/phong-thi" class="<%= !activeCategory ? 'fw-bold text-primary' : '' %>">Tất cả</a></div>
        <% categories.forEach(cat => { %>
          <div class="mb-1">
            <a href="/phong-thi?danh_muc=<%= cat.slug %>" class="<%= activeCategory===cat.slug ? 'fw-bold text-primary' : '' %>"><%= cat.name %></a>
            <% if (cat.children && cat.children.length) { %>
              <ul class="list-unstyled ms-3">
                <% cat.children.forEach(child => { %>
                  <li><a href="/phong-thi?danh_muc=<%= child.slug %>" class="<%= activeCategory===child.slug ? 'fw-bold text-primary' : '' %>"><i class="fa-solid fa-angle-right small"></i> <%= child.name %></a></li>
                <% }) %>
              </ul>
            <% } %>
          </div>
        <% }) %>
      </div>
    </div>
  </div>
  <div class="col-lg-9">
    <div class="row g-3">
      <% exams.forEach(e => { %>
        <div class="col-md-4">
          <div class="card p-3 h-100 d-flex flex-column">
            <% if (e.category_name) { %><span class="badge badge-cat mb-2 align-self-start"><%= e.category_name %></span><% } %>
            <div class="fw-semibold mb-1"><%= e.title %></div>
            <div class="small text-muted mb-3"><%= e.question_count %> câu hỏi — đạt tối thiểu <%= e.pass_score %> điểm</div>
            <% if (typeof currentUser !== 'undefined' && currentUser) { %>
              <a href="/thi/<%= e.id %>" class="btn btn-primary btn-sm mt-auto">Bắt đầu làm bài</a>
            <% } else { %>
              <a href="/dang-nhap" class="btn btn-outline-primary btn-sm mt-auto">Đăng nhập để làm bài</a>
            <% } %>
          </div>
        </div>
      <% }) %>
      <% if (exams.length === 0) { %><p class="text-muted">Chưa có đề thi nào.</p><% } %>
    </div>
  </div>
</div>

<%- include('partials/footer') %>
