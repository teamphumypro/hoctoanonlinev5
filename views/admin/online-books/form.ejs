<% var pageTitle = book ? 'Sửa sách đọc online' : 'Thêm sách đọc online' %>
<%- include('../../partials/admin-header') %>
<div style="max-width:700px">
  <form method="POST" action="<%= book ? '/admin/doc-sach-online/' + book.id : '/admin/doc-sach-online' %>" enctype="multipart/form-data">
    <div class="card p-4 mb-3">
      <h6 class="fw-bold mb-3">Thông tin sách</h6>
      <div class="mb-3"><label class="form-label">Tên sách</label>
        <input name="title" class="form-control" value="<%= book ? book.title : '' %>" required></div>
      <div class="mb-3"><label class="form-label">Tác giả</label>
        <input name="author" class="form-control" value="<%= book ? book.author : '' %>"></div>
      <div class="mb-3"><label class="form-label">Mô tả ngắn</label>
        <input name="short_desc" class="form-control" value="<%= book ? book.short_desc : '' %>"></div>
      <div class="mb-3"><label class="form-label">Danh mục <span class="text-muted fw-normal">(tùy chọn)</span></label>
        <select name="category_id" class="form-select">
          <option value="">-- Không thuộc danh mục cụ thể --</option>
          <% function renderOnlineCatOptions(cats, depth) { %>
            <% cats.forEach(c => { %>
              <option value="<%= c.id %>" <%= book && book.category_id === c.id ? 'selected' : '' %>>
                <%= '\u00A0\u00A0\u00A0\u00A0'.repeat(depth) %><%= depth > 0 ? '↳ ' : '' %><%= c.name %>
              </option>
              <% if (c.children && c.children.length) renderOnlineCatOptions(c.children, depth + 1) %>
            <% }) %>
          <% } %>
          <% renderOnlineCatOptions(categories, 0) %>
        </select>
        <div class="form-text">Chưa có danh mục phù hợp? Vào menu <strong>"Danh mục đọc sách online"</strong> bên trái để thêm trước.</div>
      </div>
      <div class="mb-0"><label class="form-label">Mô tả chi tiết</label>
        <div id="descEditor" style="height:180px; background:#fff"></div>
        <input type="hidden" name="description" id="descHidden" value="<%= book ? book.description : '' %>">
      </div>
    </div>

    <div class="card p-4 mb-3">
      <h6 class="fw-bold mb-3">Giá đọc</h6>
      <div class="row">
        <div class="col-md-6 mb-0"><label class="form-label">Giá bán (VNĐ, 0 = miễn phí)</label>
          <input type="number" name="price" class="form-control" value="<%= book ? book.price : 0 %>"></div>
        <div class="col-md-6 mb-0"><label class="form-label">Giá gốc (tùy chọn, hiện gạch ngang)</label>
          <input type="number" name="compare_at_price" class="form-control" value="<%= book && book.compare_at_price ? book.compare_at_price : '' %>"></div>
      </div>
    </div>

    <div class="card p-4 mb-3">
      <h6 class="fw-bold mb-3">File sách (đọc kiểu lật trang)</h6>
      <div class="alert alert-info small mb-3">
        Chỉ cần <b>1 file PDF duy nhất</b> — không cần tách chương. Bạn có thể tải file lên trực tiếp,
        hoặc dán link file PDF đang lưu ở bất kỳ nơi nào (Google Drive, Dropbox, CDN riêng...).
        Nếu dùng link Google Drive, nhớ bật chia sẻ "Bất kỳ ai có đường liên kết".
      </div>
      <% if (book && book.file_url) { %>
        <div class="mb-2 small">Đang dùng: <span class="badge bg-<%= book.file_source === 'upload' ? 'secondary' : 'info' %>"><%= book.file_source === 'upload' ? 'File đã tải lên' : 'Link dán tay' %></span>
          <% if (book.file_source !== 'upload') { %> — <a href="<%= book.file_url %>" target="_blank" rel="noopener"><%= book.file_url %></a><% } %>
        </div>
      <% } %>
      <div class="btn-group btn-group-sm mb-2" role="group">
        <input type="radio" class="btn-check" name="file_mode" id="fileModeUpload" checked>
        <label class="btn btn-outline-secondary" for="fileModeUpload">Tải file PDF lên</label>
        <input type="radio" class="btn-check" name="file_mode" id="fileModeLink">
        <label class="btn btn-outline-secondary" for="fileModeLink">Dán link file PDF</label>
      </div>
      <div id="bookFileUploadField"><input type="file" name="book_file" class="form-control" accept="application/pdf,.pdf"></div>
      <div id="bookFileLinkField" class="d-none"><input type="url" name="book_file_link" class="form-control" placeholder="https://drive.google.com/file/d/.../view hoặc https://.../sach.pdf"></div>
      <div class="form-text">Để trống nếu chưa muốn thay đổi file hiện tại.</div>
    </div>

    <div class="card p-4 mb-3">
      <h6 class="fw-bold mb-3">Ảnh bìa</h6>
      <% if (book && book.cover_url) { %><div class="mb-2"><img src="<%= book.cover_url %>" style="height:80px;border-radius:6px"></div><% } %>
      <div class="btn-group btn-group-sm mb-2" role="group">
        <input type="radio" class="btn-check" name="cover_mode" id="coverModeUpload" checked>
        <label class="btn btn-outline-secondary" for="coverModeUpload">Tải ảnh lên</label>
        <input type="radio" class="btn-check" name="cover_mode" id="coverModeLink">
        <label class="btn btn-outline-secondary" for="coverModeLink">Dán link ảnh</label>
      </div>
      <div id="coverUploadField"><input type="file" name="cover" class="form-control" accept="image/*"></div>
      <div id="coverLinkField" class="d-none"><input type="url" name="cover_url_link" class="form-control" placeholder="https://..."></div>
    </div>

    <div class="card p-4 mb-3">
      <div class="form-check mb-0">
        <input type="checkbox" name="is_published" class="form-check-input" id="isPublished" <%= (!book || book.is_published) ? 'checked' : '' %>>
        <label class="form-check-label" for="isPublished">Hiển thị công khai</label>
      </div>
    </div>

    <button class="btn btn-primary">Lưu</button>
    <a href="/admin/doc-sach-online" class="btn btn-outline-secondary">Hủy</a>
  </form>
</div>

<link href="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.snow.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.min.js"></script>
<script>
  const cu = document.getElementById('coverUploadField'), cl = document.getElementById('coverLinkField');
  document.getElementById('coverModeUpload').addEventListener('change', () => { cu.classList.remove('d-none'); cl.classList.add('d-none'); });
  document.getElementById('coverModeLink').addEventListener('change', () => { cl.classList.remove('d-none'); cu.classList.add('d-none'); });
  <% if (book && book.cover_url && book.cover_url.startsWith('http')) { %>
    document.getElementById('coverModeLink').checked = true; cl.classList.remove('d-none'); cu.classList.add('d-none');
  <% } %>

  const bfu = document.getElementById('bookFileUploadField'), bfl = document.getElementById('bookFileLinkField');
  document.getElementById('fileModeUpload').addEventListener('change', () => { bfu.classList.remove('d-none'); bfl.classList.add('d-none'); });
  document.getElementById('fileModeLink').addEventListener('change', () => { bfl.classList.remove('d-none'); bfu.classList.add('d-none'); });
  <% if (book && book.file_source === 'link') { %>
    document.getElementById('fileModeLink').checked = true; bfl.classList.remove('d-none'); bfu.classList.add('d-none');
  <% } %>

  const descQuill = new Quill('#descEditor', {
    theme: 'snow',
    modules: { toolbar: [['bold','italic','underline'],[{list:'ordered'},{list:'bullet'}],['link'],[{header:[2,3,false]}],['clean']] }
  });
  descQuill.root.innerHTML = document.getElementById('descHidden').value;
  document.querySelector('form').addEventListener('submit', () => {
    document.getElementById('descHidden').value = descQuill.root.innerHTML;
  });
</script>
<%- include('../../partials/admin-footer') %>
