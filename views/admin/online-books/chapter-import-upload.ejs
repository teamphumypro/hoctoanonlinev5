<% var pageTitle = 'Nhập nội dung từ file' %>
<%- include('../../partials/admin-header') %>
<div class="mb-3"><a href="/admin/doc-sach-online/<%= book.id %>/chuong" class="btn btn-outline-secondary btn-sm">← Quay lại danh sách chương</a></div>

<div class="card p-4" style="max-width:600px">
  <h6 class="fw-bold mb-1">Nhập nội dung từ file Word/PDF hoặc link Google Drive</h6>
  <p class="small text-muted mb-3">Sách: <strong><%= book.title %></strong></p>

  <% if (error) { %><div class="alert alert-danger small"><%= error %></div><% } %>

  <div class="alert alert-warning small">
    <strong>Lưu ý:</strong> hệ thống tự tách chương dựa vào các dòng dạng "Chương 1", "CHƯƠNG I", "Phần 1"... trong file. Nếu file không có các dòng này, toàn bộ nội dung sẽ gom vào 1 chương để bạn tự tách tay sau. Đọc được .docx/.pdf/.xlsx. <strong>Không đọc được công thức Toán/Lý/Hóa dạng Equation/MathType và PDF dạng ảnh scan.</strong> Bạn sẽ được xem trước và sửa lại toàn bộ trước khi lưu. Nếu dùng link Drive, file cần dưới 25MB và đã bật chia sẻ công khai.
  </div>

  <form method="POST" action="/admin/doc-sach-online/<%= book.id %>/chuong/nhap-tu-file" enctype="multipart/form-data">
    <div class="mb-3">
      <label class="form-label">Chọn file (.docx, .pdf hoặc .xlsx)</label>
      <input type="file" name="exam_file" class="form-control" accept=".docx,.pdf,.xlsx,.xls">
    </div>
    <div class="mb-3 text-center text-muted small">— hoặc —</div>
    <div class="mb-3">
      <label class="form-label">Dán link Google Drive</label>
      <input type="url" name="drive_link" class="form-control" placeholder="https://drive.google.com/file/d/.../view">
    </div>
    <button class="btn btn-primary">Tải lên và tách chương</button>
    <a href="/admin/doc-sach-online/<%= book.id %>/chuong" class="btn btn-outline-secondary">Hủy</a>
  </form>
</div>
<%- include('../../partials/admin-footer') %>
