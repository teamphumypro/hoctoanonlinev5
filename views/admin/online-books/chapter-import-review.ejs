<% var pageTitle = 'Xem trước chương đã tách' %>
<%- include('../../partials/admin-header') %>

<div class="d-flex justify-content-between align-items-center mb-3">
  <div>
    <h6 class="fw-bold mb-0">Xem trước & sửa trước khi lưu</h6>
    <div class="small text-muted">Nhận diện được <strong><%= chapters.length %></strong> chương. Sửa tiêu đề/nội dung, hoặc bỏ tick "Giữ chương này" nếu tách sai.</div>
  </div>
  <a href="/admin/doc-sach-online/<%= book.id %>/chuong" class="btn btn-outline-secondary btn-sm">Hủy, quay lại</a>
</div>

<form method="POST" action="/admin/doc-sach-online-chuong/nhap-tu-file/luu">
  <input type="hidden" name="online_book_id" value="<%= book.id %>">

  <% chapters.forEach((c, i) => { %>
    <div class="card p-3 mb-3">
      <div class="d-flex justify-content-between align-items-start mb-2">
        <span class="fw-bold">Chương <%= i+1 %> <%= c.needsReview ? '<span class="badge bg-warning text-dark ms-1">Cần kiểm tra lại</span>' : '' %></span>
        <label class="small d-flex align-items-center gap-1">
          <input type="checkbox" name="chapters[<%= i %>][include]" checked> Giữ chương này
        </label>
      </div>
      <div class="mb-2">
        <input name="chapters[<%= i %>][title]" class="form-control form-control-sm mb-2" value="<%= c.title %>" placeholder="Tên chương">
        <textarea name="chapters[<%= i %>][content]" class="form-control form-control-sm" rows="6"><%= c.content %></textarea>
      </div>
      <% if (book.price > 0) { %>
        <div class="form-check">
          <input type="checkbox" name="chapters[<%= i %>][is_free]" class="form-check-input" id="free<%= i %>">
          <label class="form-check-label small" for="free<%= i %>">Cho đọc thử miễn phí</label>
        </div>
      <% } %>
    </div>
  <% }) %>

  <% if (chapters.length > 0) { %>
    <button class="btn btn-primary">Lưu tất cả chương đã chọn</button>
  <% } %>
</form>
<%- include('../../partials/admin-footer') %>
