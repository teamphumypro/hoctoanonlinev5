<% var pageTitle = 'Sửa mục lục' %>
<%- include('../../partials/admin-header') %>
<div class="mb-3"><a href="/admin/doc-sach-online/<%= book.id %>/muc-luc" class="btn btn-outline-secondary btn-sm">← Quay lại mục lục</a></div>
<div class="card p-4" style="max-width:600px">
  <form method="POST" action="/admin/doc-sach-online-muc-luc/<%= entry.id %>">
    <input type="hidden" name="online_book_id" value="<%= book.id %>">
    <div class="mb-3"><label class="form-label">Tiêu đề</label>
      <input name="title" class="form-control" value="<%= entry.title %>" required></div>
    <div class="mb-3"><label class="form-label">Số trang</label>
      <input type="number" min="1" name="page_number" class="form-control" value="<%= entry.page_number %>" required></div>
    <button class="btn btn-primary">Lưu</button>
  </form>
</div>
<%- include('../../partials/admin-footer') %>
