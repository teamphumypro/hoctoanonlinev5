<% var pageTitle = 'Mục lục: ' + book.title %>
<%- include('../../partials/admin-header') %>
<div class="mb-3 d-flex justify-content-between">
  <a href="/admin/doc-sach-online" class="btn btn-outline-secondary btn-sm">← Quay lại danh sách</a>
  <a href="/doc-sach-online/<%= book.slug %>/doc" target="_blank" class="btn btn-outline-primary btn-sm">👁 Xem thử trang đọc</a>
</div>

<div class="alert alert-info small">
  Gõ tay tiêu đề và <b>số trang</b> tương ứng trong file PDF (trang đầu tiên của sách là trang 1).
  Khi đọc, người dùng bấm vào mục lục và chọn một mục sẽ được nhảy thẳng tới đúng trang bạn nhập ở đây —
  không cần hệ thống tự nhận diện nữa. Nếu bạn không nhập mục nào ở đây, hệ thống sẽ quay lại tự nhận diện mục lục như trước.
</div>

<div class="card p-3 mb-3">
  <h6 class="fw-bold mb-2">Thêm mục lục mới</h6>
  <form method="POST" action="/admin/doc-sach-online-muc-luc" class="row g-2 align-items-end">
    <input type="hidden" name="online_book_id" value="<%= book.id %>">
    <div class="col-sm-7">
      <label class="form-label small mb-1">Tiêu đề</label>
      <input name="title" class="form-control" placeholder="VD: Chương 1: Mệnh đề - Tập hợp" required>
    </div>
    <div class="col-sm-3">
      <label class="form-label small mb-1">Số trang</label>
      <input type="number" min="1" name="page_number" class="form-control" placeholder="VD: 5" required>
    </div>
    <div class="col-sm-2">
      <button class="btn btn-primary w-100">Thêm</button>
    </div>
  </form>
</div>

<div class="card p-3">
  <h6 class="fw-bold mb-2">Danh sách mục lục (<%= entries.length %>)</h6>
  <% if (entries.length === 0) { %>
    <div class="text-muted small">Chưa nhập mục lục nào.</div>
  <% } else { %>
    <table class="table table-sm align-middle">
      <thead><tr><th style="width:60%">Tiêu đề</th><th style="width:20%">Số trang</th><th></th></tr></thead>
      <tbody>
        <% entries.forEach(e => { %>
          <tr>
            <td><%= e.title %></td>
            <td><%= e.page_number %></td>
            <td class="text-nowrap">
              <a href="/admin/doc-sach-online-muc-luc/<%= e.id %>/sua" class="btn btn-sm btn-outline-secondary">Sửa</a>
              <form method="POST" action="/admin/doc-sach-online-muc-luc/<%= e.id %>/xoa" class="d-inline" onsubmit="return confirm('Xóa mục này?')">
                <input type="hidden" name="online_book_id" value="<%= book.id %>">
                <button class="btn btn-sm btn-outline-danger">Xóa</button>
              </form>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  <% } %>
</div>
<%- include('../../partials/admin-footer') %>
