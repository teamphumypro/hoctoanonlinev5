<% var pageTitle = 'Nhân sự & Phân quyền' %>
<%- include('../../partials/admin-header') %>
<div class="d-flex justify-content-end mb-3"><a href="/admin/nhan-su/them-moi" class="btn btn-primary btn-sm">+ Thêm nhân sự</a></div>
<div class="card p-3">
  <table class="table">
    <thead><tr><th>Họ tên</th><th>Email</th><th>Vai trò</th><th>Đổi vai trò</th></tr></thead>
    <tbody>
      <% staff.forEach(s => { %>
        <tr>
          <td><%= s.name %></td><td><%= s.email %></td>
          <td><span class="badge bg-dark"><%= s.role %></span></td>
          <td>
            <form method="POST" action="/admin/nhan-su/<%= s.id %>/vai-tro" class="d-flex gap-2">
              <select name="role" class="form-select form-select-sm" style="width:160px">
                <% ['super_admin','admin','teacher','ta'].forEach(r => { %>
                  <option value="<%= r %>" <%= s.role===r?'selected':'' %>><%= r %></option>
                <% }) %>
              </select>
              <button class="btn btn-sm btn-outline-primary">Lưu</button>
            </form>
          </td>
        </tr>
      <% }) %>
      <% if (staff.length === 0) { %><tr><td colspan="4" class="text-center text-muted">Chưa có nhân sự nào ngoài Super Admin.</td></tr><% } %>
    </tbody>
  </table>
  <p class="small text-muted mb-0">Cấp bậc quyền: super_admin > admin > teacher (giảng viên) > ta (trợ giảng). Chỉ Super Admin mới đổi được vai trò.</p>
</div>
<%- include('../../partials/admin-footer') %>
