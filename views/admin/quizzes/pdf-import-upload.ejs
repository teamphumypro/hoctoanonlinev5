<% var pageTitle = 'Tải đề thi PDF' %>
<%- include('../../partials/admin-header') %>

<div class="card p-4" style="max-width:600px">
  <h6 class="fw-bold mb-1">Tải đề thi dạng PDF sách lật</h6>
  <p class="small text-muted mb-3">Bài kiểm tra: <strong><%= quiz.title %></strong></p>

  <% if (error) { %><div class="alert alert-danger small"><%= error %></div><% } %>

  <div class="alert alert-secondary small">
    Học sinh sẽ nhìn thấy <strong>nguyên trang PDF bạn tải lên</strong> (giữ đúng công thức, hình,
    bảng như file gốc), lật trang như đọc sách. Hệ thống sẽ tự động dò xem <strong>câu nào nằm ở
    trang nào, có mấy phương án, đáp án đúng là gì</strong> (dựa trên phần "Đáp án" trong file) —
    bạn xem lại và sửa tay ở bước tiếp theo trước khi lưu, nên không cần file hoàn hảo.
  </div>

  <form method="POST" action="/admin/bai-kiem-tra/<%= quiz.id %>/tai-de" enctype="multipart/form-data">
    <div class="mb-3">
      <label class="form-label">Chọn file PDF đề thi (có kèm đáp án ở cuối)</label>
      <input type="file" name="exam_file" class="form-control" accept=".pdf" required>
    </div>
    <button class="btn btn-primary">Tải lên và phân tích</button>
    <a href="<%= quiz.lesson_id ? '/admin/bai-hoc/'+quiz.lesson_id+'/bai-kiem-tra' : '/admin/bai-kiem-tra/'+quiz.id+'/cau-hoi' %>" class="btn btn-outline-secondary">Hủy</a>
  </form>
</div>

<%- include('../../partials/admin-footer') %>
