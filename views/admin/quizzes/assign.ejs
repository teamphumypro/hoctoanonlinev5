<% var pageTitle = 'Giao đề: ' + quiz.title %>
<%- include('../../partials/admin-header') %>
<div class="mb-3"><a href="/admin/phong-thi" class="btn btn-outline-secondary btn-sm">← Quay lại Thực chiến phòng thi</a></div>

<div class="card p-4 mb-3">
  <h6 class="fw-bold mb-2">Giao đề "<%= quiz.title %>" cho học viên</h6>
  <form method="POST" action="/admin/bai-kiem-tra/<%= quiz.id %>/giao-de">
    <div class="mb-3">
      <label class="form-label">Hạn nộp (để trống = không giới hạn)</label>
      <input type="datetime-local" name="due_at" class="form-control" style="max-width:280px">
    </div>
    <div class="mb-3" style="max-height:320px; overflow-y:auto; border:1px solid #e5e5ef; border-radius:8px; padding:10px">
      <% students.forEach(s => { %>
        <div class="form-check">
          <input type="checkbox" name="user_ids" value="<%= s.id %>" class="form-check-input" id="u<%= s.id %>" <%= assignedIds.includes(s.id) ? 'checked' : '' %>>
          <label class="form-check-label" for="u<%= s.id %>"><%= s.name %> <span class="text-muted small">(<%= s.email %>)</span></label>
        </div>
      <% }) %>
      <% if (students.length === 0) { %><p class="text-muted small mb-0">Chưa có học viên nào trong hệ thống.</p><% } %>
    </div>
    <button class="btn btn-primary btn-sm">Lưu danh sách giao đề</button>
  </form>
</div>

<div class="card p-3">
  <h6 class="fw-bold mb-2">Đã giao cho (<%= assignedUsers.length %>)</h6>
  <ul class="list-group">
    <% assignedUsers.forEach(a => { %>
      <li class="list-group-item d-flex justify-content-between align-items-center">
        <span><%= a.name %> <span class="text-muted small">— hạn: <%= a.due_at ? formatDate(a.due_at) : 'Không giới hạn' %></span></span>
        <form method="POST" action="/admin/bai-kiem-tra/<%= quiz.id %>/giao-de/<%= a.user_id %>/huy">
          <button class="btn btn-sm btn-outline-danger">Hủy giao</button>
        </form>
      </li>
    <% }) %>
    <% if (assignedUsers.length === 0) { %><li class="list-group-item text-muted">Chưa giao cho ai.</li><% } %>
  </ul>
</div>
<%- include('../../partials/admin-footer') %>
