<%- include('../partials/header') %>
<div class="container-fluid py-4" style="max-width:1050px">
  <div class="card shadow-sm border-0">
    <div class="card-body p-4">
      <h4 class="fw-bold mb-2">Tạo bài thi từ PDF</h4>
      <p class="text-muted">Hệ thống giữ nguyên từng trang đề như bản gốc, tự tìm câu hỏi và trang tương ứng. Sau đó bạn có thể sửa thủ công trước khi lưu.</p>
      <% if (error) { %><div class="alert alert-danger"><%= error %></div><% } %>
      <div class="alert alert-info small">
        <strong>Cách mới:</strong> không còn chuyển Word, không bóc công thức, không dựng lại hình ảnh. Hãy xuất đề thành PDF rồi tải lên để học sinh xem đúng nguyên bản.
      </div>
      <form method="POST" action="/admin/bai-kiem-tra/<%= quiz.id %>/tai-de" enctype="multipart/form-data">
        <label class="form-label fw-semibold">Chọn file PDF</label>
        <input class="form-control mb-3" type="file" name="exam_file" accept="application/pdf,.pdf" required>
        <button class="btn btn-primary">Phân tích PDF tự động</button>
        <a class="btn btn-outline-secondary" href="/admin/bai-kiem-tra/<%= quiz.id %>/cau-hoi">Hủy</a>
      </form>
    </div>
  </div>
</div>
<%- include('../partials/footer') %>
