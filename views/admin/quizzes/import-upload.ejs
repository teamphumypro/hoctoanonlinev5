<% var pageTitle = 'Tải đề thi từ file' %>
<%- include('../../partials/admin-header') %>

<div class="card p-4" style="max-width:600px">
  <h6 class="fw-bold mb-1">Tải đề thi từ file Word/PDF hoặc link Google Drive</h6>
  <p class="small text-muted mb-3">Bài kiểm tra: <strong><%= quiz.title %></strong></p>

  <% if (error) { %><div class="alert alert-danger small"><%= error %></div><% } %>

  <div class="alert alert-warning small">
    <strong>Khuyến nghị để giống quy trình Azota:</strong> ưu tiên file <strong>.docx gốc</strong>. Hệ thống giữ ảnh nhúng và công thức Word Equation; công thức MathType cũ dạng WMF/EMF sẽ được chuyển sang ảnh khi máy chủ có LibreOffice. PDF chỉ đọc tốt khi có lớp chữ thật; PDF scan và ảnh dùng OCR nên cần rà soát kỹ. Sau khi tải lên, màn hình sẽ chia đôi: <strong>bên trái là đề thực tế, bên phải là mã nhập liệu</strong>; bạn có thể sửa, chọn đáp án, chia điểm và kiểm tra lỗi trước khi lưu.
  </div>

  <form method="POST" action="/admin/bai-kiem-tra/<%= quiz.id %>/tai-de" enctype="multipart/form-data">
    <div class="mb-3">
      <label class="form-label">Chọn file đề thi (.docx, .pdf, .xlsx hoặc ảnh .jpg/.png)</label>
      <input type="file" name="exam_file" class="form-control" accept=".docx,.pdf,.xlsx,.xls,.jpg,.jpeg,.png,.webp">
    </div>
    <div class="mb-3 text-center text-muted small">— hoặc —</div>
    <div class="mb-3">
      <label class="form-label">Dán link Google Drive</label>
      <input type="url" name="drive_link" class="form-control" placeholder="https://drive.google.com/file/d/.../view">
    </div>

    <% if (aiConfigured) { %>
      <div class="form-check mb-3">
        <input type="checkbox" name="use_ai" class="form-check-input" id="useAi" checked>
        <label class="form-check-label" for="useAi">Dùng AI để nhận diện thông minh hơn (chính xác hơn, tốn phí nhỏ theo API Key bạn đã cấu hình)</label>
      </div>
    <% } else { %>
      <div class="alert alert-secondary small">
        Chưa cấu hình AI API Key nên hệ thống sẽ chỉ dò theo mẫu thông thường (độ chính xác thấp hơn).
        Vào <a href="/admin/cai-dat/ai">Cài đặt AI</a> để bật tính năng nhận diện thông minh hơn.
      </div>
    <% } %>

    <button class="btn btn-primary">Tải lên và phân tích</button>
    <a href="<%= quiz.lesson_id ? '/admin/bai-hoc/'+quiz.lesson_id+'/bai-kiem-tra' : '/admin/bai-kiem-tra/'+quiz.id+'/cau-hoi' %>" class="btn btn-outline-secondary">Hủy</a>
  </form>
</div>

<%- include('../../partials/admin-footer') %>
