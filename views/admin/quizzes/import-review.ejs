  .az-modal-mask.show{display:flex}
  .az-modal-card{width:min(720px,96vw);max-height:86vh;overflow:auto;background:#fff;border-radius:9px;box-shadow:0 18px 50px rgba(0,0,0,.25)}
  .az-modal-head{padding:14px 18px;border-bottom:1px solid #e1e5ec;display:flex;justify-content:space-between;align-items:center}
