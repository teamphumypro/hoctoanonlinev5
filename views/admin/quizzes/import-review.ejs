<% var pageTitle = 'Kiểm tra đề đã nhận diện' %>
<%- include('../../partials/admin-header') %>
<style>
.exam-editor{height:calc(100vh - 150px);min-height:650px}.exam-col{height:100%;overflow:auto}.question-card{border:1px solid #dfe3eb;border-radius:8px;background:#fff}.question-card.active{box-shadow:0 0 0 2px #3159d9}.editable{outline:none;border-radius:4px;padding:3px}.editable:focus{background:#fffbe8;box-shadow:0 0 0 1px #f2c94c}.answer-choice{border:1px solid #dce1ea;border-radius:7px;padding:8px 10px;margin-bottom:6px;display:flex;gap:8px;align-items:flex-start}.answer-choice.correct{border-color:#2f66d5;background:#f1f5ff}.choice-badge{width:26px;height:26px;border:1px solid #aeb7c6;border-radius:50%;display:inline-flex;align-items:center;justify-content:center;flex:0 0 26px;cursor:pointer}.correct .choice-badge{background:#2f66d5;color:#fff;border-color:#2f66d5}.editor-box{font-family:ui-monospace,SFMono-Regular,Menlo,monospace;font-size:13px}.sticky-tools{position:sticky;top:0;z-index:5;background:white}.solution-box{background:#fff8e7;border-left:4px solid #f4b740}.part-title{background:#f2f4f8;border-radius:6px;padding:9px 12px;font-weight:700}.navigator button{min-width:38px}
</style>

<div class="d-flex justify-content-between align-items-center mb-2">
  <div>
    <h5 class="fw-bold mb-0">Kiểm tra và sửa đề</h5>
    <div class="small text-muted">Đã nhận diện <strong><%= questions.length %></strong> câu. Có thể sửa ở cả khung trái và khung phải; hai bên đồng bộ ngay.</div>
  </div>
  <a href="/admin/bai-kiem-tra/<%= quiz.id %>/tai-de" class="btn btn-outline-secondary btn-sm">Tải file khác</a>
</div>
<% if (aiError) { %><div class="alert alert-warning py-2 small">AI không xử lý được nên hệ thống đã dùng bộ nhận diện nội bộ: <%= aiError %></div><% } %>

<form method="POST" action="/admin/bai-kiem-tra/luu-de-import" id="saveForm">
<input type="hidden" name="redirect_to" value="<%= quiz.lesson_id ? '/admin/bai-hoc/'+quiz.lesson_id+'/bai-kiem-tra' : '/admin/bai-kiem-tra/'+quiz.id+'/cau-hoi' %>">
<input type="hidden" name="quiz_id" value="<%= quiz.id %>">

<div class="row g-2 exam-editor">
  <div class="col-lg-7 exam-col border rounded bg-light p-2" id="previewColumn">
    <div class="sticky-tools border-bottom p-2 mb-2 d-flex justify-content-between align-items-center">
      <div class="small fw-semibold"><i class="fa-solid fa-eye"></i> Đề học viên nhìn thấy</div>
      <div class="small text-muted">Bấm vào nội dung để sửa trực tiếp</div>
    </div>
    <% let lastPart = null; questions.forEach((q,i)=>{ let part=q.part || (q.type==='true_false'?2:q.type==='short_answer'?3:1); %>
      <% if (part !== lastPart) { lastPart=part; %><div class="part-title mb-2">PHẦN <%= ['','I','II','III'][part] || part %></div><% } %>
      <div class="question-card p-3 mb-2 preview-row" data-index="<%= i %>">
        <div class="d-flex justify-content-between mb-2"><strong>Câu <%= q.questionNumber || i+1 %>.</strong><span class="badge <%= q.needsReview?'bg-warning text-dark':'bg-success' %>"><%= q.needsReview?'Cần kiểm tra':'Đã nhận diện' %></span></div>
        <div class="editable preview-question" contenteditable="true"></div>
        <div class="preview-answers mt-2"></div>
        <div class="solution-box rounded p-2 mt-2 preview-solution" style="display:none"><div class="small fw-bold mb-1">HƯỚNG DẪN GIẢI</div><div class="editable preview-explanation" contenteditable="true"></div></div>
      </div>
    <% }) %>
  </div>

  <div class="col-lg-5 exam-col border rounded bg-white" id="editorColumn">
    <div class="sticky-tools p-2 border-bottom">
      <div class="d-flex gap-2 align-items-center">
        <strong class="small">Dữ liệu câu hỏi</strong>
        <select class="form-select form-select-sm" id="jumpQuestion"><% questions.forEach((q,i)=>{ %><option value="<%= i %>">Câu <%= q.questionNumber || i+1 %> — Phần <%= q.part || '?' %></option><% }) %></select>
      </div>
    </div>
    <% questions.forEach((q,i)=>{ %>
      <div class="p-3 editor-row <%= i?'d-none':'' %>" data-index="<%= i %>">
        <input type="checkbox" name="questions[<%= i %>][include]" checked class="form-check-input"> <span class="small">Giữ câu này</span>
        <div class="row g-2 mt-1">
          <div class="col-8"><label class="small">Dạng câu</label><select name="questions[<%= i %>][type]" class="form-select form-select-sm q-type"><option value="single_choice" <%= q.type==='single_choice'?'selected':'' %>>Trắc nghiệm</option><option value="true_false" <%= q.type==='true_false'?'selected':'' %>>Đúng/Sai</option><option value="short_answer" <%= q.type==='short_answer'?'selected':'' %>>Trả lời ngắn</option><option value="essay" <%= q.type==='essay'?'selected':'' %>>Tự luận</option></select></div>
          <div class="col-4"><label class="small">Điểm</label><input name="questions[<%= i %>][points]" type="number" step="0.05" class="form-control form-control-sm" value="<%= q.points %>"></div>
        </div>
        <label class="small mt-2">Nội dung</label><textarea name="questions[<%= i %>][question]" class="form-control form-control-sm editor-box q-question" rows="6"><%= q.question %></textarea>
        <div class="type-fields mt-2" data-type="single_choice">
          <% for(let k=0;k<4;k++){ %><div class="input-group input-group-sm mb-1"><span class="input-group-text"><input type="radio" name="questions[<%= i %>][correct_index]" value="<%= k %>" class="q-correct-index" <%= q.correctIndex===k?'checked':'' %>></span><span class="input-group-text"><%= String.fromCharCode(65+k) %></span><input name="questions[<%= i %>][options][]" class="form-control q-option" value="<%= q.options?.[k] || '' %>"></div><% } %>
        </div>
        <div class="type-fields mt-2" data-type="true_false">
          <% for(let k=0;k<4;k++){ let it=q.items?.[k]||{content:'',is_correct:false}; %><div class="input-group input-group-sm mb-1"><span class="input-group-text"><%= String.fromCharCode(97+k) %>)</span><input name="questions[<%= i %>][tf_content][]" class="form-control q-tf-content" value="<%= it.content %>"><span class="input-group-text"><input type="checkbox" name="questions[<%= i %>][tf_correct][]" value="<%= k %>" class="q-tf-correct" <%= it.is_correct?'checked':'' %>> Đúng</span></div><% } %>
        </div>
        <div class="type-fields mt-2" data-type="short_answer"><label class="small">Đáp án đúng</label><input name="questions[<%= i %>][correct_answer]" class="form-control form-control-sm q-correct-answer" value="<%= q.correct_answer || '' %>"></div>
        <label class="small mt-2">Lời giải chi tiết</label><textarea name="questions[<%= i %>][explanation]" class="form-control form-control-sm editor-box q-explanation" rows="8"><%= q.explanation || '' %></textarea>
      </div>
    <% }) %>
  </div>
</div>
<div class="d-flex justify-content-between mt-3"><div class="small text-muted">Đáp án được chọn bằng nút tròn ở khung trái hoặc phải.</div><button class="btn btn-primary px-4"><i class="fa-solid fa-floppy-disk"></i> Lưu toàn bộ đề thi</button></div>
</form>

<script>window.MathJax={tex:{inlineMath:[['$','$']]},startup:{typeset:false}};</script><script src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/mml-chtml.js"></script>
<script>
const letters=['A','B','C','D'];
function editor(i){return document.querySelector('.editor-row[data-index="'+i+'"]')}
function preview(i){return document.querySelector('.preview-row[data-index="'+i+'"]')}
function showFields(row){const type=row.querySelector('.q-type').value;row.querySelectorAll('.type-fields').forEach(x=>x.style.display=x.dataset.type===type?'':'none')}
function render(i){
 const e=editor(i),p=preview(i),type=e.querySelector('.q-type').value;
 p.querySelector('.preview-question').innerHTML=e.querySelector('.q-question').value;
 let html='';
 if(type==='single_choice'){
  const chosen=Number(e.querySelector('.q-correct-index:checked')?.value ?? -1);
  [...e.querySelectorAll('.q-option')].forEach((x,k)=>html+=`<div class="answer-choice ${k===chosen?'correct':''}" data-choice="${k}"><span class="choice-badge">${letters[k]}</span><div class="editable preview-option flex-grow-1" data-k="${k}" contenteditable="true">${x.value}</div></div>`);
 }else if(type==='true_false'){
  const cs=[...e.querySelectorAll('.q-tf-content')],bs=[...e.querySelectorAll('.q-tf-correct')];
  cs.forEach((x,k)=>html+=`<div class="answer-choice ${bs[k].checked?'correct':''}" data-tf="${k}"><span class="choice-badge">${String.fromCharCode(97+k)}</span><div class="editable preview-tf flex-grow-1" data-k="${k}" contenteditable="true">${x.value}</div><strong>${bs[k].checked?'Đúng':'Sai'}</strong></div>`);
 }else if(type==='short_answer'){html=`<div class="alert alert-light py-2">Đáp án: <span class="editable preview-short" contenteditable="true">${e.querySelector('.q-correct-answer').value}</span></div>`}
 p.querySelector('.preview-answers').innerHTML=html;
 const ex=e.querySelector('.q-explanation').value,box=p.querySelector('.preview-solution');box.style.display=ex.trim()?'':'none';p.querySelector('.preview-explanation').innerHTML=ex;
 bindPreview(i); if(window.MathJax?.typesetPromise) window.MathJax.typesetPromise([p]).catch(()=>{});
}
function bindPreview(i){const e=editor(i),p=preview(i);
 p.querySelector('.preview-question').oninput=ev=>e.querySelector('.q-question').value=ev.target.innerHTML;
 p.querySelectorAll('.preview-option').forEach(x=>x.oninput=()=>e.querySelectorAll('.q-option')[x.dataset.k].value=x.innerHTML);
 p.querySelectorAll('[data-choice]').forEach(x=>x.querySelector('.choice-badge').onclick=()=>{e.querySelectorAll('.q-correct-index')[x.dataset.choice].checked=true;render(i)});
 p.querySelectorAll('.preview-tf').forEach(x=>x.oninput=()=>e.querySelectorAll('.q-tf-content')[x.dataset.k].value=x.innerHTML);
 p.querySelectorAll('[data-tf]').forEach(x=>x.querySelector('.choice-badge').onclick=()=>{const c=e.querySelectorAll('.q-tf-correct')[x.dataset.tf];c.checked=!c.checked;render(i)});
 const sh=p.querySelector('.preview-short');if(sh)sh.oninput=()=>e.querySelector('.q-correct-answer').value=sh.innerText;
 p.querySelector('.preview-explanation').oninput=ev=>e.querySelector('.q-explanation').value=ev.target.innerHTML;
 p.onclick=()=>selectQuestion(i);
}
function selectQuestion(i){document.querySelectorAll('.editor-row').forEach(x=>x.classList.toggle('d-none',Number(x.dataset.index)!==i));document.querySelectorAll('.preview-row').forEach(x=>x.classList.toggle('active',Number(x.dataset.index)===i));document.getElementById('jumpQuestion').value=i}
document.querySelectorAll('.editor-row').forEach((e,i)=>{showFields(e);e.querySelectorAll('input,textarea,select').forEach(x=>x.addEventListener('input',()=>{showFields(e);render(i)}));e.querySelectorAll('input,select').forEach(x=>x.addEventListener('change',()=>{showFields(e);render(i)}));render(i)});
document.getElementById('jumpQuestion').onchange=e=>{const i=Number(e.target.value);selectQuestion(i);preview(i).scrollIntoView({behavior:'smooth',block:'center'})};if(document.querySelector('.preview-row'))selectQuestion(0);
</script>
<%- include('../../partials/admin-footer') %>
