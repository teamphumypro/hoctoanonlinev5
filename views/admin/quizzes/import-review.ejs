<script>window.MathJax={tex:{inlineMath:[['$','$'],['\\(','\\)']]},startup:{typeset:false}};</script>
<script id="MathJax-script" async src="https://cdn.jsdelivr.net/npm/mathjax@3/es5/tex-mml-chtml.js"></script>
<script>
(function(){
  const editor=document.getElementById('rawEditor');
  const preview=document.getElementById('previewPane');
  const hidden=document.getElementById('hiddenQuestions');
  const status=document.getElementById('parseStatus');
  const saveCount=document.getElementById('saveCount');
  const lineNumbers=document.getElementById('lineNumbers');
  const navPop=document.getElementById('navPop');
  let debounce;
  let sectionPoints={};

  const esc=s=>String(s==null?'':s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  function safeRich(s){
    const t=document.createElement('template');
    t.innerHTML=String(s||'').replace(/\n/g,'<br>');
    t.content.querySelectorAll('script,iframe,object,embed,style,link,form,input,button').forEach(n=>n.remove());
    t.content.querySelectorAll('*').forEach(el=>[...el.attributes].forEach(a=>{
      const n=a.name.toLowerCase();
      if(n.startsWith('on')||n==='srcdoc'||n==='href')el.removeAttribute(a.name);
      if(n==='src'&&!/^(data:image\/|https?:\/\/|\/)/i.test(a.value))el.removeAttribute(a.name);
    }));
    return t.innerHTML;
  }
  function sectionType(title){
    const normalized=String(title||'').toUpperCase().replace(/PHAN/g,'PHẦN');
    const m=normalized.match(/PHẦN\s*(IV|III|II|I|4|3|2|1)\b/);
    const code=m?m[1]:'I';
    if(code==='II'||code==='2')return 'true_false';
    if(code==='III'||code==='3')return 'short_answer';
    if(code==='IV'||code==='4')return 'essay';
    return 'single_choice';
  }
  function defaultPoints(type){return type==='true_false'?1:type==='short_answer'?0.5:type==='essay'?2:0.25}

  function parse(text){
    const lines=String(text||'').replace(/\r/g,'').split('\n');
    const sections=[];let section=null,q=null,mode='single_choice',errors=[];
    function ensureSection(){if(!section){section={id:'I',title:'PHẦN I: Trắc nghiệm nhiều lựa chọn',type:'single_choice',questions:[]};sections.push(section)}}
    function finishQ(){
      if(!q)return;
      ensureSection();
      q.question=q.question.trim();q.explanation=q.explanation.trim();
      if(q.question)section.questions.push(q);
      q=null;
    }
    function startSection(line){
      finishQ();
      const title=line.replace(/^\s*\[|\]\s*$/g,'').trim();
      mode=sectionType(title);
      const mm=title.toUpperCase().match(/PH(?:Ầ|A)N\s*(IV|III|II|I|4|3|2|1)/);
      section={id:mm?mm[1]:String(sections.length+1),title,type:mode,questions:[]};
      sections.push(section);
    }
    lines.forEach((raw,idx)=>{
      const line=raw.trim();
      if(!line){if(q&&q.explanation)q.explanation+='\n';return}
      if(/^\[\s*PH(?:Ầ|A)N\b/i.test(line)){startSection(line);return}
      let m=line.match(/^(?:Câu|Cau|Question)\s*(\d+)\s*[\.\:\-\)]\s*(.*)$/i);
      if(m){finishQ();ensureSection();q={number:Number(m[1]),sourceLine:idx+1,type:mode,question:m[2],points:sectionPoints[section.id]??defaultPoints(mode),options:['','','',''],correctIndex:-1,items:[null,null,null,null],correct_answer:'',explanation:'',readingExplanation:false};return}
      if(!q){if(section)section.title+=' '+line;return}
      m=line.match(/^([A-D])\s*[\.\)\:\-]\s*(.*)$/i);
      if(m&&q.type==='single_choice'){q.options[m[1].toUpperCase().charCodeAt(0)-65]=m[2];q.readingExplanation=false;return}
      m=line.match(/^([a-d])\s*[\)\.\-]\s*(.*?)(?:\s*\[(Đúng|Dung|Sai|True|False|Đ|S)\]\s*)?$/i);
      if(m&&q.type==='true_false'){
        const k=m[1].toLowerCase().charCodeAt(0)-97;
        q.items[k]={content:m[2],is_correct:/^(đúng|dung|true|đ)$/i.test(m[3]||'')};q.readingExplanation=false;return
      }
      m=line.match(/^(?:Đáp\s*án|Dap\s*an|Đáp\s*số|Dap\s*so|ĐA)\s*[:\.]\s*(.*)$/i);
      if(m){
        const ans=m[1].trim();
        if(q.type==='single_choice'&&/^[A-D]$/i.test(ans))q.correctIndex=ans.toUpperCase().charCodeAt(0)-65;
        else q.correct_answer=ans;
        q.readingExplanation=false;return
      }
      m=line.match(/^(?:Lời\s*giải|Loi\s*giai|Hướng\s*dẫn\s*giải|Huong\s*dan\s*giai)\s*[:\.]\s*(.*)$/i);
      if(m){q.explanation=m[1];q.readingExplanation=true;return}
      if(q.readingExplanation)q.explanation+=(q.explanation?'\n':'')+line;
      else if(q.type==='single_choice'){
        const last=q.options.map((v,i)=>v?i:-1).filter(i=>i>=0).pop();
        if(last!==undefined)q.options[last]+='\n'+line;else q.question+='\n'+line;
      }else if(q.type==='true_false'){
        const last=q.items.map((v,i)=>v?i:-1).filter(i=>i>=0).pop();
        if(last!==undefined)q.items[last].content+='\n'+line;else q.question+='\n'+line;
      }else q.question+='\n'+line;
    });
    finishQ();
    sections.forEach(sec=>sec.questions.forEach(item=>{
      if(item.type==='single_choice'){
        const n=item.options.filter(v=>String(v||'').trim()).length;
        if(n<2)errors.push({line:item.sourceLine,msg:'Câu '+item.number+' chưa đủ phương án A–D.'});
        if(item.correctIndex<0)errors.push({line:item.sourceLine,msg:'Câu '+item.number+' chưa có đáp án đúng.'});
      }
      if(item.type==='true_false'){
        item.items=item.items.map(v=>v||{content:'',is_correct:false});
        if(item.items.filter(v=>v.content.trim()).length<4)errors.push({line:item.sourceLine,msg:'Câu '+item.number+' chưa đủ 4 ý a–d.'});
      }
      if(item.type==='short_answer'&&!item.correct_answer)errors.push({line:item.sourceLine,msg:'Câu '+item.number+' chưa có đáp án ngắn.'});
    }));
    return {sections,questions:sections.flatMap(s=>s.questions),errors};
  }

  function field(name,value){const el=document.createElement('input');el.type='hidden';el.name=name;el.value=value==null?'':value;return el}
  function buildHidden(questions){
    hidden.innerHTML='';
    questions.forEach((q,i)=>{
      hidden.append(field(`questions[${i}][include]`,'on'));
      hidden.append(field(`questions[${i}][type]`,q.type));
      hidden.append(field(`questions[${i}][points]`,q.points));
      hidden.append(field(`questions[${i}][question]`,q.question));
      hidden.append(field(`questions[${i}][explanation]`,q.explanation||''));
      if(q.type==='single_choice'){
        hidden.append(field(`questions[${i}][correct_index]`,q.correctIndex));
        q.options.forEach(v=>hidden.append(field(`questions[${i}][options][]`,v)));
      }else if(q.type==='true_false'){
        q.items.forEach((it,k)=>{
          hidden.append(field(`questions[${i}][tf_content][]`,it.content));
          if(it.is_correct)hidden.append(field(`questions[${i}][tf_correct][]`,k));
        });
      }else if(q.type==='short_answer')hidden.append(field(`questions[${i}][correct_answer]`,q.correct_answer||''));
    });
  }
  function replaceAnswerInEditor(q,letter){
    const lines=editor.value.replace(/\r/g,'').split('\n');
    const start=q.sourceLine-1;
    let end=lines.length;
    for(let i=start+1;i<lines.length;i++)if(/^(?:Câu|Cau|Question)\s*\d+\s*[\.\:\-\)]/i.test(lines[i].trim())||/^\[\s*PH(?:Ầ|A)N\b/i.test(lines[i].trim())){end=i;break}
    let found=-1;
    for(let i=start+1;i<end;i++)if(/^(?:Đáp\s*án|Dap\s*an|Đáp\s*số|Dap\s*so|ĐA)\s*[:\.]/i.test(lines[i].trim())){found=i;break}
    if(found>=0)lines[found]='Đáp án: '+letter;else lines.splice(end,0,'Đáp án: '+letter);
    editor.value=lines.join('\n');update(true);
  }
  function replaceTfInEditor(q,k,isCorrect){
    const lines=editor.value.replace(/\r/g,'').split('\n');
    const start=q.sourceLine-1;let end=lines.length;
    for(let i=start+1;i<lines.length;i++)if(/^(?:Câu|Cau|Question)\s*\d+\s*[\.\:\-\)]/i.test(lines[i].trim())||/^\[\s*PH(?:Ầ|A)N\b/i.test(lines[i].trim())){end=i;break}
    const letter=String.fromCharCode(97+k);
    for(let i=start+1;i<end;i++){
      const re=new RegExp('^\\s*'+letter+'\\s*[\\)\\.\\-]','i');
      if(re.test(lines[i])){lines[i]=lines[i].replace(/\s*\[(?:Đúng|Dung|Sai|True|False|Đ|S)\]\s*$/i,'')+' ['+(isCorrect?'Đúng':'Sai')+']';break}
    }
    editor.value=lines.join('\n');update(true);
  }
  function render(result){
    if(!result.questions.length)preview.innerHTML='<div class="az-empty">Chưa nhận diện được câu hỏi. Hãy nhập theo mẫu ở khung bên phải.</div>';
    else preview.innerHTML=result.sections.map((sec,si)=>{
      if(!sec.questions.length)return '';
      return `<section class="az-group"><div class="az-group-head"><span class="az-group-label">Tiêu đề nhóm</span><div class="az-group-title">${esc(sec.title)}</div></div>${sec.questions.map((q,qi)=>{
        let answers='';
        if(q.type==='single_choice')answers=q.options.map((o,k)=>`<div class="az-answer ${k===q.correctIndex?'correct':''}" data-action="single" data-line="${q.sourceLine}" data-k="${k}"><span class="az-letter">${String.fromCharCode(65+k)}</span><div class="az-answer-text">${safeRich(o)}</div></div>`).join('');
        else if(q.type==='true_false')answers=q.items.map((it,k)=>`<div class="az-answer ${it.is_correct?'correct':''}" data-action="tf" data-line="${q.sourceLine}" data-k="${k}" data-value="${it.is_correct?'1':'0'}"><span class="az-letter">${String.fromCharCode(97+k)}</span><div class="az-answer-text">${safeRich(it.content)} <strong>— ${it.is_correct?'Đúng':'Sai'}</strong></div></div>`).join('');
        else if(q.type==='short_answer')answers=`<div class="small border rounded p-2">Đáp án ngắn: <strong>${safeRich(q.correct_answer)}</strong></div>`;
        else answers='<div class="small text-muted border rounded p-2">Câu tự luận — học sinh nhập bài, giáo viên chấm tay.</div>';
        return `<article class="az-question" id="q-${si}-${qi}" data-source-line="${q.sourceLine}"><div class="az-qbar"><span class="az-qbadge">Câu ${q.number}.</span><span class="az-qactions">Nhập điểm · Audio · Đổi câu khác</span><span class="az-qpoints">${Number(q.points).toFixed(2).replace(/\.00$/,'')} điểm</span></div><div class="az-qtext">${safeRich(q.question)}</div>${answers}${q.explanation?`<div class="az-solution"><div class="az-solution-title">Hướng dẫn giải</div>${safeRich(q.explanation)}</div>`:''}</article>`;
      }).join('')}</section>`;
    }).join('');
    preview.querySelectorAll('[data-action="single"]').forEach(el=>el.onclick=()=>{
      const q=result.questions.find(x=>x.sourceLine===Number(el.dataset.line));if(q)replaceAnswerInEditor(q,String.fromCharCode(65+Number(el.dataset.k)));
    });
    preview.querySelectorAll('[data-action="tf"]').forEach(el=>el.onclick=()=>{
      const q=result.questions.find(x=>x.sourceLine===Number(el.dataset.line));if(q)replaceTfInEditor(q,Number(el.dataset.k),el.dataset.value!=='1');
    });
    buildHidden(result.questions);saveCount.textContent=result.questions.length;
    status.innerHTML=result.errors.length?`<span class="az-error">${result.questions.length} câu · ${result.errors.length} lỗi cần xem</span>`:`Đã nhận diện ${result.questions.length} câu`;
    renderNav(result);
    if(window.MathJax&&window.MathJax.typesetPromise)window.MathJax.typesetPromise([preview]).catch(()=>{});
  }
  function renderNav(result){
    const box=document.getElementById('navContent');
    box.innerHTML=result.sections.map((sec,si)=>`<div class="mb-3"><div class="small fw-bold mb-2">${esc(sec.title)}</div><div class="az-nav-grid">${sec.questions.map((q,qi)=>{
      const bad=result.errors.some(e=>e.line===q.sourceLine);return `<button type="button" class="${bad?'has-error':'ok'}" data-target="q-${si}-${qi}">${q.number}</button>`
    }).join('')}</div></div>`).join('');
    box.querySelectorAll('button[data-target]').forEach(b=>b.onclick=()=>{document.getElementById(b.dataset.target)?.scrollIntoView({behavior:'smooth',block:'start'});navPop.classList.remove('show')});
  }
  function update(immediate){
    const result=parse(editor.value);render(result);updateLines();
    return result;
  }
  function updateLines(){
    const count=editor.value.split('\n').length;lineNumbers.textContent=Array.from({length:count},(_,i)=>i+1).join('\n');
    lineNumbers.scrollTop=editor.scrollTop;
  }
  editor.addEventListener('input',()=>{clearTimeout(debounce);debounce=setTimeout(update,150);updateLines()});
  editor.addEventListener('scroll',()=>{lineNumbers.scrollTop=editor.scrollTop});

  function insertAtCursor(text){const a=editor.selectionStart,b=editor.selectionEnd;editor.setRangeText(text,a,b,'end');editor.focus();update()}
  document.getElementById('insertSection').onclick=()=>{
    const type=prompt('Nhập 1, 2, 3 hoặc 4:\n1 = Trắc nghiệm A-D\n2 = Đúng/Sai\n3 = Trả lời ngắn\n4 = Tự luận','1');
    const templates={
      '1':'\n[PHẦN I: Thí sinh chỉ chọn một phương án.]\nCâu 1. Nội dung câu hỏi\nA. Phương án A\nB. Phương án B\nC. Phương án C\nD. Phương án D\nĐáp án: A\n',
      '2':'\n[PHẦN II: Trong mỗi ý a), b), c), d), chọn Đúng hoặc Sai.]\nCâu 1. Nội dung câu hỏi\na) Ý thứ nhất [Đúng]\nb) Ý thứ hai [Sai]\nc) Ý thứ ba [Sai]\nd) Ý thứ tư [Đúng]\n',
      '3':'\n[PHẦN III: Trả lời ngắn.]\nCâu 1. Nội dung câu hỏi\nĐáp án: 0\n',
      '4':'\n[PHẦN IV: Tự luận.]\nCâu 1. Nội dung câu hỏi\n'
    };if(templates[type])insertAtCursor(templates[type]);
  };
  document.getElementById('insertFormula').onclick=()=>insertAtCursor('$\\frac{a}{b}$');
  document.getElementById('insertImage').onclick=()=>{const u=prompt('Dán link ảnh https://...');if(u)insertAtCursor(`<img src="${u}">`)};
  document.getElementById('uploadAgain').onclick=()=>location.href='/admin/bai-kiem-tra/<%= quiz.id %>/tai-de';
  document.getElementById('formatBtn').onclick=()=>{
    editor.value=editor.value.replace(/\r/g,'').replace(/\n{3,}/g,'\n\n').replace(/^\s+(?=\S)/gm,'').replace(/^(Câu\s*\d+)\s*[:\-]\s*/gim,'$1. ').trim();update();
  };
  document.getElementById('jumpBtn').onclick=()=>navPop.classList.toggle('show');
  document.getElementById('closeNav').onclick=()=>navPop.classList.remove('show');
  document.getElementById('infoBtn').onclick=()=>document.getElementById('infoModal').classList.add('show');
  document.querySelectorAll('[data-close-modal]').forEach(b=>b.onclick=()=>b.closest('.az-modal-mask').classList.remove('show'));

  document.getElementById('pointBtn').onclick=()=>{
    const r=parse(editor.value),rows=document.getElementById('pointRows');
    rows.innerHTML=r.sections.filter(s=>s.questions.length).map((s,i)=>`<div class="az-point-row"><div><strong>${esc(s.title)}</strong><div class="small text-muted">${s.questions.length} câu</div></div><input class="form-control form-control-sm section-point" data-id="${esc(s.id)}" type="number" min="0" step="0.05" value="${sectionPoints[s.id]??defaultPoints(s.type)}"><div class="small text-end section-subtotal">0 điểm</div></div>`).join('');
    function calc(){let total=0;rows.querySelectorAll('.section-point').forEach((inp,i)=>{const sec=r.sections.filter(s=>s.questions.length)[i];const sub=(Number(inp.value)||0)*sec.questions.length;total+=sub;inp.closest('.az-point-row').querySelector('.section-subtotal').textContent=sub.toFixed(2)+' điểm'});document.getElementById('pointTotal').textContent=total.toFixed(2)+' điểm'}
    rows.querySelectorAll('input').forEach(i=>i.oninput=calc);calc();document.getElementById('pointModal').classList.add('show');
  };
  document.getElementById('applyPoints').onclick=()=>{
    document.querySelectorAll('.section-point').forEach(i=>sectionPoints[i.dataset.id]=Number(i.value)||0);
    document.getElementById('pointModal').classList.remove('show');update();
  };
  document.getElementById('validateBtn').onclick=()=>{
    const r=parse(editor.value);alert(r.errors.length?r.errors.map(e=>'Dòng '+e.line+': '+e.msg).join('\n'):'Đề hợp lệ: '+r.questions.length+' câu hỏi.');
  };
  document.getElementById('saveExamForm').addEventListener('submit',e=>{
    const r=parse(editor.value);
    if(!r.questions.length){e.preventDefault();alert('Chưa có câu hỏi hợp lệ để lưu.');return}
    if(r.errors.length&&!confirm('Còn '+r.errors.length+' lỗi nhận diện. Bạn vẫn muốn tiếp tục lưu?'))e.preventDefault();
  });
  update();
})();
</script>

