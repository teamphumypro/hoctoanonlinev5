<% var pageTitle = 'Nhập đề thực chiến kiểu Azota' %>
<%- include('../../partials/admin-header') %>

<%
function htmlToEditor(v) {
  var mathTokens = [];
  var imageTokens = [];
  var value = String(v || '')
    .replace(/<math[\s\S]*?<\/math>/gi, function(m){ var i = mathTokens.push(m) - 1; return '___MATH_' + i + '___'; })
    .replace(/<img\b[^>]*src=["']([^"']+)["'][^>]*>/gi, function(m, src){ var i = imageTokens.push('<img src="' + src + '">') - 1; return '___IMAGE_' + i + '___'; })
    .replace(/<br\s*\/?\s*>/gi, '\n')
    .replace(/<[^>]+>/g, '')
    .replace(/&nbsp;/gi, ' ')
    .replace(/&amp;/gi, '&')
    .replace(/&lt;/gi, '<')
    .replace(/&gt;/gi, '>');
  value = value.replace(/___MATH_(\d+)___/g, function(m, i){ return mathTokens[Number(i)] || ''; });
  value = value.replace(/___IMAGE_(\d+)___/g, function(m, i){ return imageTokens[Number(i)] || ''; });
  return value.trim();
}
function buildEditorText(list) {
  var groups = { single_choice: [], true_false: [], short_answer: [], essay: [] };
  (list || []).forEach(function(q){ (groups[q.type] || groups.single_choice).push(q); });
  var out = [];
  function addTitle(code, title) { out.push('[PHẦN ' + code + ': ' + title + ']'); }
  function addCommon(q, number) {
    out.push('Câu ' + number + '. ' + htmlToEditor(q.question || ''));
  }
  if (groups.single_choice.length) {
    addTitle('I', 'Thí sinh trả lời từ câu 1 đến hết phần. Mỗi câu chỉ chọn một phương án.');
    groups.single_choice.forEach(function(q, i){
      addCommon(q, i + 1);
      ['A','B','C','D'].forEach(function(letter, k){ out.push(letter + '. ' + htmlToEditor((q.options && q.options[k]) || '')); });
      if (Number.isInteger(q.correctIndex) && q.correctIndex >= 0) out.push('Đáp án: ' + ['A','B','C','D'][q.correctIndex]);
      if (q.explanation) out.push('Lời giải: ' + htmlToEditor(q.explanation));
      out.push('');
    });
  }
  if (groups.true_false.length) {
    addTitle('II', 'Trong mỗi ý a), b), c), d), thí sinh chọn Đúng hoặc Sai.');
    groups.true_false.forEach(function(q, i){
      addCommon(q, i + 1);
      ['a','b','c','d'].forEach(function(letter, k){
        var item = q.items && q.items[k] ? q.items[k] : { content:'', is_correct:false };
        out.push(letter + ') ' + htmlToEditor(item.content || '') + ' [' + (item.is_correct ? 'Đúng' : 'Sai') + ']');
      });
      if (q.explanation) out.push('Lời giải: ' + htmlToEditor(q.explanation));
      out.push('');
    });
  }
  if (groups.short_answer.length) {
    addTitle('III', 'Thí sinh trả lời ngắn.');
    groups.short_answer.forEach(function(q, i){
      addCommon(q, i + 1);
      out.push('Đáp án: ' + htmlToEditor(q.correct_answer || ''));
      if (q.explanation) out.push('Lời giải: ' + htmlToEditor(q.explanation));
      out.push('');
    });
  }
  if (groups.essay.length) {
    addTitle('IV', 'Tự luận.');
    groups.essay.forEach(function(q, i){
      addCommon(q, i + 1);
      if (q.explanation) out.push('Lời giải: ' + htmlToEditor(q.explanation));
      out.push('');
    });
  }
  return out.join('\n').trim();
}
var initialEditorText = buildEditorText(questions);
%>

<style>
  body{overflow:hidden}
  .az-shell{height:calc(100vh - 72px);min-height:650px;margin:-16px -12px -20px;background:#f3f5f9;display:flex;flex-direction:column;border-top:1px solid #dde3ee}
