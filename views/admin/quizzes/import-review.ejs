<% var pageTitle = 'Biên tập đề AST V5' %>
<%- include('../../partials/admin-header') %>
<style>
.ast-editor{display:grid;grid-template-columns:minmax(0,1fr) 430px;gap:14px}.ast-main,.ast-side{min-width:0}.ast-side{position:sticky;top:76px;height:calc(100vh - 95px);overflow:auto}.ast-card{background:#fff;border:1px solid #d9e0e8;border-radius:12px;margin-bottom:12px;overflow:hidden}.ast-head{padding:9px 12px;background:#f8fafc;border-bottom:1px solid #e5e7eb;display:flex;justify-content:space-between}.ast-body{padding:12px}.editable{border:1px solid #d6dce5;border-radius:8px;padding:9px;min-height:42px;background:#fff}.ast-paragraph{display:inline}.ast-math-img{display:inline-block;vertical-align:middle;max-height:2.1em;max-width:100%;width:auto!important}.ast-image{display:block;max-width:100%;max-height:430px;margin:8px auto}.ast-table{border-collapse:collapse;max-width:100%}.ast-table td{border:1px solid #ddd;padding:5px}.option-row{display:flex;align-items:flex-start;gap:8px;margin:7px 0}.option-row .editable{flex:1}.rubric-list{display:grid;gap:6px}.rubric-row{display:grid;grid-template-columns:1fr 90px 34px;gap:6px}.source-json{width:100%;min-height:330px;font:12px/1.45 Consolas,monospace;border:1px solid #d9e0e8;border-radius:8px;padding:10px;color:#344054;background:#f8fafc}.badge-ast{background:#e8f1ff;color:#175cd3}.side-box{background:#fff;border:1px solid #d9e0e8;border-radius:12px;padding:12px;margin-bottom:12px}@media(max-width:1050px){.ast-editor{display:block}.ast-side{position:static;height:auto}}
</style>
<div class="d-flex justify-content-between align-items-center mb-3"><div><h5 class="mb-0">Import Engine AST V5</h5><small class="text-muted">DOCX được đọc thành Text / Math / Image / Table nodes; không render bằng placeholder.</small></div><a class="btn btn-outline-secondary btn-sm" href="<%= quiz.lesson_id ? '/admin/bai-hoc/'+quiz.lesson_id+'/bai-kiem-tra' : '/admin/bai-kiem-tra/'+quiz.id+'/cau-hoi' %>">Hủy</a></div>
<form id="examForm" method="POST" action="/admin/bai-kiem-tra/luu-de-import">
<input type="hidden" name="quiz_id" value="<%= quiz.id %>"><input type="hidden" name="redirect_to" value="<%= quiz.lesson_id ? '/admin/bai-hoc/'+quiz.lesson_id+'/bai-kiem-tra' : '/admin/bai-kiem-tra/'+quiz.id+'/cau-hoi' %>">
<div class="ast-editor"><main class="ast-main">
<% questions.forEach((q,i)=>{ %>
<article class="ast-card question-row" data-index="<%= i %>"><div class="ast-head"><strong>Câu <%= q.number || i+1 %> <span class="badge badge-ast">AST</span></strong><label class="small"><input type="checkbox" name="questions[<%= i %>][include]" checked> Giữ</label></div><div class="ast-body">
<div class="row g-2 mb-2"><div class="col-md-8"><select class="form-select form-select-sm q-type" name="questions[<%= i %>][type]"><option value="single_choice" <%= q.type==='single_choice'||q.type==='multiple_choice'?'selected':'' %>>Trắc nghiệm</option><option value="true_false" <%= q.type==='true_false'?'selected':'' %>>Đúng/Sai</option><option value="short_answer" <%= q.type==='short_answer'?'selected':'' %>>Trả lời ngắn</option><option value="essay" <%= q.type==='essay'?'selected':'' %>>Tự luận</option></select></div><div class="col-md-4"><input type="number" step="0.05" class="form-control form-control-sm" name="questions[<%= i %>][points]" value="<%= q.points || 0.25 %>"></div></div>
<div class="editable q-question" contenteditable="true"><%- q.questionHtml %></div><textarea hidden name="questions[<%= i %>][question]" class="q-question-value"></textarea><textarea hidden name="questions[<%= i %>][ast_json]" class="q-ast"><%= q.astJson %></textarea>
<div class="choice-fields mt-2"><% (q.optionHtml||[]).forEach((html,k)=>{ %><div class="option-row"><input type="radio" name="questions[<%= i %>][correct_index]" value="<%= k %>" <%= q.correctIndex===k?'checked':'' %>><strong><%= q.labels[k]||String.fromCharCode(65+k) %>.</strong><div class="editable q-option" contenteditable="true"><%- html %></div><input type="hidden" name="questions[<%= i %>][options][]" class="q-option-value"></div><% }) %></div>
<div class="tf-fields mt-2"><% (q.optionHtml||[]).forEach((html,k)=>{ %><div class="option-row"><strong><%= String.fromCharCode(97+k) %>)</strong><div class="editable q-tf" contenteditable="true"><%- html %></div><input type="hidden" name="questions[<%= i %>][tf_content][]" class="q-tf-value"><label class="small"><input type="checkbox" name="questions[<%= i %>][tf_correct][]" value="<%= k %>" <%= q.items[k]&&q.items[k].is_correct?'checked':'' %>> Đúng</label></div><% }) %></div>
<div class="short-fields mt-2"><input class="form-control form-control-sm" name="questions[<%= i %>][correct_answer]" value="<%= q.correct_answer||'' %>" placeholder="Đáp án"></div>
<div class="mt-3"><div class="small fw-bold text-warning-emphasis mb-1">HƯỚNG DẪN GIẢI</div><div class="editable q-solution" contenteditable="true"><%- q.solutionHtml %></div><textarea hidden name="questions[<%= i %>][explanation]" class="q-solution-value"></textarea></div>
<div class="essay-fields mt-3"><div class="d-flex justify-content-between align-items-center"><strong class="small">Thang điểm tự luận (rubric)</strong><button class="btn btn-sm btn-outline-primary add-rubric" type="button">+ Thêm ý</button></div><div class="rubric-list mt-2"></div><input type="hidden" name="questions[<%= i %>][rubric_json]" class="rubric-json"></div>
</div></article>
<% }) %>
<button class="btn btn-primary mb-4">Lưu <%= questions.length %> câu hỏi</button></main>
<aside class="ast-side"><div class="side-box"><strong>Tài liệu AST</strong><div class="small text-muted mt-1">Phiên bản <%= document.version %> · <%= Object.keys(document.assets.math||{}).length %> công thức · <%= Object.keys(document.assets.image||{}).length %> hình</div></div><div class="side-box"><strong>Đi đến câu</strong><div class="input-group mt-2"><input id="goNumber" class="form-control" type="number" min="1"><button id="goQuestion" class="btn btn-outline-secondary" type="button">Đi</button></div></div><div class="side-box"><strong>AST nguồn (chỉ đọc)</strong><textarea class="source-json" readonly><%= JSON.stringify({version:document.version,kind:document.kind,source:document.source,blocks:document.blocks},null,2) %></textarea></div></aside></div></form>
<script>
function updateType(row){const t=row.querySelector('.q-type').value;row.querySelector('.choice-fields').style.display=t==='single_choice'?'':'none';row.querySelector('.tf-fields').style.display=t==='true_false'?'':'none';row.querySelector('.short-fields').style.display=t==='short_answer'?'':'none';row.querySelector('.essay-fields').style.display=t==='essay'?'':'none'}
function addRubric(row,title='',score=''){const list=row.querySelector('.rubric-list'),d=document.createElement('div');d.className='rubric-row';d.innerHTML='<input class="form-control form-control-sm rubric-title" placeholder="Ví dụ: Xác định điều kiện"><input class="form-control form-control-sm rubric-score" type="number" step="0.05" min="0" placeholder="Điểm"><button type="button" class="btn btn-sm btn-outline-danger">×</button>';d.querySelector('.rubric-title').value=title;d.querySelector('.rubric-score').value=score;d.querySelector('button').onclick=()=>d.remove();list.appendChild(d)}
document.querySelectorAll('.question-row').forEach(row=>{row.querySelector('.q-type').addEventListener('change',()=>updateType(row));updateType(row);row.querySelector('.add-rubric').onclick=()=>addRubric(row);if(row.querySelector('.q-type').value==='essay'){addRubric(row,'Phương pháp và lập luận đúng','');addRubric(row,'Tính toán và kết luận','')}});
document.getElementById('goQuestion').onclick=()=>{const i=Number(document.getElementById('goNumber').value)-1;document.querySelector('.question-row[data-index="'+i+'"]')?.scrollIntoView({behavior:'smooth'})};
document.getElementById('examForm').addEventListener('submit',()=>document.querySelectorAll('.question-row').forEach(row=>{row.querySelector('.q-question-value').value=row.querySelector('.q-question').innerHTML;row.querySelector('.q-solution-value').value=row.querySelector('.q-solution').innerHTML;row.querySelectorAll('.q-option-value').forEach((x,i)=>x.value=row.querySelectorAll('.q-option')[i].innerHTML);row.querySelectorAll('.q-tf-value').forEach((x,i)=>x.value=row.querySelectorAll('.q-tf')[i].innerHTML);const rubric=[...row.querySelectorAll('.rubric-row')].map((x,i)=>({id:'r'+(i+1),title:x.querySelector('.rubric-title').value.trim(),score:Number(x.querySelector('.rubric-score').value||0)})).filter(x=>x.title);row.querySelector('.rubric-json').value=JSON.stringify(rubric)}));
</script>
<%- include('../../partials/admin-footer') %>
