<% var pageTitle = 'Biên tập đề kiểu Azota' %>
<%- include('../../partials/admin-header') %>
<style>
  .az-editor{display:grid;grid-template-columns:minmax(0,1fr) minmax(420px,48%);gap:12px;height:calc(100vh - 130px)}
  .az-visual,.az-source{overflow:auto;border:1px solid #dbe2ea;background:#f5f7fb;border-radius:10px}
  .az-source{background:#fff;position:relative}.az-toolbar{position:sticky;top:0;z-index:4;background:#fff;border-bottom:1px solid #ddd;padding:8px;display:flex;gap:8px;align-items:center}
  .az-source textarea{border:0;resize:none;width:100%;min-height:calc(100% - 52px);padding:12px 12px 60px 54px;font-family:Consolas,monospace;font-size:13px;line-height:1.55;color:#b42318;background:linear-gradient(to right,#f7f7f7 0,#f7f7f7 44px,#ddd 45px,#fff 46px)}
  .az-card{background:#fff;border:1px solid #cfd8e3;border-radius:8px;margin:10px;overflow:hidden}.az-card-head{display:flex;justify-content:space-between;align-items:center;padding:8px 12px;border-bottom:1px solid #e5e7eb}.az-card-body{padding:12px}
  .exam-math{display:inline-block;vertical-align:middle}.exam-math-img{display:inline-block;vertical-align:middle;max-height:2.2em;width:auto}.exam-content-img{display:block;max-width:100%;max-height:420px;margin:8px auto}.exam-missing-asset{color:#b42318;background:#fff2f0;padding:1px 4px;border-radius:4px}
  .editable{border:1px solid #d9dee6;border-radius:5px;padding:8px;min-height:40px}.option-edit{display:flex;gap:7px;align-items:flex-start;margin:6px 0}.option-edit .editable{flex:1;min-height:34px;padding:5px 8px}
  .solution-box{border-top:1px solid #ead7a5;margin-top:12px;padding-top:10px}.source-status{font-size:12px;color:#667085;margin-left:auto}
  @media(max-width:980px){.az-editor{display:block;height:auto}.az-visual,.az-source{height:70vh;margin-bottom:10px}}
</style>

<div class="d-flex justify-content-between align-items-center mb-2">
  <div><h5 class="mb-0">Biên tập đề theo mô hình Azota</h5><small class="text-muted">Tài nguyên công thức/hình được lưu riêng; bên phải giữ mã tham chiếu, bên trái hiển thị nội dung thật.</small></div>
  <a href="<%= quiz.lesson_id ? '/admin/bai-hoc/'+quiz.lesson_id+'/bai-kiem-tra' : '/admin/bai-kiem-tra/'+quiz.id+'/cau-hoi' %>" class="btn btn-outline-secondary btn-sm">Hủy</a>
</div>

<form id="examForm" method="POST" action="/admin/bai-kiem-tra/luu-de-import">
<input type="hidden" name="redirect_to" value="<%= quiz.lesson_id ? '/admin/bai-hoc/'+quiz.lesson_id+'/bai-kiem-tra' : '/admin/bai-kiem-tra/'+quiz.id+'/cau-hoi' %>">
<input type="hidden" name="quiz_id" value="<%= quiz.id %>">
<div class="az-editor">
  <section class="az-visual" id="visualPane">
    <% document.sections.forEach(sec => { %>
      <div class="m-2 p-2 bg-white border rounded"><strong><%= sec.title || ('PHẦN '+sec.number) %></strong><div class="small"><%= sec.instruction %></div></div>
      <% questions.filter(q => q.sectionNumber === sec.number).forEach((q) => { var i = questions.indexOf(q); %>
      <article class="az-card question-row" data-index="<%= i %>">
        <div class="az-card-head"><strong>Câu <%= q.number %></strong><div><% if(q.needsReview){ %><span class="badge bg-warning text-dark">Cần kiểm tra</span><% } %> <label class="small"><input type="checkbox" name="questions[<%= i %>][include]" checked> Giữ</label></div></div>
        <div class="az-card-body">
          <div class="row g-2 mb-2"><div class="col-8"><select name="questions[<%= i %>][type]" class="form-select form-select-sm q-type">
            <option value="single_choice" <%= q.type==='single_choice'||q.type==='multiple_choice'?'selected':'' %>>Trắc nghiệm</option><option value="true_false" <%= q.type==='true_false'?'selected':'' %>>Đúng/Sai</option><option value="short_answer" <%= q.type==='short_answer'?'selected':'' %>>Trả lời ngắn</option><option value="essay" <%= q.type==='essay'?'selected':'' %>>Tự luận</option>
          </select></div><div class="col-4"><input type="number" step="0.05" class="form-control form-control-sm" name="questions[<%= i %>][points]" value="<%= q.points %>"></div></div>
          <div class="editable q-question-edit" contenteditable="true"><%- q.question %></div>
          <textarea hidden class="q-question-raw" name="questions[<%= i %>][question]"><%= q.rawQuestion %></textarea>

          <div class="choice-fields" style="<%= q.type==='single_choice'||q.type==='multiple_choice'?'':'display:none' %>">
            <% q.rawOptions.forEach((opt,k)=>{ %><div class="option-edit"><input type="radio" name="questions[<%= i %>][correct_index]" value="<%= k %>" <%= q.correctIndex===k?'checked':'' %>><b><%= q.labels[k]||String.fromCharCode(65+k) %>.</b><div class="editable q-option-edit" contenteditable="true"><%- q.options[k] %></div><input type="hidden" class="q-option-raw" name="questions[<%= i %>][options][]" value="<%= opt %>"></div><% }) %>
          </div>
          <div class="tf-fields" style="<%= q.type==='true_false'?'':'display:none' %>">
            <% q.rawOptions.forEach((opt,k)=>{ %><div class="option-edit"><b><%= q.labels[k]||String.fromCharCode(97+k) %>)</b><div class="editable q-tf-edit" contenteditable="true"><%- q.options[k] %></div><input type="hidden" class="q-tf-raw" name="questions[<%= i %>][tf_content][]" value="<%= opt %>"><label><input type="checkbox" name="questions[<%= i %>][tf_correct][]" value="<%= k %>" <%= q.items[k]&&q.items[k].is_correct?'checked':'' %>> Đúng</label></div><% }) %>
          </div>
          <div class="short-fields" style="<%= q.type==='short_answer'?'':'display:none' %>"><input class="form-control form-control-sm" name="questions[<%= i %>][correct_answer]" value="<%= q.correct_answer %>" placeholder="Đáp án"></div>
          <div class="solution-box"><small class="text-warning-emphasis fw-bold">HƯỚNG DẪN GIẢI</small><div class="editable q-solution-edit mt-1" contenteditable="true"><%- q.explanation || '' %></div><textarea hidden class="q-solution-raw" name="questions[<%= i %>][explanation]"><%= q.rawSolution || '' %></textarea></div>
        </div>
      </article>
      <% }) %>
    <% }) %>
  </section>
  <aside class="az-source">
    <div class="az-toolbar"><button type="button" class="btn btn-sm btn-outline-primary" id="applySource">Áp dụng nội dung</button><button type="button" class="btn btn-sm btn-outline-secondary" id="goQuestion">Đi đến câu</button><input id="goNumber" type="number" min="1" class="form-control form-control-sm" style="width:72px"><span class="source-status" id="sourceStatus">Có <%= Object.keys(document.assets.maths).length %> công thức, <%= Object.keys(document.assets.images).length %> hình</span></div>
    <textarea id="sourceEditor" spellcheck="false"><%= document.rawText %></textarea>
  </aside>
</div>
<div class="mt-2"><button class="btn btn-primary">Lưu các câu đã chọn</button></div>
</form>

<script type="application/json" id="assetData"><%- JSON.stringify(document.assets).replace(/</g,'\\u003c') %></script>
<script>
const assets=JSON.parse(document.getElementById('assetData').textContent);
function esc(s){return String(s||'').replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;')}
function renderRefs(raw){let s=esc(raw).replace(/\n/g,'<br>');s=s.replace(/\[!m:\$([^$\]]+)\$\]/g,(_,id)=>{const a=assets.maths[id];if(!a)return '<span class="exam-missing-asset">[⚠ công thức]</span>';if(a.mathml)return '<span class="exam-math">'+a.mathml+'</span>';return '<img class="exam-math-img" src="'+a.dataUrl+'">'});s=s.replace(/\[img:\$([^$\]]+)\$\]/g,(_,id)=>{const a=assets.images[id];return a?'<img class="exam-content-img" src="'+a.dataUrl+'">':'<span class="exam-missing-asset">[⚠ hình]</span>'});return s}
function bindType(row){const sel=row.querySelector('.q-type');function update(){row.querySelector('.choice-fields').style.display=sel.value==='single_choice'?'':'none';row.querySelector('.tf-fields').style.display=sel.value==='true_false'?'':'none';row.querySelector('.short-fields').style.display=sel.value==='short_answer'?'':'none'}sel.addEventListener('change',update);update()}
document.querySelectorAll('.question-row').forEach(bindType);
document.getElementById('goQuestion').addEventListener('click',()=>{const n=document.getElementById('goNumber').value;const card=[...document.querySelectorAll('.az-card')].find(x=>x.querySelector('.az-card-head strong').textContent.trim()==='Câu '+n);if(card)card.scrollIntoView({behavior:'smooth',block:'start'})});
// Parser nhẹ phía trình duyệt để sửa nguồn bên phải rồi cập nhật câu/phương án bên trái.
document.getElementById('applySource').addEventListener('click',()=>{const src=document.getElementById('sourceEditor').value;const parts=src.split(/\n(?=(?:Câu|Bài|Question)\s*\d+\s*[.:)])/i);let changed=0;for(const part of parts){const m=part.match(/^(?:Câu|Bài|Question)\s*(\d+)\s*[.:)]\s*([\s\S]*)/i);if(!m)continue;const n=Number(m[1]);const card=[...document.querySelectorAll('.az-card')].find(x=>x.querySelector('.az-card-head strong').textContent.trim()==='Câu '+n);if(!card)continue;const body=m[2];const marks=[...body.matchAll(/(?:^|\n|\t| {2,})([A-H])\s*[.)]\s*/g)];let stem=body,opts=[];if(marks.length>=2){stem=body.slice(0,marks[0].index).trim();opts=marks.map((x,i)=>body.slice(x.index+x[0].length,marks[i+1]?marks[i+1].index:body.length).trim())}card.querySelector('.q-question-raw').value=stem;card.querySelector('.q-question-edit').innerHTML=renderRefs(stem);card.querySelectorAll('.q-option-raw').forEach((el,i)=>{if(opts[i]!=null){el.value=opts[i];card.querySelectorAll('.q-option-edit')[i].innerHTML=renderRefs(opts[i])}});changed++}document.getElementById('sourceStatus').textContent='Đã cập nhật '+changed+' câu';});
// Trước khi submit: chuyển phần hiển thị đã sửa thành HTML lưu vào DB; raw placeholder vẫn nằm ở editor nguồn.
document.getElementById('examForm').addEventListener('submit',()=>{document.querySelectorAll('.question-row').forEach(row=>{const q=row.querySelector('.q-question-raw');q.value=row.querySelector('.q-question-edit').innerHTML;row.querySelectorAll('.q-option-raw').forEach((el,i)=>el.value=row.querySelectorAll('.q-option-edit')[i].innerHTML);row.querySelectorAll('.q-tf-raw').forEach((el,i)=>el.value=row.querySelectorAll('.q-tf-edit')[i].innerHTML);row.querySelector('.q-solution-raw').value=row.querySelector('.q-solution-edit').innerHTML})});
</script>
<%- include('../../partials/admin-footer') %>
