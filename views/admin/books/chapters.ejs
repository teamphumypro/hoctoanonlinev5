<% var pageTitle = 'Chương đọc online: ' + book.title %>
<%- include('../../partials/admin-header') %>
<div class="mb-3 d-flex justify-content-between">
  <a href="/admin/sach" class="btn btn-outline-secondary btn-sm">← Quay lại danh sách Sách</a>
  <a href="/admin/sach/<%= book.id %>/chuong/nhap-tu-file" class="btn btn-outline-success btn-sm">📄 Nhập nội dung từ file/link</a>
</div>
<div class="alert alert-secondary small">Thêm chương để cho phép đọc cuốn sách này trực tiếp trên web (kiểu lật trang), song song với việc tải file (nếu có).</div>

<div class="card p-3 mb-3">
  <h6 class="fw-bold mb-2">Thêm chương mới</h6>
  <form method="POST" action="/admin/sach-chuong">
    <input type="hidden" name="book_id" value="<%= book.id %>">
    <div class="mb-2"><input name="title" class="form-control" placeholder="Tên chương (vd: Chương 1)" required></div>
    <div class="mb-2"><textarea name="content" class="form-control" rows="6" placeholder="Nội dung chương..."></textarea></div>
    <% if (book.price > 0) { %>
      <div class="form-check mb-2">
        <input type="checkbox" name="is_free" class="form-check-input" id="isFreeNew">
        <label class="form-check-label" for="isFreeNew">Cho đọc thử miễn phí (dù sách đang tính phí)</label>
      </div>
    <% } %>
    <button class="btn btn-primary btn-sm">Thêm chương</button>
  </form>
</div>

<div class="card p-3">
  <h6 class="fw-bold mb-2">Danh sách chương (<%= chapters.length %>)</h6>
  <ul class="list-group" id="chapterList">
    <% chapters.forEach((c, i) => { %>
      <li class="list-group-item d-flex justify-content-between align-items-center" data-id="<%= c.id %>">
        <span><i class="fa-solid fa-grip-vertical drag-handle me-2"></i>Chương <%= i+1 %>: <%= c.title %>
          <% if (c.is_free) { %><span class="badge bg-success ms-1">Đọc thử</span><% } %>
        </span>
        <span>
          <a href="/admin/sach-chuong/<%= c.id %>/sua" class="btn btn-sm btn-outline-secondary">Sửa</a>
          <form method="POST" action="/admin/sach-chuong/<%= c.id %>/xoa" class="d-inline" onsubmit="return confirm('Xóa chương này?')">
            <input type="hidden" name="book_id" value="<%= book.id %>">
            <button class="btn btn-sm btn-outline-danger">Xóa</button>
          </form>
        </span>
      </li>
    <% }) %>
    <% if (chapters.length === 0) { %><li class="list-group-item text-muted">Chưa có chương nào — sách này chỉ dùng để tải file (nếu có link file).</li><% } %>
  </ul>
</div>

<script src="https://cdnjs.cloudflare.com/ajax/libs/Sortable/1.15.2/Sortable.min.js"></script>
<script>
new Sortable(document.getElementById('chapterList'), {
  handle: '.drag-handle', animation: 150,
  onEnd: () => {
    const ids = [...document.querySelectorAll('#chapterList > li')].map(el => el.dataset.id).filter(Boolean);
    fetch('/admin/sach-chuong/sap-xep', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ ids }) });
  }
});
</script>
<%- include('../../partials/admin-footer') %>
