<% var pageTitle = book ? 'Sửa sách' : 'Thêm sách' %>
<%- include('../../partials/admin-header') %>

<div style="max-width:700px">
  <form method="POST" action="<%= book ? '/admin/sach/' + book.id : '/admin/sach' %>" enctype="multipart/form-data">

    <div class="card p-4 mb-3">
      <h6 class="fw-bold mb-3">1. Thông tin cơ bản</h6>
      <div class="mb-3"><label class="form-label">Tên sách</label>
        <input name="title" class="form-control" value="<%= book ? book.title : '' %>" required></div>
      <div class="mb-3"><label class="form-label">Tác giả</label>
        <input name="author" class="form-control" value="<%= book ? book.author : '' %>"></div>
      <div class="mb-3"><label class="form-label">Mô tả ngắn</label>
        <input name="short_desc" class="form-control" value="<%= book ? book.short_desc : '' %>"></div>
      <div class="mb-0"><label class="form-label">Mô tả chi tiết</label>
        <div id="descEditor" style="height:200px; background:#fff"></div>
        <input type="hidden" name="description" id="descHidden" value="<%= book ? book.description : '' %>"></div>
    </div>

    <div class="card p-4 mb-3">
      <h6 class="fw-bold mb-3">2. Phân loại <span class="fw-normal text-muted small">(để lọc/hiển thị trên trang Sách)</span></h6>
      <div class="row">
        <div class="col-md-6 mb-3"><label class="form-label">Danh mục sách <span class="text-muted fw-normal">(tùy chọn)</span></label>
          <select name="category_id" class="form-select">
            <option value="">-- Không thuộc danh mục cụ thể --</option>
            <% function renderCatOptions(cats, depth) { %>
              <% cats.forEach(c => { %>
                <option value="<%= c.id %>" <%= book && book.category_id === c.id ? 'selected' : '' %>>
                  <%= '\u00A0\u00A0\u00A0\u00A0'.repeat(depth) %><%= depth > 0 ? '↳ ' : '' %><%= c.name %>
                </option>
                <% if (c.children && c.children.length) renderCatOptions(c.children, depth + 1) %>
              <% }) %>
            <% } %>
            <% renderCatOptions(categories, 0) %>
          </select>
          <div class="form-text">Chỉ cần chọn nếu sách gắn với 1 danh mục cụ thể. Chưa có danh mục phù hợp? Vào menu <strong>"Danh mục sách"</strong> bên trái để thêm trước. Sách chung chung có thể bỏ trống.</div>
        </div>
        <div class="col-md-6 mb-0"><label class="form-label">Thể loại sách <span class="text-muted fw-normal">(tùy chọn)</span></label>
          <select name="book_type_id" class="form-select">
            <option value="">-- Không chọn --</option>
            <% bookTypes.forEach(t => { %>
              <option value="<%= t.id %>" <%= book && book.book_type_id === t.id ? 'selected' : '' %>><%= t.name %></option>
            <% }) %>
          </select>
          <div class="form-text">Chưa có thể loại phù hợp? Vào menu <strong>"Thể loại sách"</strong> bên trái để thêm trước.</div>
        </div>
      </div>
    </div>

    <div class="card p-4 mb-3">
      <h6 class="fw-bold mb-3">3. Giá bán</h6>
      <div class="row">
        <div class="col-md-6 mb-0"><label class="form-label">Giá bán (VNĐ)</label>
          <input type="number" name="price" class="form-control" value="<%= book ? book.price : 0 %>"></div>
        <div class="col-md-6 mb-0"><label class="form-label">Giá gốc (tùy chọn, hiện gạch ngang)</label>
          <input type="number" name="compare_at_price" class="form-control" value="<%= book && book.compare_at_price ? book.compare_at_price : '' %>"></div>
      </div>
    </div>

    <div class="card p-4 mb-3">
      <h6 class="fw-bold mb-3">4. Ảnh bìa</h6>
      <% if (book && book.cover_url) { %><div class="mb-2"><img src="<%= book.cover_url %>" style="height:80px;border-radius:6px"></div><% } %>
      <div class="btn-group btn-group-sm mb-2" role="group">
        <input type="radio" class="btn-check" name="cover_mode" id="coverModeUpload" checked>
        <label class="btn btn-outline-secondary" for="coverModeUpload">Tải ảnh lên</label>
        <input type="radio" class="btn-check" name="cover_mode" id="coverModeLink">
        <label class="btn btn-outline-secondary" for="coverModeLink">Dán link ảnh</label>
      </div>
      <div id="coverUploadField">
        <input type="file" name="cover" class="form-control" accept="image/*">
      </div>
      <div id="coverLinkField" class="d-none">
        <input type="url" name="cover_url_link" class="form-control" placeholder="https://...">
      </div>
    </div>

    <div class="card p-4 mb-3">
      <h6 class="fw-bold mb-3">5. File & liên kết</h6>
      <div class="mb-3">
        <label class="form-label">Link file ebook đầy đủ <span class="text-muted fw-normal">(gửi cho khách sau khi mua)</span></label>
        <input type="url" name="file_url" class="form-control" value="<%= book ? book.file_url : '' %>" placeholder="https://drive.google.com/...">
      </div>
      <div class="mb-0">
        <label class="form-label">Link PDF đọc thử <span class="text-muted fw-normal">(tùy chọn — khách xem trước ngay trên web, không cần mua)</span></label>
        <input type="url" name="preview_url" class="form-control" value="<%= book && book.preview_url ? book.preview_url : '' %>" placeholder="https://drive.google.com/...">
        <div class="form-text">Google Drive: bấm Chia sẻ → "Bất kỳ ai có đường liên kết" → dán vào đây.</div>
      </div>
    </div>

    <div class="card p-4 mb-3">
      <div class="form-check mb-0">
        <input type="checkbox" name="is_published" class="form-check-input" id="isPublished" <%= (!book || book.is_published) ? 'checked' : '' %>>
        <label class="form-check-label" for="isPublished">Hiển thị công khai trên trang web</label>
      </div>
    </div>

    <button class="btn btn-primary">Lưu</button>
    <a href="/admin/sach" class="btn btn-outline-secondary">Hủy</a>
  </form>
</div>

<script>
  const coverUploadField = document.getElementById('coverUploadField');
  const coverLinkField = document.getElementById('coverLinkField');
  document.getElementById('coverModeUpload').addEventListener('change', () => {
    coverUploadField.classList.remove('d-none'); coverLinkField.classList.add('d-none');
  });
  document.getElementById('coverModeLink').addEventListener('change', () => {
    coverLinkField.classList.remove('d-none'); coverUploadField.classList.add('d-none');
  });
  <% if (book && book.cover_url && book.cover_url.startsWith('http')) { %>
    document.getElementById('coverModeLink').checked = true;
    coverLinkField.classList.remove('d-none'); coverUploadField.classList.add('d-none');
  <% } %>
</script>

<link href="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.snow.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.min.js"></script>
<script>
  const descQuill = new Quill('#descEditor', {
    theme: 'snow',
    modules: { toolbar: [['bold','italic','underline'],[{list:'ordered'},{list:'bullet'}],['link'],[{header:[2,3,false]}],['clean']] }
  });
  descQuill.root.innerHTML = document.getElementById('descHidden').value;
  document.querySelector('form').addEventListener('submit', () => {
    document.getElementById('descHidden').value = descQuill.root.innerHTML;
  });
</script>

<%- include('../../partials/admin-footer') %>
