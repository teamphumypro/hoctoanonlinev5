<% var pageTitle = 'Thể loại sách' %>
<%- include('../../partials/admin-header') %>
<div class="mb-3"><a href="/admin/sach" class="btn btn-outline-secondary btn-sm">← Quay lại danh sách Sách</a></div>

<div class="card p-3 mb-3">
  <form method="POST" action="/admin/sach/loai" class="row g-2 align-items-end">
    <div class="col-md-8"><label class="form-label">Tên thể loại</label><input name="name" class="form-control" placeholder="Vd: Sách văn học, Sách tham khảo, Sách kỹ năng..." required></div>
    <div class="col-md-4"><button class="btn btn-primary w-100">Thêm</button></div>
  </form>
</div>

<div class="card p-3">
  <ul class="list-group">
    <% bookTypes.forEach(t => { %>
      <li class="list-group-item d-flex justify-content-between align-items-center">
        <%= t.name %>
        <form method="POST" action="/admin/sach/loai/<%= t.id %>/xoa" onsubmit="return confirm('Xóa thể loại này?')">
          <button class="btn btn-sm btn-outline-danger">Xóa</button>
        </form>
      </li>
    <% }) %>
    <% if (bookTypes.length === 0) { %><li class="list-group-item text-muted">Chưa có thể loại nào.</li><% } %>
  </ul>
</div>

<%- include('../../partials/admin-footer') %>
