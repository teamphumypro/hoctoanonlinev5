<% var pageTitle = 'Sửa chương' %>
<%- include('../../partials/admin-header') %>
<div class="mb-3"><a href="/admin/sach/<%= book.id %>/chuong" class="btn btn-outline-secondary btn-sm">← Quay lại danh sách chương</a></div>
<div class="card p-4" style="max-width:800px">
  <form method="POST" action="/admin/sach-chuong/<%= chapter.id %>">
    <input type="hidden" name="book_id" value="<%= book.id %>">
    <div class="mb-3"><label class="form-label">Tên chương</label>
      <input name="title" class="form-control" value="<%= chapter.title %>" required></div>
    <div class="mb-3"><label class="form-label">Nội dung</label>
      <textarea name="content" class="form-control" rows="14"><%= chapter.content %></textarea></div>
    <% if (book.price > 0) { %>
      <div class="form-check mb-3">
        <input type="checkbox" name="is_free" class="form-check-input" id="isFree" <%= chapter.is_free ? 'checked' : '' %>>
        <label class="form-check-label" for="isFree">Cho đọc thử miễn phí</label>
      </div>
    <% } %>
    <button class="btn btn-primary">Lưu</button>
  </form>
</div>
<%- include('../../partials/admin-footer') %>
