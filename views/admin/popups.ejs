<% var pageTitle = 'Popup quảng cáo' %>
<%- include('../partials/admin-header') %>

<div class="alert alert-secondary small">
  Popup sẽ tự hiện ra 1 lần khi khách vào trang chủ (không hiện lại liên tục trong cùng phiên truy cập). Chỉ popup đang "Bật" gần nhất được hiển thị.
</div>

<div class="card p-3 mb-3">
  <form method="POST" action="/admin/popup" enctype="multipart/form-data" class="row g-2 align-items-end">
    <div class="col-md-3"><label class="form-label">Tải ảnh lên</label><input type="file" name="image" class="form-control" accept="image/*"></div>
    <div class="col-md-3"><label class="form-label">... hoặc dán link ảnh</label><input type="url" name="image_url_link" class="form-control" placeholder="https://..."></div>
    <div class="col-md-2"><label class="form-label">Tiêu đề</label><input name="title" class="form-control"></div>
    <div class="col-md-2"><label class="form-label">Link khi click</label><input name="link_url" class="form-control" placeholder="/khoa-hoc/..."></div>
    <div class="col-md-2"><button class="btn btn-primary w-100">Thêm</button></div>
  </form>
</div>

<div class="row g-3">
  <% popups.forEach(p => { %>
    <div class="col-md-3">
      <div class="card p-2">
        <img src="<%= p.image_url %>" class="w-100 mb-2" style="height:140px;object-fit:contain;border-radius:6px;background:#f0f0f7">
        <div class="small fw-semibold"><%= p.title %></div>
        <div class="d-flex justify-content-between mt-2">
          <form method="POST" action="/admin/popup/<%= p.id %>/bat-tat">
            <button class="btn btn-sm btn-outline-<%= p.is_active ? 'success' : 'secondary' %>"><%= p.is_active ? 'Đang bật' : 'Đang tắt' %></button>
          </form>
          <form method="POST" action="/admin/popup/<%= p.id %>/xoa" onsubmit="return confirm('Xóa popup?')">
            <button class="btn btn-sm btn-outline-danger">Xóa</button>
          </form>
        </div>
      </div>
    </div>
  <% }) %>
  <% if (popups.length === 0) { %><p class="text-muted">Chưa có popup nào.</p><% } %>
</div>

<%- include('../partials/admin-footer') %>
