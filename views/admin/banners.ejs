<% var pageTitle = 'Banner' %>
<%- include('../partials/admin-header') %>
<div class="card p-3 mb-3">
  <form method="POST" action="/admin/banner" enctype="multipart/form-data" class="row g-2 align-items-end">
    <div class="col-md-3"><label class="form-label">Tải ảnh lên</label><input type="file" name="image" class="form-control" accept="image/*"></div>
    <div class="col-md-3"><label class="form-label">... hoặc dán link ảnh</label><input type="url" name="image_url_link" class="form-control" placeholder="https://..."></div>
    <div class="col-md-2"><label class="form-label">Tiêu đề</label><input name="title" class="form-control"></div>
    <div class="col-md-2"><label class="form-label">Link khi click</label><input name="link_url" class="form-control" placeholder="/khoa-hoc/..."></div>
    <div class="col-md-2"><button class="btn btn-primary w-100">Thêm</button></div>
  </form>
</div>
<div class="row g-3">
  <% banners.forEach(b => { %>
    <div class="col-md-3">
      <div class="card p-2">
        <img src="<%= b.image_url %>" class="w-100 mb-2" style="height:100px;object-fit:cover;border-radius:6px">
        <div class="d-flex justify-content-between">
          <form method="POST" action="/admin/banner/<%= b.id %>/bat-tat">
            <button class="btn btn-sm btn-outline-<%= b.is_active ? 'success' : 'secondary' %>"><%= b.is_active ? 'Đang hiện' : 'Đang ẩn' %></button>
          </form>
          <form method="POST" action="/admin/banner/<%= b.id %>/xoa" onsubmit="return confirm('Xóa banner?')">
            <button class="btn btn-sm btn-outline-danger">Xóa</button>
          </form>
        </div>
      </div>
    </div>
  <% }) %>
</div>
<%- include('../partials/admin-footer') %>
