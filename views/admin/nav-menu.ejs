<% var pageTitle = 'Menu điều hướng' %>
<%- include('../partials/admin-header') %>

<div class="alert alert-secondary small">
  Đây là các tab hiện thêm trên thanh menu công khai, nằm giữa "Trang chủ" và "Đăng nhập". "Trang chủ" luôn có sẵn, không xóa được.
</div>

<div class="card p-3 mb-3">
  <form method="POST" action="/admin/menu" class="row g-2 align-items-end">
    <div class="col-md-4"><label class="form-label">Tên hiển thị</label><input name="label" class="form-control" placeholder="Vd: Khóa học, Sách..." required></div>
    <div class="col-md-6"><label class="form-label">Đường dẫn</label><input name="url" class="form-control" placeholder="Vd: /khoa-hoc  hoặc  https://..." required></div>
    <div class="col-md-2"><button class="btn btn-primary w-100">Thêm</button></div>
  </form>
</div>

<div class="card p-3">
  <ul class="list-group" id="menuList">
    <% items.forEach(item => { %>
      <li class="list-group-item d-flex justify-content-between align-items-center" data-id="<%= item.id %>">
        <span><i class="fa-solid fa-grip-vertical drag-handle me-2"></i><%= item.label %> <span class="text-muted small">(<%= item.url %>)</span></span>
        <span>
          <form method="POST" action="/admin/menu/<%= item.id %>/bat-tat" class="d-inline">
            <button class="btn btn-sm btn-outline-<%= item.is_active ? 'success' : 'secondary' %>"><%= item.is_active ? 'Đang hiện' : 'Đang ẩn' %></button>
          </form>
          <form method="POST" action="/admin/menu/<%= item.id %>/xoa" class="d-inline" onsubmit="return confirm('Xóa mục menu này?')">
            <button class="btn btn-sm btn-outline-danger">Xóa</button>
          </form>
        </span>
      </li>
    <% }) %>
    <% if (items.length === 0) { %><li class="list-group-item text-muted">Chưa có mục nào ngoài "Trang chủ".</li><% } %>
  </ul>
</div>

<script>
new Sortable(document.getElementById('menuList'), {
  handle: '.drag-handle', animation: 150,
  onEnd: () => {
    const ids = [...document.querySelectorAll('#menuList > li')].map(el => el.dataset.id).filter(Boolean);
    fetch('/admin/menu/sap-xep', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ ids }) });
  }
});
</script>

<%- include('../partials/admin-footer') %>
