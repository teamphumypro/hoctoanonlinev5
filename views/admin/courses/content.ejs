<% var pageTitle = 'Nội dung: ' + course.title %>
<%- include('../../partials/admin-header') %>

<button class="btn btn-primary btn-sm mb-3" data-bs-toggle="modal" data-bs-target="#addChapterModal">+ Thêm chương</button>

<div id="chapterList">
  <% chapters.forEach(ch => { %>
    <div class="card p-3 mb-3" data-id="<%= ch.id %>">
      <div class="d-flex justify-content-between align-items-center mb-2">
        <h6 class="fw-bold mb-0"><i class="fa-solid fa-grip-vertical drag-handle chapter-handle me-2"></i><%= ch.title %></h6>
        <div>
          <button class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#addLessonModal" data-chapter="<%= ch.id %>">+ Bài học</button>
          <form method="POST" action="/admin/chuong/<%= ch.id %>/xoa" class="d-inline" onsubmit="return confirm('Xóa chương này và toàn bộ bài học bên trong?')">
            <input type="hidden" name="course_id" value="<%= course.id %>">
            <button class="btn btn-sm btn-outline-danger">Xóa chương</button>
          </form>
        </div>
      </div>
      <ul class="list-group lesson-list" data-chapter="<%= ch.id %>">
        <% ch.lessons.forEach(l => { %>
          <li class="list-group-item" data-id="<%= l.id %>">
            <div class="d-flex justify-content-between align-items-center">
              <span><i class="fa-solid fa-grip-vertical drag-handle lesson-handle me-2"></i>
                <%= l.title %> <% if (l.is_preview) { %><span class="badge bg-success ms-1">Học thử</span><% } %>
              </span>
              <div>
                <button class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#addVideoModal" data-lesson="<%= l.id %>">+ Video</button>
                <button class="btn btn-sm btn-outline-secondary" data-bs-toggle="modal" data-bs-target="#addFileModal" data-lesson="<%= l.id %>">+ Tài liệu</button>
                <a href="/admin/bai-hoc/<%= l.id %>/bai-kiem-tra" class="btn btn-sm btn-outline-warning"><%= l.quiz ? 'Sửa bài KT' : '+ Bài kiểm tra' %></a>
                <form method="POST" action="/admin/bai-hoc/<%= l.id %>/xoa" class="d-inline" onsubmit="return confirm('Xóa bài học này?')">
                  <input type="hidden" name="course_id" value="<%= course.id %>">
                  <button class="btn btn-sm btn-outline-danger">Xóa</button>
                </form>
              </div>
            </div>
            <% if (l.videos.length || l.files.length) { %>
              <ul class="list-unstyled small mt-2 ms-4 mb-0">
                <% l.videos.forEach(v => { %>
                  <li class="text-muted"><i class="fa-solid fa-video text-primary"></i> <%= v.title %> <span class="badge bg-light text-dark"><%= v.source_type %></span>
                    <form method="POST" action="/admin/video/<%= v.id %>/xoa" class="d-inline" onsubmit="return confirm('Xóa video?')">
                      <input type="hidden" name="course_id" value="<%= course.id %>">
                      <button class="btn btn-sm btn-link text-danger p-0 ms-1">xóa</button>
                    </form>
                  </li>
                <% }) %>
                <% l.files.forEach(f => { %>
                  <li class="text-muted"><i class="fa-solid fa-file"></i> <%= f.title %>
                    <form method="POST" action="/admin/tai-lieu/<%= f.id %>/xoa" class="d-inline" onsubmit="return confirm('Xóa tài liệu?')">
                      <input type="hidden" name="course_id" value="<%= course.id %>">
                      <button class="btn btn-sm btn-link text-danger p-0 ms-1">xóa</button>
                    </form>
                  </li>
                <% }) %>
              </ul>
            <% } %>
          </li>
        <% }) %>
      </ul>
    </div>
  <% }) %>
  <% if (chapters.length === 0) { %><p class="text-muted">Chưa có chương nào. Bấm "+ Thêm chương" để bắt đầu.</p><% } %>
</div>

<!-- Modal: Them chuong -->
<div class="modal fade" id="addChapterModal"><div class="modal-dialog"><div class="modal-content">
  <form method="POST" action="/admin/chuong">
    <div class="modal-header"><h5 class="modal-title">Thêm chương</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
    <div class="modal-body">
      <input type="hidden" name="course_id" value="<%= course.id %>">
      <input name="title" class="form-control" placeholder="Tên chương" required>
    </div>
    <div class="modal-footer"><button class="btn btn-primary">Thêm</button></div>
  </form>
</div></div></div>

<!-- Modal: Them bai hoc -->
<div class="modal fade" id="addLessonModal"><div class="modal-dialog"><div class="modal-content">
  <form method="POST" action="/admin/bai-hoc">
    <div class="modal-header"><h5 class="modal-title">Thêm bài học</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
    <div class="modal-body">
      <input type="hidden" name="course_id" value="<%= course.id %>">
      <input type="hidden" name="chapter_id" id="lessonChapterId">
      <div class="mb-2"><input name="title" class="form-control" placeholder="Tên bài học" required></div>
      <div class="mb-2"><textarea name="content" class="form-control" rows="3" placeholder="Nội dung bài học (tùy chọn)"></textarea></div>
      <div class="form-check"><input type="checkbox" name="is_preview" class="form-check-input"><label class="form-check-label">Cho học thử miễn phí</label></div>
    </div>
    <div class="modal-footer"><button class="btn btn-primary">Thêm</button></div>
  </form>
</div></div></div>

<!-- Modal: Them video -->
<div class="modal fade" id="addVideoModal"><div class="modal-dialog"><div class="modal-content">
  <form method="POST" action="/admin/video" enctype="multipart/form-data">
    <div class="modal-header"><h5 class="modal-title">Thêm video</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
    <div class="modal-body">
      <input type="hidden" name="course_id" value="<%= course.id %>">
      <input type="hidden" name="lesson_id" id="videoLessonId">
      <div class="mb-2"><input name="title" class="form-control" placeholder="Tên video" required></div>
      <div class="mb-2">
        <select name="source_type" class="form-select" id="videoSourceType">
          <option value="youtube">YouTube (dán link)</option>
          <option value="vimeo">Vimeo (dán link)</option>
          <option value="drive">Google Drive (dán link chia sẻ)</option>
          <option value="upload">Upload file MP4</option>
        </select>
      </div>
      <div class="mb-2" id="videoUrlField"><input name="source_value" class="form-control" placeholder="Dán link video vào đây"></div>
      <div class="mb-2 d-none" id="videoFileField"><input type="file" name="video_file" class="form-control" accept="video/mp4"></div>
    </div>
    <div class="modal-footer"><button class="btn btn-primary">Thêm</button></div>
  </form>
</div></div></div>

<!-- Modal: Them tai lieu -->
<div class="modal fade" id="addFileModal"><div class="modal-dialog"><div class="modal-content">
  <form method="POST" action="/admin/tai-lieu" enctype="multipart/form-data">
    <div class="modal-header"><h5 class="modal-title">Thêm tài liệu / PDF</h5><button class="btn-close" data-bs-dismiss="modal"></button></div>
    <div class="modal-body">
      <input type="hidden" name="course_id" value="<%= course.id %>">
      <input type="hidden" name="lesson_id" id="fileLessonId">
      <div class="mb-2"><input name="title" class="form-control" placeholder="Tên tài liệu" required></div>
      <div class="mb-2"><input type="file" name="file" class="form-control" required></div>
    </div>
    <div class="modal-footer"><button class="btn btn-primary">Thêm</button></div>
  </form>
</div></div></div>

<script>
document.getElementById('addLessonModal').addEventListener('show.bs.modal', e => {
  document.getElementById('lessonChapterId').value = e.relatedTarget.dataset.chapter;
});
document.getElementById('addVideoModal').addEventListener('show.bs.modal', e => {
  document.getElementById('videoLessonId').value = e.relatedTarget.dataset.lesson;
});
document.getElementById('addFileModal').addEventListener('show.bs.modal', e => {
  document.getElementById('fileLessonId').value = e.relatedTarget.dataset.lesson;
});
document.getElementById('videoSourceType').addEventListener('change', e => {
  const isUpload = e.target.value === 'upload';
  document.getElementById('videoUrlField').classList.toggle('d-none', isUpload);
  document.getElementById('videoFileField').classList.toggle('d-none', !isUpload);
});

// Keo tha sap xep chuong
new Sortable(document.getElementById('chapterList'), {
  handle: '.chapter-handle',
  animation: 150,
  onEnd: () => {
    const ids = [...document.querySelectorAll('#chapterList > div')].map(el => el.dataset.id);
    fetch('/admin/chuong/sap-xep', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ ids }) });
  }
});
// Keo tha sap xep bai hoc trong tung chuong
document.querySelectorAll('.lesson-list').forEach(list => {
  new Sortable(list, {
    handle: '.lesson-handle',
    animation: 150,
    onEnd: () => {
      const ids = [...list.querySelectorAll('li')].map(el => el.dataset.id);
      fetch('/admin/bai-hoc/sap-xep', { method: 'POST', headers: {'Content-Type':'application/json'}, body: JSON.stringify({ ids }) });
    }
  });
});
</script>
<%- include('../../partials/admin-footer') %>
