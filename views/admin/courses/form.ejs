<% var pageTitle = course ? 'Sửa khóa học' : 'Thêm khóa học' %>
<%- include('../../partials/admin-header') %>
<div class="card p-4" style="max-width:700px">
  <form method="POST" action="<%= course ? '/admin/khoa-hoc/' + course.id : '/admin/khoa-hoc' %>" enctype="multipart/form-data">
    <div class="mb-3"><label class="form-label">Tên khóa học</label>
      <input name="title" class="form-control" value="<%= course ? course.title : '' %>" required></div>
    <div class="row">
      <div class="col-md-6 mb-3"><label class="form-label">Danh mục</label>
        <select name="category_id" class="form-select">
          <option value="">-- Chọn danh mục --</option>
          <% categories.forEach(c => { %>
            <option value="<%= c.id %>" <%= course && course.category_id === c.id ? 'selected' : '' %>><%= c.name %></option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-6 mb-3"><label class="form-label">Giảng viên</label>
        <select name="teacher_id" class="form-select">
          <option value="">-- Chọn giảng viên --</option>
          <% teachers.forEach(t => { %>
            <option value="<%= t.id %>" <%= course && course.teacher_id === t.id ? 'selected' : '' %>><%= t.name %> (<%= t.role %>)</option>
          <% }) %>
        </select>
      </div>
    </div>
    <div class="mb-3"><label class="form-label">Mô tả ngắn</label>
      <input name="short_desc" class="form-control" value="<%= course ? course.short_desc : '' %>"></div>
    <div class="mb-3"><label class="form-label">Mô tả chi tiết</label>
      <div id="descEditor" style="height:200px; background:#fff"></div>
      <input type="hidden" name="description" id="descHidden" value="<%= course ? course.description : '' %>"></div>
    <div class="row">
      <div class="col-md-6 mb-3"><label class="form-label">Giá bán (VNĐ, 0 = miễn phí)</label>
        <input type="number" name="price" class="form-control" value="<%= course ? course.price : 0 %>"></div>
      <div class="col-md-6 mb-3"><label class="form-label">Giá gốc (tùy chọn, hiện gạch ngang nếu đang giảm giá)</label>
        <input type="number" name="compare_at_price" class="form-control" value="<%= course && course.compare_at_price ? course.compare_at_price : '' %>" placeholder="Để trống nếu không giảm giá"></div>
    </div>

    <div class="mb-3">
      <label class="form-label">Video giới thiệu khóa học (tùy chọn)</label>
      <input type="url" name="intro_video_url" class="form-control" value="<%= course && course.intro_video_url ? course.intro_video_url : '' %>" placeholder="Dán link Youtube/Vimeo/Google Drive/bất kỳ nguồn nào">
      <div class="form-text">Nếu để trống, trang chi tiết khóa học sẽ tự dùng video của bài "Học thử" đầu tiên (nếu có), hoặc hiện ảnh đại diện.</div>
    </div>

    <div class="mb-3">
      <label class="form-label">Ảnh đại diện</label>
      <% if (course && course.thumbnail_url) { %>
        <div class="mb-2"><img src="<%= course.thumbnail_url %>" style="height:80px;border-radius:8px" onerror="this.style.display='none'"></div>
      <% } %>
      <div class="btn-group btn-group-sm mb-2" role="group">
        <input type="radio" class="btn-check" name="thumb_mode" id="thumbModeUpload" checked>
        <label class="btn btn-outline-secondary" for="thumbModeUpload">Tải ảnh lên</label>
        <input type="radio" class="btn-check" name="thumb_mode" id="thumbModeLink">
        <label class="btn btn-outline-secondary" for="thumbModeLink">Dán link ảnh</label>
      </div>
      <div id="thumbUploadField">
        <input type="file" name="thumbnail" class="form-control" accept="image/*">
      </div>
      <div id="thumbLinkField" class="d-none">
        <input type="url" name="thumbnail_url_link" class="form-control" placeholder="https://..." value="<%= course && course.thumbnail_url && course.thumbnail_url.startsWith('http') ? course.thumbnail_url : '' %>">
      </div>
    </div>
    <div class="form-check mb-3">
      <input type="checkbox" name="is_published" class="form-check-input" <%= (!course || course.is_published) ? 'checked' : '' %>>
      <label class="form-check-label">Hiển thị công khai</label>
    </div>
    <button class="btn btn-primary">Lưu</button>
    <a href="/admin/khoa-hoc" class="btn btn-outline-secondary">Hủy</a>
  </form>
</div>
<script>
  const uploadField = document.getElementById('thumbUploadField');
  const linkField = document.getElementById('thumbLinkField');
  document.getElementById('thumbModeUpload').addEventListener('change', () => {
    uploadField.classList.remove('d-none'); linkField.classList.add('d-none');
  });
  document.getElementById('thumbModeLink').addEventListener('change', () => {
    linkField.classList.remove('d-none'); uploadField.classList.add('d-none');
  });
  // Neu dang sua khoa hoc va anh hien tai la 1 link ngoai (khong phai upload noi bo), mac dinh mo che do "Dan link"
  <% if (course && course.thumbnail_url && course.thumbnail_url.startsWith('http')) { %>
    document.getElementById('thumbModeLink').checked = true;
    linkField.classList.remove('d-none'); uploadField.classList.add('d-none');
  <% } %>
</script>
<link href="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.snow.css" rel="stylesheet">
<script src="https://cdn.jsdelivr.net/npm/quill@1.3.7/dist/quill.min.js"></script>
<script>
  const descQuill = new Quill('#descEditor', {
    theme: 'snow',
    modules: { toolbar: [['bold','italic','underline'],[{list:'ordered'},{list:'bullet'}],['link'],[{header:[2,3,false]}],['clean']] }
  });
  descQuill.root.innerHTML = document.getElementById('descHidden').value;
  document.querySelector('form').addEventListener('submit', () => {
    document.getElementById('descHidden').value = descQuill.root.innerHTML;
  });
</script>
<%- include('../../partials/admin-footer') %>
