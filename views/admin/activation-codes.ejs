<% var pageTitle = 'Mã kích hoạt' %>
<%- include('../partials/admin-header') %>
<div class="card p-3 mb-3">
  <form method="POST" action="/admin/ma-kich-hoat" class="row g-2 align-items-end">
    <div class="col-md-4">
      <label class="form-label">Khóa học</label>
      <select name="course_id" class="form-select" onchange="location='/admin/ma-kich-hoat?course_id='+this.value">
        <% courses.forEach(c => { %>
          <option value="<%= c.id %>" <%= selectedCourseId === c.id ? 'selected' : '' %>><%= c.title %></option>
        <% }) %>
      </select>
    </div>
    <div class="col-md-3">
      <label class="form-label">Số lượng mã cần tạo</label>
      <input type="number" name="quantity" class="form-control" value="10" min="1" max="200">
    </div>
    <div class="col-md-3">
      <label class="form-label">Hạn dùng (ngày, để trống = vô hạn)</label>
      <input type="number" name="expiry_days" class="form-control" placeholder="Vd: 30">
    </div>
    <input type="hidden" name="course_id" value="<%= selectedCourseId %>">
    <div class="col-md-2"><button class="btn btn-primary w-100">Tạo mã</button></div>
  </form>
</div>
<div class="card p-3">
  <table class="table">
    <thead><tr><th>Mã</th><th>Trạng thái</th><th>Hạn dùng</th><th>Ngày tạo</th><th></th></tr></thead>
    <tbody>
      <% codes.forEach(c => { %>
        <% var st = !c.is_active ? 'vo_hieu_hoa' : (c.is_used ? 'da_dung' : (c.expires_at && new Date(c.expires_at) < new Date() ? 'het_han' : 'chua_dung')); %>
        <tr>
          <td><code><%= c.code %></code></td>
          <td>
            <% if (st === 'chua_dung') { %><span class="badge bg-success">Chưa dùng</span>
            <% } else if (st === 'da_dung') { %><span class="badge bg-secondary">Đã dùng</span>
            <% } else if (st === 'het_han') { %><span class="badge bg-danger">Hết hạn</span>
            <% } else { %><span class="badge bg-dark">Đã vô hiệu hóa</span><% } %>
          </td>
          <td><%= c.expires_at ? formatDate(c.expires_at) : 'Vô hạn' %></td>
          <td><%= formatDate(c.created_at) %></td>
          <td class="text-nowrap">
            <% if (st === 'chua_dung' || st === 'het_han') { %>
              <form method="POST" action="/admin/ma-kich-hoat/<%= c.id %>/vo-hieu-hoa" class="d-inline" onsubmit="return confirm('Vô hiệu hóa mã này?')">
                <button class="btn btn-sm btn-outline-warning">Vô hiệu hóa</button>
              </form>
            <% } else if (st === 'vo_hieu_hoa') { %>
              <form method="POST" action="/admin/ma-kich-hoat/<%= c.id %>/kich-hoat-lai" class="d-inline">
                <button class="btn btn-sm btn-outline-success">Kích hoạt lại</button>
              </form>
            <% } %>
            <% if (!c.is_used) { %>
              <form method="POST" action="/admin/ma-kich-hoat/<%= c.id %>/xoa" class="d-inline" onsubmit="return confirm('Xóa mã này?')">
                <button class="btn btn-sm btn-outline-danger">Xóa</button>
              </form>
            <% } %>
          </td>
        </tr>
      <% }) %>
      <% if (codes.length === 0) { %><tr><td colspan="5" class="text-center text-muted">Chưa có mã nào cho khóa học này.</td></tr><% } %>
    </tbody>
  </table>
</div>
<%- include('../partials/admin-footer') %>
