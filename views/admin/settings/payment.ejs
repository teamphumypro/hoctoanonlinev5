<% var pageTitle = 'Cài đặt thanh toán' %>
<%- include('../../partials/admin-header') %>

<% if (success) { %><div class="alert alert-success"><%= success %></div><% } %>

<form method="POST" action="/admin/cai-dat/thanh-toan">
  <div class="card p-4 mb-3">
    <h6 class="fw-bold mb-3">💳 VNPay</h6>
    <p class="small text-muted">Đăng ký tài khoản merchant test miễn phí tại <a href="https://sandbox.vnpayment.vn" target="_blank">sandbox.vnpayment.vn</a> để lấy 2 mã bên dưới.</p>
    <div class="row">
      <div class="col-md-6 mb-3"><label class="form-label">Mã Terminal (TMN Code)</label>
        <input name="vnp_tmn_code" class="form-control" value="<%= config.vnp_tmn_code || '' %>"></div>
      <div class="col-md-6 mb-3"><label class="form-label">Chuỗi bí mật (Hash Secret)</label>
        <input name="vnp_hash_secret" class="form-control" value="<%= config.vnp_hash_secret || '' %>"></div>
    </div>
    <div class="mb-1"><label class="form-label">Cổng thanh toán (để mặc định nếu dùng sandbox test)</label>
      <input name="vnp_url" class="form-control" value="<%= config.vnp_url || 'https://sandbox.vnpayment.vn/paymentv2/vpcpay.html' %>"></div>
  </div>

  <div class="card p-4 mb-3">
    <h6 class="fw-bold mb-3">💰 Ví MoMo</h6>
    <p class="small text-muted">Đăng ký merchant test tại <a href="https://business.momo.vn" target="_blank">business.momo.vn</a>.</p>
    <div class="row">
      <div class="col-md-4 mb-3"><label class="form-label">Partner Code</label>
        <input name="momo_partner_code" class="form-control" value="<%= config.momo_partner_code || '' %>"></div>
      <div class="col-md-4 mb-3"><label class="form-label">Access Key</label>
        <input name="momo_access_key" class="form-control" value="<%= config.momo_access_key || '' %>"></div>
      <div class="col-md-4 mb-3"><label class="form-label">Secret Key</label>
        <input name="momo_secret_key" class="form-control" value="<%= config.momo_secret_key || '' %>"></div>
    </div>
  </div>

  <div class="card p-4 mb-3">
    <h6 class="fw-bold mb-3">🅩 ZaloPay</h6>
    <p class="small text-muted">Đăng ký merchant test tại <a href="https://docs.zalopay.vn" target="_blank">docs.zalopay.vn</a>.</p>
    <div class="row">
      <div class="col-md-6 mb-3"><label class="form-label">App ID</label>
        <input name="zalopay_app_id" class="form-control" value="<%= config.zalopay_app_id || '' %>"></div>
      <div class="col-md-6 mb-3"><label class="form-label">Key1</label>
        <input name="zalopay_key1" class="form-control" value="<%= config.zalopay_key1 || '' %>"></div>
    </div>
  </div>

  <div class="card p-4 mb-3 border-success">
    <h6 class="fw-bold mb-3">⚡ SePay — Tự động xác nhận chuyển khoản QR (khuyên dùng)</h6>
    <p class="small text-muted">
      Đăng ký miễn phí tại <a href="https://sepay.vn" target="_blank">sepay.vn</a>, liên kết tài khoản ngân hàng của bạn (đúng số tài khoản đã điền ở mục "Chuyển khoản QR" bên dưới).
      Sau đó vào <strong>Tích hợp → Webhooks → Thêm webhook</strong>, điền URL nhận webhook là:
    </p>
    <div class="mb-2">
      <code style="word-break:break-all">https://<em>tên-miền-của-bạn</em>.onrender.com/webhook/sepay</code>
    </div>
    <p class="small text-muted">Chọn xác thực kiểu <strong>API Key</strong>, tự đặt 1 chuỗi bất kỳ làm API Key rồi dán vào ô bên dưới:</p>
    <div class="mb-1"><label class="form-label">API Key (phải khớp với API Key bạn đặt bên SePay)</label>
      <input name="sepay_api_key" class="form-control" value="<%= config.sepay_api_key || '' %>"></div>
  </div>

  <div class="card p-4 mb-3">
    <h6 class="fw-bold mb-3">🏦 Chuyển khoản QR (VietQR — miễn phí, dùng ngay không cần đăng ký)</h6>
    <div class="row">
      <div class="col-md-4 mb-3"><label class="form-label">Mã ngân hàng (BIN)</label>
        <input name="bank_bin" class="form-control" value="<%= config.bank_bin || '970436' %>">
        <div class="form-text">Vd: Vietcombank = 970436, Techcombank = 970407, ACB = 970416, MB Bank = 970422... <a href="https://api.vietqr.io/v2/banks" target="_blank">tra cứu đầy đủ</a></div>
      </div>
      <div class="col-md-4 mb-3"><label class="form-label">Số tài khoản</label>
        <input name="bank_account_no" class="form-control" value="<%= config.bank_account_no || '' %>"></div>
      <div class="col-md-4 mb-3"><label class="form-label">Tên chủ tài khoản (không dấu, IN HOA)</label>
        <input name="bank_account_name" class="form-control" value="<%= config.bank_account_name || '' %>" placeholder="NGUYEN VAN A"></div>
    </div>
  </div>

  <button class="btn btn-primary">Lưu cài đặt</button>
</form>

<%- include('../../partials/admin-footer') %>
