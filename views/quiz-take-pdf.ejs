<% var pageTitle = quiz.title %>
<%- include('partials/header') %>

<div class="mb-2">
  <h5 class="fw-bold mb-1"><%= quiz.title %></h5>
  <p class="text-muted small mb-0">Tổng điểm: <%= totalPoints %> — Cần đạt tối thiểu <strong><%= quiz.pass_score %></strong> điểm.
    <% if (quiz.is_standalone) { %> — <a href="/thi/<%= quiz.id %>/xep-hang">Xem bảng xếp hạng</a><% } %>
  </p>
  <% if (quiz.time_limit_minutes && quizStart) { %>
    <div id="examTimer" class="alert alert-primary d-flex justify-content-between align-items-center small fw-bold py-1 px-2 mb-2">
      <span><i class="fa-solid fa-clock"></i> Thời gian còn lại</span>
      <span id="timerDisplay" class="fs-6">--:--</span>
    </div>
  <% } %>
  <% if (bestAttempt) { %>
    <div class="alert alert-<%= bestAttempt.passed ? 'success' : 'warning' %> small py-1 px-2 mb-2">
      Kết quả tốt nhất trước đó: <strong><%= bestAttempt.score %>/<%= bestAttempt.total %></strong> — <%= bestAttempt.passed ? 'Đạt' : 'Chưa đạt' %>.
    </div>
  <% } %>
</div>

<% if (questions.length === 0) { %>
  <p class="text-muted">Bài kiểm tra này chưa có câu hỏi.</p>
<% } else { %>

<div class="d-flex gap-2 mb-2">
  <button type="button" id="modeDesktopBtn" class="btn btn-sm btn-outline-secondary">Xem 2 cột</button>
  <button type="button" id="modeMobileBtn" class="btn btn-sm btn-outline-secondary">Xem từng phần</button>
</div>

<div id="examFrame" class="border rounded" style="overflow:hidden;">
  <div class="d-flex align-items-center justify-content-between px-2 py-2 border-bottom bg-light">
    <div class="small">Trang <span id="pageNoLabel">1</span> / <%= quiz.pdf_total_pages || 1 %></div>
    <div class="d-flex gap-1">
      <button type="button" id="prevPageBtn" class="btn btn-sm btn-outline-secondary">&larr; Trang trước</button>
      <button type="button" id="nextPageBtn" class="btn btn-sm btn-outline-secondary">Trang sau &rarr;</button>
    </div>
  </div>

  <div id="tabsBar" class="d-none border-bottom">
    <button type="button" id="tabExamBtn" class="btn btn-sm w-50 rounded-0">Đề thi</button>
    <button type="button" id="tabAnswerBtn" class="btn btn-sm w-50 rounded-0">Bài làm</button>
  </div>

  <div id="frameBody" class="d-flex">
    <div id="examPane" style="flex:1 1 60%; border-right:1px solid #eee; overflow:auto; max-height:75vh; text-align:center; background:#f8f8f8;">
      <div id="canvasWrap" style="position:relative; display:inline-block;">
        <canvas id="pdfCanvas" style="max-width:100%; display:block;"></canvas>
        <div id="overlayLayer" style="position:absolute; left:0; top:0; right:0; bottom:0; pointer-events:none;"></div>
      </div>
    </div>
    <div id="answerPane" style="flex:1 1 40%; min-width:260px; overflow:auto; max-height:75vh; padding:12px;">
      <div id="questionsOnPage"></div>
    </div>
  </div>
</div>

<p class="small text-muted mt-1">Có thể bấm thẳng vào chữ A/B/C/D trên trang đề (nếu nhận đúng vị trí), hoặc chọn ở bảng bên phải như bình thường — hai bên luôn đồng bộ.</p>

<div class="d-flex align-items-center gap-2 mt-2 flex-wrap" id="jumpStrip"></div>

<form method="POST" action="/thi/<%= quiz.id %>/nop-bai" id="quizForm" class="mt-3">
  <button class="btn btn-primary">Nộp bài</button>
  <span class="small text-muted ms-2">Đã làm <span id="answeredCount">0</span>/<%= questions.length %> câu</span>
</form>

<% } %>

<style>
  #overlayLayer{ z-index:2; }
  .pdf-overlay-dot{
    position:absolute; pointer-events:auto; border-radius:50%;
    border:2px solid #0d6efd; background:rgba(13,110,253,.12);
    cursor:pointer; transition:background .15s, transform .1s;
  }
  .pdf-overlay-dot:hover{ background:rgba(13,110,253,.28); transform:scale(1.08); }
  .pdf-overlay-dot.picked{ background:#0d6efd; border-color:#0d6efd; }
</style>

<script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
<script>
const questions = <%- JSON.stringify(questions) %>;
const pdfUrl = <%- JSON.stringify(quiz.pdf_source_path) %>;
const totalPages = <%- quiz.pdf_total_pages || 1 %>;
const answers = {};

function letterAt(i) { return String.fromCharCode(65 + i); }

pdfjsLib.GlobalWorkerOptions.workerSrc = 'https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.worker.min.js';
let pdfDoc = null;
let currentPage = 1;
const canvas = document.getElementById('pdfCanvas');
const ctx = canvas.getContext('2d');

async function renderPage(n) {
  n = Math.min(Math.max(1, n), totalPages);
  currentPage = n;
  document.getElementById('pageNoLabel').textContent = n;
  document.getElementById('overlayLayer').innerHTML = '';
  let viewport = null;
  if (pdfDoc) {
    const page = await pdfDoc.getPage(n);
    viewport = page.getViewport({ scale: 1.4 });
    canvas.width = viewport.width;
    canvas.height = viewport.height;
    await page.render({ canvasContext: ctx, viewport }).promise;
    buildOverlay(page, viewport, questions.filter(q => q.page_number === n));
  }
  renderAnswerPane();
}
pdfjsLib.getDocument(pdfUrl).promise.then(doc => { pdfDoc = doc; renderPage(1); });
document.getElementById('prevPageBtn').onclick = () => renderPage(currentPage - 1);
document.getElementById('nextPageBtn').onclick = () => renderPage(currentPage + 1);

// ---- Lop "nut bam de tren trang" (giong cam giac Azota) - CHI LA LOP LAM DEP THEM. Neu khong
// dinh vi duoc tin cay (font/layout PDF khac thuong), tu dong khong hien gi ca va hoc sinh van
// dung bang tra loi ben canh binh thuong - khong bao gio chan duoc viec lam bai. ----
let overlayDots = [];

function paintOverlay() {
  overlayDots.forEach(d => {
    const picked = d.kind === 'single' ? answers[d.qid] === d.valueId : ((answers[d.qid] || {})[d.valueId] === 'true');
    d.el.classList.toggle('picked', !!picked);
  });
}

async function buildOverlay(page, viewport, questionsOnPage) {
  overlayDots = [];
  const layer = document.getElementById('overlayLayer');
  layer.innerHTML = '';
  const relevant = questionsOnPage.filter(q => q.type === 'single_choice' || q.type === 'true_false');
  if (relevant.length === 0) return;

  try {
    const textContent = await page.getTextContent();
    const items = textContent.items
      .map(it => {
        const tx = pdfjsLib.Util.transform(viewport.transform, it.transform);
        const h = Math.hypot(tx[2], tx[3]);
        return { str: it.str, x: tx[4], yTop: tx[5] - h, yBottom: tx[5], height: h };
      })
      .filter(it => it.str.trim() !== '');
    if (items.length === 0) return;

    // Gom thanh tung "dong" theo do gan nhau cua truc y
    items.sort((a, b) => (a.yTop - b.yTop) || (a.x - b.x));
    const lines = [];
    items.forEach(it => {
      const mid = (it.yTop + it.yBottom) / 2;
      let line = lines.find(l => Math.abs(l.midY - mid) < it.height * 0.6);
      if (!line) { line = { midY: mid, items: [] }; lines.push(line); }
      line.items.push(it);
    });
    lines.forEach(l => l.items.sort((a, b) => a.x - b.x));

    // Tim tung nhan "A." "B." ... hoac "a)" "b)" ... (co the tach thanh 2 item: chu cai + dau cham)
    const found = [];
    lines.forEach(line => {
      for (let i = 0; i < line.items.length; i++) {
        const it = line.items[i];
        const s = it.str.trim();
        let label = null;
        if (/^[A-Ha-h][.)]$/.test(s)) label = s[0];
        else if (/^[A-Ha-h]$/.test(s) && line.items[i + 1]) {
          const next = line.items[i + 1];
          if (/^[.)]/.test(next.str.trim()) && (next.x - it.x) < it.height * 3) label = s;
        }
        if (label) found.push({ label, isUpper: /[A-H]/.test(label), x: it.x, yTop: it.yTop, height: it.height });
      }
    });
    if (found.length === 0) return;

    // Gan lan luot cac nhan tim duoc cho tung cau tren trang, theo dung SO LUONG phuong an server
    // da bao truoc (khong tu doan lai loai cau o day) - neu khong du nhan tin cay thi bo qua cau do.
    let cursor = 0;
    relevant.sort((a, b) => a.displayNumber - b.displayNumber).forEach(q => {
      const wantUpper = q.type === 'single_choice';
      const values = q.type === 'single_choice' ? q.options : q.tfItems;
      const need = values.length;
      const candidates = found.slice(cursor).filter(f => f.isUpper === wantUpper);
      if (candidates.length < need) return;
      const picked = candidates.slice(0, need);
      cursor = found.indexOf(picked[picked.length - 1]) + 1;

      picked.forEach((f, i) => {
        const size = Math.max(16, Math.round(f.height * 1.5));
        const btn = document.createElement('button');
        btn.type = 'button';
        btn.className = 'pdf-overlay-dot';
        btn.style.left = Math.round(f.x - size * 1.1) + 'px';
        btn.style.top = Math.round(f.yTop - (size - f.height) / 2) + 'px';
        btn.style.width = btn.style.height = size + 'px';
        btn.title = 'Chọn ' + f.label.toUpperCase();
        const valueId = q.type === 'single_choice' ? values[i].id : values[i].id;
        btn.addEventListener('click', () => {
          if (q.type === 'single_choice') { answers[q.id] = valueId; }
          else { answers[q.id] = answers[q.id] || {}; answers[q.id][valueId] = 'true'; }
          updateAnsweredCount();
          renderAnswerPane();
          paintOverlay();
        });
        layer.appendChild(btn);
        overlayDots.push({ el: btn, qid: q.id, kind: q.type === 'single_choice' ? 'single' : 'tf', valueId });
      });
    });
    paintOverlay();
  } catch (err) {
    // Khong dinh vi duoc (PDF co font/layout dac biet) - im lang bo qua, dung bang ben canh nhu binh thuong.
    console.error('Không đặt được nút chọn trên trang PDF, dùng bảng trả lời bên cạnh:', err.message);
  }
}

function updateAnsweredCount() {
  document.getElementById('answeredCount').textContent = Object.keys(answers).filter(k => {
    const v = answers[k];
    if (v == null) return false;
    if (typeof v === 'object') return Object.keys(v).length > 0;
    return String(v).trim() !== '';
  }).length;
}

function renderAnswerPane() {
  const wrap = document.getElementById('questionsOnPage');
  const onPage = questions.filter(q => q.page_number === currentPage);
  if (onPage.length === 0) {
    wrap.innerHTML = '<p class="text-muted small">Trang này không có câu hỏi cần làm.</p>';
    return;
  }
  wrap.innerHTML = '';
  onPage.forEach(q => {
    const box = document.createElement('div');
    box.className = 'mb-3 pb-2 border-bottom';
    const title = document.createElement('p');
    title.className = 'fw-semibold small mb-1';
    title.textContent = 'Câu ' + q.displayNumber + ' (' + q.points + 'đ)';
    box.appendChild(title);

    if (q.type === 'single_choice') {
      q.options.forEach((o, i) => {
        const id = 'opt_' + o.id;
        const row = document.createElement('div');
        row.className = 'form-check';
        row.innerHTML = '<input class="form-check-input" type="radio" name="answers[' + q.id + ']" value="' + o.id + '" id="' + id + '" ' + (answers[q.id]==o.id?'checked':'') + '>' +
          '<label class="form-check-label small" for="' + id + '">' + letterAt(i) + '</label>';
        row.querySelector('input').addEventListener('change', () => { answers[q.id] = o.id; updateAnsweredCount(); paintOverlay(); });
        box.appendChild(row);
      });
    } else if (q.type === 'true_false') {
      const table = document.createElement('table');
      table.className = 'table table-sm small';
      table.innerHTML = '<thead><tr><th>Ý</th><th class="text-center">Đúng</th><th class="text-center">Sai</th></tr></thead><tbody></tbody>';
      const tbody = table.querySelector('tbody');
      q.tfItems.forEach((it, i) => {
        const tr = document.createElement('tr');
        const current = (answers[q.id] || {})[it.id];
        tr.innerHTML = '<td>' + String.fromCharCode(97+i) + ')</td>' +
          '<td class="text-center"><input type="radio" name="answers_tf[' + q.id + '][' + it.id + ']" value="true" ' + (current==='true'?'checked':'') + '></td>' +
          '<td class="text-center"><input type="radio" name="answers_tf[' + q.id + '][' + it.id + ']" value="false" ' + (current==='false'?'checked':'') + '></td>';
        tr.querySelectorAll('input').forEach(inp => inp.addEventListener('change', () => {
          answers[q.id] = answers[q.id] || {};
          answers[q.id][it.id] = inp.value;
          updateAnsweredCount();
          paintOverlay();
        }));
        tbody.appendChild(tr);
      });
      box.appendChild(table);
    } else if (q.type === 'short_answer') {
      const input = document.createElement('input');
      input.className = 'form-control form-control-sm';
      input.style.maxWidth = '200px';
      input.value = answers[q.id] || '';
      input.addEventListener('input', () => { answers[q.id] = input.value; updateAnsweredCount(); });
      box.appendChild(input);
    } else {
      const ta = document.createElement('textarea');
      ta.className = 'form-control form-control-sm';
      ta.rows = 6;
      ta.value = answers[q.id] || '';
      ta.addEventListener('input', () => { answers[q.id] = ta.value; updateAnsweredCount(); });
      box.appendChild(ta);
    }
    wrap.appendChild(box);
  });
}

const jumpStrip = document.getElementById('jumpStrip');
questions.forEach(q => {
  const btn = document.createElement('button');
  btn.type = 'button';
  btn.className = 'btn btn-sm btn-outline-secondary';
  btn.style.width = '36px';
  btn.textContent = q.displayNumber;
  btn.addEventListener('click', () => renderPage(q.page_number || 1));
  jumpStrip.appendChild(btn);
});

function setMode(mobile) {
  const tabsBar = document.getElementById('tabsBar');
  const examPane = document.getElementById('examPane');
  const answerPane = document.getElementById('answerPane');
  if (mobile) {
    tabsBar.classList.remove('d-none');
    examPane.style.display = 'block';
    answerPane.style.display = 'none';
    document.getElementById('tabExamBtn').onclick = () => { examPane.style.display='block'; answerPane.style.display='none'; };
    document.getElementById('tabAnswerBtn').onclick = () => { examPane.style.display='none'; answerPane.style.display='block'; };
  } else {
    tabsBar.classList.add('d-none');
    examPane.style.display = 'block';
    answerPane.style.display = 'block';
  }
}
document.getElementById('modeDesktopBtn').onclick = () => setMode(false);
document.getElementById('modeMobileBtn').onclick = () => setMode(true);
if (window.innerWidth < 768) setMode(true);

document.getElementById('quizForm').addEventListener('submit', () => {
  const form = document.getElementById('quizForm');
  Object.entries(answers).forEach(([qid, val]) => {
    const q = questions.find(x => String(x.id) === String(qid));
    if (!q) return;
    if (q.type === 'single_choice' || q.type === 'short_answer') {
      const inp = document.createElement('input');
      inp.type = 'hidden'; inp.name = 'answers[' + qid + ']'; inp.value = val;
      form.appendChild(inp);
    } else if (q.type === 'true_false') {
      Object.entries(val).forEach(([itemId, v]) => {
        const inp = document.createElement('input');
        inp.type = 'hidden'; inp.name = 'answers_tf[' + qid + '][' + itemId + ']'; inp.value = v;
        form.appendChild(inp);
      });
    } else if (q.type === 'essay') {
      const inp = document.createElement('input');
      inp.type = 'hidden'; inp.name = 'essay[' + qid + ']'; inp.value = val;
      form.appendChild(inp);
    }
  });
});
</script>

<% if (quiz.time_limit_minutes && quizStart) { %>
<script>
  const startedAt = new Date('<%= quizStart.started_at %>').getTime();
  const limitSeconds = <%= quiz.time_limit_minutes %> * 60;
  const display = document.getElementById('timerDisplay');
  let autoSubmitted = false;
  function tick() {
    const elapsed = Math.floor((Date.now() - startedAt) / 1000);
    const remaining = limitSeconds - elapsed;
    if (remaining <= 0) {
      display.textContent = '00:00';
      if (!autoSubmitted) {
        autoSubmitted = true;
        alert('Đã hết thời gian làm bài, hệ thống sẽ tự động nộp bài.');
        document.getElementById('quizForm').requestSubmit();
      }
      return;
    }
    const m = Math.floor(remaining / 60), s = remaining % 60;
    display.textContent = String(m).padStart(2,'0') + ':' + String(s).padStart(2,'0');
    if (remaining <= 60) document.getElementById('examTimer').classList.replace('alert-primary','alert-danger');
  }
  tick();
  setInterval(tick, 1000);
</script>
<% } %>

<%- include('partials/footer') %>
